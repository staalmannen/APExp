#!/bin/sh

# This script is a WIP. I have not bothered to pass any
# arguments to configure up until now because it is 
# annoying. When this script is finnished, most 
# packages that rely on configure will be configured
# with these reasonable defaults.
# Please correct me if I got any of these wrong.

./configure --enable-static --disable-shared\
	--disable-nls --prefix=/\
	--bindir=/bin --sbindir=/bin --libexecdir=/bin\
	--sysconfdir=/sys/lib --sharedstatedir=/srv\
	--localstatedir=/srv --runstatedir=/srv\
	--libdir=/$objtype/lib/ape\
	--includedir=/sys/include/ape\
	--oldincludedir=/$objtype/include/ape\
	--datarootdir=/sys/lib/ape --datadir=/sys/lib/ape\
	--infodir=/sys/lib/info\
	--localedir=/sys/lib/ape/locale\
	--mandir=/sys/man --docdir=/sys/doc\
	--htmldir=/sys/doc --dvidir=/sys/doc\
	--pdfdir=/sys/doc --psdir=/sys/doc\
	$*
	
	