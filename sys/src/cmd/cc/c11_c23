--- Not done ---

1. typeof / typeof_unqual operators
   EFFORT: medium (~100 lines across 4 files)
   PRIORITY: HIGH - __typeof__ is currently SILENTLY BROKEN (swallowed
             like __attribute__), corrupting any declaration using it.
   DESIGN:
     cc/lex.c:
       - Change __typeof__/__typeof__ case in the LNAME swallow block
         to NOT swallow — instead return LTYPEOF token.
       - Add "typeof" and "__typeof__" and "__typeof" to itab[] as LTYPEOF.
     cc/cc.y:
       %token LTYPEOF
       /* Expression context (typeof used like sizeof): */
       uexpr:
         LTYPEOF '(' cexpr ')'
           { $$ = new(OTYPEOF, $3, Z); }
       | LTYPEOF '(' tlist abdecor ')'
           { $$ = new(OTYPEOF, Z, Z);
             dodecl(NODECL, CXXX, $3, $4);
             $$->type = lastdcl; }
       /* Type-specifier context (__typeof__(x) y; declares y same type as x): */
       complex:
         ... existing rules ...
       | LTYPEOF '(' cexpr ')'
           { complex($3); $$ = $3->type != T ? $3->type : types[TINT]; }
       | LTYPEOF '(' tlist abdecor ')'
           { dodecl(NODECL, CXXX, $3, $4); $$ = lastdcl; }
     cc/com.c:
       case OTYPEOF:  (in tcom())
         if(l != Z) { if(tcomo(l,0)) goto bad; n->type = l->type; }
         if(n->type == T) goto bad;
         /* for typeof_unqual: strip const/volatile from n->type */
         break;
   NOTE: OTYPEOF opcode also needs adding to cc.h opcode enum.
         The complex/tlist path is the critical one for declarations
         like: __typeof__(errno) saved; or __typeof__(*ptr) tmp;

