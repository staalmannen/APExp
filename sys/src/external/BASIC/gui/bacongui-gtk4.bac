	{ type=BUTTON name=scratch_run callback=clicked label=\" Execute \" valign=GTK_ALIGN_END halign=GTK_ALIGN_END } \
	{ type=WINDOW name=exec_dialog callback=close-request title=\"Compile and Execute\" width-request=450 } \
	{ type=GRID name=exec_grid parent=exec_dialog column-spacing=5 row-spacing=5 } \
	{ type=BOX name=exec_box orientation=GTK_ORIENTATION_HORIZONTAL } \
	{ type=LABEL name=exec_label parent=exec_box label=\"Convert command: \" } \
	{ type=ENTRY name=exec_entry parent=exec_box hexpand=1 text=\"xterm -sb -geometry 132x40 -e 'bacon -r @; read'\" } \
	{ type=BUTTON name=exec_cancel callback=clicked label=\"Cancel\" vexpand=TRUE valign=GTK_ALIGN_END halign=GTK_ALIGN_START } \
	{ type=BUTTON name=exec_run callback=clicked label=\"Execute\" vexpand=TRUE valign=GTK_ALIGN_END halign=GTK_ALIGN_END } \
