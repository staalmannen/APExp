CALL GUIFN(id, "doc_grid", attach, GUIWIDGET(id, "doc_scroll"), 0, 0, 3, 1)
CALL GUIFN(id, "doc_grid", attach, GUIWIDGET(id, "doc_close"), 1, 1, 1, 1)
CALL GUIFN(id, "find_grid", attach, GUIWIDGET(id, "find_label"), 0, 0, 1, 1)
CALL GUIFN(id, "find_grid", attach, GUIWIDGET(id, "find_entry"), 1, 0, 1, 1)
CALL GUIFN(id, "find_grid", attach, GUIWIDGET(id, "find_check"), 1, 1, 1, 1)
CALL GUIFN(id, "find_grid", attach, GUIWIDGET(id, "find_cancel"), 0, 2, 1, 1)
CALL GUIFN(id, "find_grid", attach, GUIWIDGET(id, "find_term"), 1, 2, 1, 1)

' Set Clipboard object
clipBoard = gdk_display_get_clipboard(gdk_display_get_default())

' Load and format the documentation
txt_head = gtk_text_buffer_create_tag(dbuffer, "txt_head", "weight", PANGO_WEIGHT_ULTRABOLD, "scale", PANGO_SCALE_X_LARGE, NULL)
txt_bold = gtk_text_buffer_create_tag(dbuffer, "txt_bold", "weight", PANGO_WEIGHT_BOLD, "scale", PANGO_SCALE_LARGE, NULL)
txt_para = gtk_text_buffer_create_tag(dbuffer, "txt_para", "weight", PANGO_WEIGHT_BOLD, "scale", PANGO_SCALE_LARGE, "foreground", "red", NULL)
CALL gtk_text_buffer_get_start_iter(dbuffer, &start_iter)
FOR txt$ IN LOAD$(Data_Path$ & "/BaCon/documentation/documentation.txt") STEP NL$
	IF linenr = 0 THEN
		CALL gtk_text_buffer_insert_with_tags(dbuffer, &start_iter, CHOP$(txt$) & NL$, -1, txt_head, NULL)
	ELIF REGEX(txt$, "^[A-Z]+") THEN
		CALL gtk_text_buffer_insert_with_tags(dbuffer, &start_iter, txt$ & NL$, -1, txt_bold, NULL)
		heading(UCASE$(CHOP$(txt$))) = linenr
	ELIF REGEX(txt$, "^  [A-Z]+") THEN
		CALL gtk_text_buffer_insert_with_tags(dbuffer, &start_iter, txt$ & NL$, -1, txt_para, NULL)
		heading(UCASE$(CHOP$(txt$))) = linenr
	ELSE
		CALL gtk_text_buffer_insert(dbuffer, &start_iter, txt$ & NL$, -1)
	ENDIF
	INCR linenr
NEXT

' Set syntax highlighting to BaCon
CALL gtk_source_buffer_set_language(GTK_SOURCE_BUFFER(buffer), gtk_source_language_manager_get_language(gtk_source_language_manager_get_default(), "bacon") )
CALL gtk_source_buffer_set_language(GTK_SOURCE_BUFFER(sbuffer), gtk_source_language_manager_get_language(gtk_source_language_manager_get_default(), "bacon") )

' Keyboard shortcuts
SUB KeyAccel(keyval, keycode, state, user_data, win)
	IF user_data = 4 THEN
		SELECT keycode
			CASE ASC("n"):
				CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "fmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "fmenu_box")), 0)): CALL GUIFN(id, "fmenu_box", emit, "row-selected")
			CASE ASC("o"):
				CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "fmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "fmenu_box")), 1)): CALL GUIFN(id, "fmenu_box", emit, "row-selected")
			CASE ASC("s"):
				CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "fmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "fmenu_box")), 2)): CALL GUIFN(id, "fmenu_box", emit, "row-selected")
			CASE ASC("q"):
				CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "fmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "fmenu_box")), 9)): CALL GUIFN(id, "fmenu_box", emit, "row-selected")
			CASE ASC("z"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 0)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("r"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 1)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("x"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 3)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("c"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 4)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("v"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 5)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("a"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 7)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("f"):
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "emenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "emenu_box")), 9)): CALL GUIFN(id, "emenu_box", emit, "row-selected")
			CASE ASC("e"):
				CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "omenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "omenu_box")), 0)): CALL GUIFN(id, "omenu_box", emit, "row-selected")
			CASE ASC("m"):
				CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "omenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "omenu_box")), 4)): CALL GUIFN(id, "omenu_box", emit, "row-selected")
			CASE ASC("p"):
				CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "omenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "omenu_box")), 6)): CALL GUIFN(id, "omenu_box", emit, "row-selected")
			CASE ASC("d"):
				CALL GUISET(id, "hmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "hmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "hmenu_box")), 0)): CALL GUIFN(id, "hmenu_box", emit, "row-selected")
			CASE ASC("i"):
				CALL GUISET(id, "hmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
				CALL GUIFN(id, "hmenu_box", row_set, gtk_list_box_get_row_at_index(GTK_LIST_BOX(GUIWIDGET(id, "hmenu_box")), 1)): CALL GUIFN(id, "hmenu_box", emit, "row-selected")
		ENDSELECT
	ENDIF
ENDSUB
control1 = gtk_event_controller_key_new()
CALL g_signal_connect(G_OBJECT(control1), "key-pressed", G_CALLBACK(KeyAccel), NULL)
CALL GUIFN(id, "window", ctrl_add, control1)
control2 = gtk_event_controller_key_new()
CALL g_signal_connect(G_OBJECT(control2), "key-pressed", G_CALLBACK(KeyAccel), NULL)
CALL GUIFN(id, "scratch_dialog", ctrl_add, control2)

' Load last file if it is there
IF FILEEXISTS(Configuration$) THEN
	FOR cfg$ IN LOAD$(Configuration$) STEP NL$
		SELECT HEAD$(cfg$)
			CASE "file"
				filename$ = LAST$(cfg$)
				current_name$ = BASENAME$(filename$)
		ENDSELECT
	NEXT
	IF LEN(filename$) AND FILEEXISTS(filename$) THEN Load_File(filename$)
ENDIF

' Endless loop
WHILE TRUE
	event$ = GUIEVENT$(id)

	' Ignore event from menu_button for the respective popup
	IF event$ <> "show_menu1" THEN CALL GUIFN(id, "fmenu", hide)
	IF event$ <> "show_menu2" THEN CALL GUIFN(id, "emenu", hide)
	IF event$ <> "show_menu3" THEN CALL GUIFN(id, "omenu", hide)
	IF event$ <> "show_menu4" THEN CALL GUIFN(id, "hmenu", hide)

	SELECT event$
		CASE "show_menu1"
			IF NOT(GUIFN(id, "fmenu", visible)) THEN
				CALL GUIFN(id, "menu1", emit, "activate")
				CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_NONE)
			ENDIF
		CASE "show_menu2"
			IF NOT(GUIFN(id, "emenu", visible)) THEN
				CALL GUIFN(id, "menu2", emit, "activate")
				CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_NONE)
			ENDIF
		CASE "show_menu3"
			IF NOT(GUIFN(id, "omenu", visible)) THEN
				CALL GUIFN(id, "menu3", emit, "activate")
				CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_NONE)
			ENDIF
		CASE "show_menu4"
			IF NOT(GUIFN(id, "hmenu", visible)) THEN
				CALL GUIFN(id, "menu4", emit, "activate")
				CALL GUISET(id, "hmenu_box", "selection-mode", GTK_SELECTION_NONE)
			ENDIF
		CASE "fmenu"
			CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
			CALL GUIFN(id, "fmenu", show)
		CASE "fmenu_box"
			SELECT gtk_list_box_row_get_index(GUIFN(id, "fmenu_box", row_get))+1
				CASE 1
					IF gtk_text_buffer_get_modified(buffer) THEN
						CALL GUISET(id, "question_label", "label", "\nDiscard current changes?")
						CALL GUIFN(id, "question_dialog", show)
						question = 2
					ELSE
						CALL gtk_text_buffer_set_text(buffer, "", -1)
						CALL gtk_text_buffer_set_modified(buffer, FALSE)
					ENDIF
				CASE 2
					CALL GUIFN(id, "file_dialog", show)
				CASE 3
					IF NOT(LEN(current_name$)) THEN
						CALL GUISET(id, "error_dialog", "text", "\nSave program first!")
						CALL GUIFN(id, "error_dialog", show)
					ELSE
						CALL gtk_text_buffer_get_bounds(buffer, &start_iter, &end_iter)
						SAVE gtk_text_buffer_get_text(buffer, &start_iter, &end_iter, TRUE) TO current_name$
						CALL gtk_text_buffer_set_modified(buffer, FALSE)
						CALL GUISET(id, "info_dialog", "text", "\nProgram saved.")
						CALL GUIFN(id, "info_dialog", show)
					ENDIF
				CASE 4
					CALL GUIFN(id, "save_dialog", show)
				CASE 6
					SYSTEM ME$ & " &"
				CASE 8
					IF NOT(LEN(EXEC$("which enscript 2>/dev/null"))) OR NOT(LEN(current_name$)) THEN
						CALL GUISET(id, "error_dialog", "text", "\nThe 'enscript' utility fails!")
						CALL GUIFN(id, "error_dialog", show)
					ELSE
						SYSTEM "enscript --tabsize=4 --color --language=html --highlight=bacon --title=" & current_name$ & " --output=" & current_name$ & ".html " & current_name$
						CALL GUISET(id, "info_dialog", "text", "\nHTML generated.")
						CALL GUIFN(id, "info_dialog", show)
					ENDIF
				CASE 10
					IF gtk_text_buffer_get_modified(buffer) THEN
						CALL GUISET(id, "question_label", "label", "\nDiscard current changes?")
						CALL GUIFN(id, "question_dialog", show)
						question = 1
					ELSE
						IF LEN(current_name$) THEN
							IF FILEEXISTS(Configuration$) THEN
								cfg$ = COLLAPSE$(LOAD$(Configuration$), NL$)
								DOTIMES AMOUNT(cfg$, NL$)
									IF REGEX(TOKEN$(cfg$, _, NL$), "^file") THEN cfg$ = DEL$(cfg$, _, NL$)
								NEXT
								SAVE CHOP$(APPEND$(cfg$, 0, "file " & CURDIR$ & "/" & current_name$, NL$)) TO Configuration$
							ELSE
								SAVE "file " & CURDIR$ & "/" & current_name$ TO Configuration$
							ENDIF
						ENDIF
						BREAK
					ENDIF
			ENDSELECT
			CALL GUIFN(id, "fmenu", hide)
			CALL GUISET(id, "fmenu_box", "selection-mode", GTK_SELECTION_NONE)
		CASE "emenu"
			CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_BROWSE)
			CALL GUIFN(id, "emenu", show)
		CASE "emenu_box"
			SELECT gtk_list_box_row_get_index(GUIFN(id, "emenu_box", row_get))+1
				CASE 1
					IF gtk_text_buffer_get_can_undo(GTK_TEXT_BUFFER(buffer)) THEN CALL gtk_text_buffer_undo(GTK_TEXT_BUFFER(buffer))
					CALL gtk_text_view_scroll_mark_onscreen(GTK_TEXT_VIEW(GUIWIDGET(id, "view")), gtk_text_buffer_get_insert(buffer))
				CASE 2
					IF gtk_text_buffer_get_can_redo(GTK_TEXT_BUFFER(buffer)) THEN CALL gtk_text_buffer_redo(GTK_TEXT_BUFFER(buffer))
					CALL gtk_text_view_scroll_mark_onscreen(GTK_TEXT_VIEW(GUIWIDGET(id, "view")), gtk_text_buffer_get_insert(buffer))
				CASE 4
					CALL gtk_text_buffer_cut_clipboard(buffer, clipBoard, 1)
				CASE 5
					CALL gtk_text_buffer_copy_clipboard(buffer, clipBoard)
				CASE 6
					CALL gtk_text_buffer_paste_clipboard(buffer, clipBoard, NULL, 1)
				CASE 8
					CALL gtk_text_buffer_get_bounds(buffer, &start_iter, &end_iter)
					CALL gtk_text_buffer_select_range(buffer, &start_iter, &end_iter)
				CASE 10
					CALL GUIFN(id, "find_dialog", show)
					CALL gtk_editable_set_position(GTK_EDITABLE(GUIWIDGET(id, "find_entry")), -1)
					CALL gtk_widget_grab_focus(GUIWIDGET(id, "find_entry"))
			ENDSELECT
			CALL GUIFN(id, "emenu", hide)
			CALL GUISET(id, "emenu_box", "selection-mode", GTK_SELECTION_NONE)
		CASE "omenu"
			CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_BROWSE)
			CALL GUIFN(id, "omenu", show)
		CASE "omenu_box"
			SELECT gtk_list_box_row_get_index(GUIFN(id, "omenu_box", row_get))+1
				CASE 1
					CALL GUIFN(id, "exec_dialog", show)
					CALL gtk_editable_set_position(GTK_EDITABLE(GUIWIDGET(id, "exec_entry")), -1)
					CALL gtk_widget_grab_focus(GUIWIDGET(id, "exec_run"))
				CASE 3
					CALL GUIGET(id, "nr_menu", "active", &mode)
					CALL GUISET(id, "view", "show-line-numbers", mode)
				CASE 5
					CALL gtk_text_buffer_get_bounds(buffer, &start_iter, &end_iter)
					CALL gtk_text_buffer_set_text(buffer, Indent_Prog$(gtk_text_buffer_get_text(buffer, &start_iter, &end_iter, TRUE)), -1)
				CASE 7
					CALL GUIFN(id, "scratch_dialog", show)
			ENDSELECT
			CALL GUIFN(id, "omenu", hide)
			CALL GUISET(id, "omenu_box", "selection-mode", GTK_SELECTION_NONE)
		CASE "hmenu"
			CALL GUISET(id, "hmenu_box", "selection-mode", GTK_SELECTION_BROWSE)
			CALL GUIFN(id, "hmenu", show)
		CASE "hmenu_box"
			SELECT gtk_list_box_row_get_index(GUIFN(id, "hmenu_box", row_get))+1
				CASE 1
					CALL GUIFN(id, "doc_dialog", show)
				CASE 2
					IF gtk_widget_has_focus(GTK_WIDGET(GUIWIDGET(id, "scratch_view"))) THEN
						tmp_buffer = sbuffer
					ELSE
						tmp_buffer = buffer
					ENDIF
					CALL gtk_text_buffer_get_iter_at_mark(tmp_buffer, &start_iter, gtk_text_buffer_get_insert(tmp_buffer))
					CALL gtk_text_buffer_get_iter_at_mark(tmp_buffer, &end_iter, gtk_text_buffer_get_insert(tmp_buffer))
					IF NOT(gtk_text_iter_starts_word(&start_iter)) THEN CALL gtk_text_iter_backward_word_start(&start_iter)
					IF NOT(gtk_text_iter_ends_word(&end_iter)) THEN CALL gtk_text_iter_forward_word_end(&end_iter)
					CALL gtk_text_iter_forward_char(&end_iter)
					txt$ = CHOP$(gtk_text_buffer_get_text(tmp_buffer, &start_iter, &end_iter, 1))
					IF NOT(REGEX(RIGHT$(txt$, 1), "[a-zA-Z$]")) THEN txt$ = LEFT$(txt$, LEN(txt$)-1)
					linenr = heading(UCASE$(txt$))
					CALL gtk_text_buffer_get_iter_at_line(dbuffer, &start_iter, linenr)
					CALL gtk_text_view_scroll_to_iter(GTK_TEXT_VIEW(GUIWIDGET(id, "doc_view")), &start_iter, 0.0, TRUE, 0.0, 0.0)
					CALL GUIFN(id, "doc_dialog", show)
				CASE 4
					CALL GUIFN(id, "about_dialog", show)
			ENDSELECT
			CALL GUIFN(id, "hmenu", hide)
			CALL GUISET(id, "hmenu_box", "selection-mode", GTK_SELECTION_NONE)
		CASE "window"
			IF gtk_text_buffer_get_modified(buffer) THEN
				CALL GUISET(id, "question_label", "label", "\nDiscard current changes?")
				CALL GUIFN(id, "question_dialog", show)
				question = 1
			ELSE
				BREAK
			ENDIF
		CASE "file_dialog", "file_cancel"
			CALL GUIFN(id, "file_dialog", hide)
		CASE "save_dialog", "save_cancel"
			CALL GUIFN(id, "save_dialog", hide)
		CASE "file_open"
			IF gtk_text_buffer_get_modified(buffer) THEN
				CALL GUISET(id, "question_label", "label", "\nDiscard current changes?")
				CALL GUIFN(id, "question_dialog", show)
				question = 3
			ELSE
				Load_File_From_Dialog()
			ENDIF
		CASE "save_open"
			file = g_file_get_parse_name(gtk_file_chooser_get_file(GTK_FILE_CHOOSER(GUIWIDGET(id, "savechooser"))))
			IF FILEEXISTS(file) THEN
				CALL GUISET(id, "question_label", "label", "\nAre you sure to overwrite?")
				CALL GUIFN(id, "question_dialog", show)
				question = 4
			ELSE
				Save_File_From_Dialog(file)
				FREE file
			ENDIF
		CASE "scratch_dialog", "scratch_cancel"
			CALL GUIFN(id, "scratch_dialog", hide)
		CASE "scratch_run"
			CALL gtk_text_buffer_get_bounds(sbuffer, &start_iter, &end_iter)
			SAVE gtk_text_buffer_get_text(sbuffer, &start_iter, &end_iter, TRUE) TO Scratch_Temp$
			CALL GUIGET(id, "exec_entry", "text", &command$)
			SYSTEM REPLACE$(command$, "@", Scratch_Temp$)
		CASE "exec_run"
			IF NOT(LEN(current_name$)) THEN
				CALL GUISET(id, "info_dialog", "text", "\nSave program first!")
				CALL GUIFN(id, "info_dialog", show)
			ELSE
				CALL gtk_text_buffer_get_bounds(buffer, &start_iter, &end_iter)
				SAVE gtk_text_buffer_get_text(buffer, &start_iter, &end_iter, TRUE) TO current_name$
				CALL gtk_text_buffer_set_modified(buffer, FALSE)
				CALL GUIGET(id, "exec_entry", "text", &command$)
				SYSTEM REPLACE$(command$, "@", current_name$)
			ENDIF
			CALL GUIFN(id, "exec_dialog", hide)
		CASE "exec_dialog", "exec_cancel"
			CALL GUIFN(id, "exec_dialog", hide)
		CASE "doc_dialog", "doc_close"
			CALL GUIFN(id, "doc_dialog", hide)
		CASE "info_dialog"
			CALL GUIFN(id, "info_dialog", hide)
		CASE "error_dialog"
			CALL GUIFN(id, "error_dialog", hide)
		CASE "about_dialog"
			CALL GUIFN(id, "about_dialog", hide)
		CASE "question_dialog"
			CALL GUIFN(id, "question_dialog", hide)
		CASE "question_no"
			CALL GUIFN(id, "question_dialog", hide)
			SELECT question
				CASE 1, 2
					CONTINUE
				CASE 3
					CALL GUIFN(id, "file_dialog", hide)
					CONTINUE
				CASE 4
					CALL GUIFN(id, "save_dialog", hide)
					CONTINUE
			ENDSELECT
		CASE "question_yes"
			CALL GUIFN(id, "question_dialog", hide)
			SELECT question
				CASE 1
					BREAK
				CASE 2
					CALL gtk_text_buffer_set_text(buffer, "", -1)
					CALL gtk_text_buffer_set_modified(buffer, FALSE)
				CASE 3
					CALL GUIFN(id, "file_dialog", hide)
					Load_File_From_Dialog()
				CASE 4
					CALL GUIFN(id, "save_dialog", hide)
					Save_File_From_Dialog(file)
					FREE file
			ENDSELECT
		CASE "find_dialog", "find_cancel"
			CALL GUIFN(id, "find_dialog", hide)
		CASE "find_term", "find_entry"
			CALL GUIGET(id, "find_entry", "text", &term$)
			IF gtk_text_buffer_get_has_selection(buffer) THEN
				CALL gtk_text_buffer_get_iter_at_mark(buffer, &find_iter, gtk_text_buffer_get_selection_bound(buffer))
			ELSE
				CALL gtk_text_buffer_get_iter_at_mark(buffer, &find_iter, gtk_text_buffer_get_insert(buffer))
			ENDIF
			IF LEN(term$) THEN
				find_mode = GTK_TEXT_SEARCH_TEXT_ONLY | GTK_TEXT_SEARCH_CASE_INSENSITIVE
				IF gtk_check_button_get_active(GTK_CHECK_BUTTON(GUIWIDGET(id, "find_check"))) THEN find_mode = GTK_TEXT_SEARCH_TEXT_ONLY
				IF gtk_text_iter_forward_search(&find_iter, term$, find_mode, &start_iter, &end_iter, NULL) THEN
					CALL gtk_text_buffer_select_range(buffer, &start_iter, &end_iter)
					CALL gtk_text_view_scroll_to_mark(GTK_TEXT_VIEW(GUIWIDGET(id, "view")), gtk_text_buffer_get_selection_bound(buffer), 0, 1, 0.5, 0.5)
				ELSE
					CALL GUISET(id, "info_dialog", "text", "\nTerm not found, restarting from top!")
					CALL GUIFN(id, "info_dialog", show)
					CALL gtk_text_buffer_get_start_iter(buffer, &find_iter)
					CALL gtk_text_buffer_place_cursor(buffer, &find_iter)
				ENDIF
			ENDIF
	ENDSELECT
WEND
