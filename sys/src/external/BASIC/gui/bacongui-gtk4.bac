	{ type=TEXT_VIEW name=doc_view parent=doc_scroll monospace=TRUE editable=FALSE wrap-mode=2 vexpand=1 } \
	{ type=BUTTON name=doc_close callback=clicked hexpand=0 halign=GTK_ALIGN_CENTER label=\" Close \" } \
	{ type=WINDOW name=find_dialog callback=close-request title=\"Find term...\" transient-for=window width-request=300 } \
	{ type=GRID name=find_grid parent=find_dialog column-spacing=5 row-spacing=5 } \
	{ type=LABEL name=find_label yalign=0.5 label=\"Enter term: \" } \
