	{ type=MESSAGE_DIALOG name=info_dialog callback=response transient-for=window message-type=GTK_MESSAGE_INFO buttons=GTK_BUTTONS_CLOSE title=\"Information\" } \
	{ type=MESSAGE_DIALOG name=about_dialog callback=response transient-for=window message-type=GTK_MESSAGE_INFO buttons=GTK_BUTTONS_CLOSE title=\"About This Editor\" text=\"\\n A Minimal BaCon Editor in GTK4!\\n\\n(c) 2024 Peter van Eerten\" } \
	{ type=WINDOW name=question_dialog callback=close-request width-request=200 height-request=100 title=\"Question?\" } \
	{ type=GRID name=question_grid parent=question_dialog column-spacing=5 row-spacing=5 } \
