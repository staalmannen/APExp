	{ type=BUTTON name=save_open callback=clicked label=\"Save\" valign=GTK_ALIGN_END halign=GTK_ALIGN_END } \
	{ type=WINDOW name=scratch_dialog callback=close-request title=\"BaCon Scratchpad\" width-request=500 height-request=300 } \
	{ type=GRID name=scratch_grid parent=scratch_dialog column-spacing=5 row-spacing=5 } \
	{ type=SCROLLED_WINDOW name=scratch_swin valign=GTK_ALIGN_BASELINE hexpand=TRUE vexpand=TRUE } \
	{ type=GTK_SOURCE_TYPE_VIEW name=scratch_view parent=scratch_swin wrap-mode=GTK_WRAP_NONE vexpand=1 monospace=1 tab-width=4 } \
