'
' For the "Mint-Y" theme, add the monospace definition to its style file /usr/share/themes/Mint-Y/gtk-4.0/gtk.css:
'
' .monospace { font-family: Monospace; }
'------------------------------------------------------------------------------------------------------------------

OPTION GUI TRUE
PRAGMA GUI gtk4

OPTION EXPLICIT TRUE
OPTION QUOTED FALSE

CONST Configuration$ = GETENVIRON$("HOME") & "/.bacon/settings_gtk4.cfg"
CONST Data_Path$ = DATA_PATH
CONST Scratch_Temp$ = "/tmp/scratchpad.bac"

' Using GtkSourceView: apt install libgtksourceview-5-dev
PRAGMA INCLUDE <gtksourceview/gtksource.h>
PRAGMA OPTIONS `pkg-config --cflags gtksourceview-5`
PRAGMA OPTIONS -Wno-deprecated-declarations
PRAGMA LDFLAGS `pkg-config --libs gtksourceview-5`

LOCAL id, mode, linenr, question, find_mode
LOCAL file TYPE STRING
LOCAL current_name$, command$, txt$, cfg$, term$, filename$, event$

LOCAL (*show)() = gtk_widget_show TYPE void
LOCAL (*hide)() = gtk_widget_hide TYPE void
LOCAL (*visible)() = gtk_widget_get_visible TYPE int
LOCAL (*attach)() = gtk_grid_attach TYPE void
LOCAL (*ctrl_add)() = gtk_widget_add_controller TYPE void
LOCAL (*menu_add)() = gtk_list_box_insert TYPE void
LOCAL (*emit)(void*, const char*, ...) = g_signal_emit_by_name TYPE void
LOCAL (*row_set)() = gtk_list_box_select_row TYPE void
LOCAL (*row_get)() = gtk_list_box_get_selected_row TYPE GtkListBoxRow*

LOCAL start_iter, end_iter, find_iter TYPE GtkTextIter
LOCAL *buffer, *sbuffer, *dbuffer, *tmp_buffer TYPE GtkTextBuffer
LOCAL *txt_head, *txt_bold, *txt_para TYPE GtkTextTag
LOCAL *control1, *control2, *mc1, *mc2, *mc3, *mc4, TYPE GtkEventController
LOCAL *clipBoard TYPE GdkClipboard
LOCAL heading ASSOC int

'----------------------------------------------------------------------------

' Indentation code taken from BaCon source
FUNC Indent_Prog$(text$)
	LOCAL result$, line$, previous$
	LOCAL myposition, nextposition, label_active, wrap_active, total, x
	SPLIT text$ BY NL$ TO lines$ SIZE total
	FOR x = 0 TO total-1
		myposition = nextposition
		lines$[x] = CHOP$(lines$[x])
		IF LEN(lines$[x]) = 0 AND label_active THEN
			label_active = FALSE
			DECR myposition
			nextposition = myposition
		ENDIF
		IF REGEX(lines$[x], "^(CASE|UNTIL)[ \\t]|^(DEFAULT|FI|NEXT|WEND|DONE)|^ELSE$|^ELIF.+THEN$|^END.+") THEN
			IF NOT(REGEX(lines$[x], "^END.+[0-9]+|^ENDFORK")) THEN DECR myposition
			IF REGEX(lines$[x], "SELECT$") THEN DECR myposition
			IF myposition < 0 THEN myposition = 0
			nextposition = myposition
		ENDIF
		IF REGEX(lines$[x], "^(CASE|ENUM|FOR|FUNCTION|FUNC|GLOBAL RECORD|LABEL|RECORD|SELECT|SUB|WHILE|DOTIMES|WITH)[ \\t]|^(DEFAULT|REPEAT|USEC|USEH|DO$)|^IF.+THEN$|^ELIF.+THEN$|^ELSE$") THEN
			INCR nextposition
			IF REGEX(lines$[x], "^SELECT") THEN INCR nextposition
			IF LEFT$(lines$[x], 5) = "LABEL" THEN label_active = TRUE
		ENDIF
		IF RIGHT$(lines$[x], 2) = CHR$(32) & CHR$(92) AND NOT(REGEX(lines$[x], "^(REM|')")) THEN
			IF NOT(wrap_active) THEN INCR nextposition
			wrap_active = TRUE
		ELSE
			IF wrap_active THEN DECR nextposition
			wrap_active = FALSE
		ENDIF
		IF REGEX(previous$, "^(REM|')") THEN result$ = CHANGE$(result$, x, TAB$(myposition) & previous$, NL$)
		IF LEN(lines$[x]) THEN
			result$ = result$ & TAB$(myposition) & lines$[x] & NL$
		ELSE
			result$ = result$ & NL$
		ENDIF
		previous$ = lines$[x]
	NEXT
	RETURN CHOP$(result$)
ENDFUNC

'----------------------------------------------------------------------------

SUB Load_File(file$)
	CALL gtk_text_buffer_set_text(buffer, LOAD$(file$), -1)
	CALL gtk_text_buffer_set_modified(buffer, FALSE)
	CALL gtk_text_buffer_get_start_iter(buffer, &start_iter)
	CALL gtk_text_buffer_place_cursor(buffer, &start_iter)
	CHANGEDIR DIRNAME$(file$)
	CALL GUISET(id, "window", "title", "The BaCon Editor - '" & BASENAME$(file$) & "'")
ENDSUB

SUB Load_File_From_Dialog()
	file = g_file_get_parse_name(gtk_file_chooser_get_file(GTK_FILE_CHOOSER(GUIWIDGET(id, "filechooser"))))
	IF LEN(file) THEN Load_File(file)
	CALL GUIFN(id, "file_dialog", hide)
	current_name$ = BASENAME$(file)
	FREE file
ENDSUB

SUB Save_File_From_Dialog(file$)
	CALL gtk_text_buffer_get_bounds(buffer, &start_iter, &end_iter)
	SAVE gtk_text_buffer_get_text(buffer, &start_iter, &end_iter, TRUE) TO file$
	CALL gtk_text_buffer_set_modified(buffer, FALSE)
	CHANGEDIR DIRNAME$(file$)
	current_name$ = BASENAME$(file$)
	CALL GUIFN(id, "save_dialog", hide)
ENDSUB

