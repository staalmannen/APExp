@OS_IS_NATIVE_WINDOWS_TRUE@test-localcharset-windows-utf8.res : $(srcdir)/windows-utf8.rc
@OS_IS_NATIVE_WINDOWS_TRUE@	$(WINDRES) -i $(srcdir)/windows-utf8.rc -o test-localcharset-windows-utf8.res --output-format=coff
