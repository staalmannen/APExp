|         }
| 
|       if (c && strlen (c) != cwd_len)
|         {
|           fail = 23;
|           break;
|         }
|       ++n_chdirs;
|     }
| 
|   /* Leaving behind such a deep directory is not polite.
|      So clean up here, right away, even though the driving
|      shell script would also clean up.  */
|   {
|     size_t i;
| 
|     /* Try rmdir first, in case the chdir failed.  */
|     rmdir (DIR_NAME);
