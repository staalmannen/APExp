|                     free (regs.end);
|                   }
|                 regfree (&regex);
|               }
| 
|             memset (&regex, 0, sizeof regex);
|             s = re_compile_pattern ("x", 1, &regex);
|             if (s)
|               result |= 8;
|             else
|               {
