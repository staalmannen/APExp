|   int result = 0;
| 
|   if (strcmp ("ja_JP", "none") != 0
|       && setlocale (LC_ALL, "ja_JP") != NULL)
|     {
|       /* This fails on NetBSD 10.0.  */
|       /* U+FF21 FULLWIDTH LATIN CAPITAL LETTER A */
|       is = for_character ("\243\301", 2);
|       if (!(is == 0))
|         result |= 1;
|     }
|   if (strcmp ("en_US.UTF-8", "none") != 0
