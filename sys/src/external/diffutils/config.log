| static volatile int sigint_occurred;
| static void
| sigint_handler (int sig)
| {
|   sigint_occurred++;
| }
| int main ()
| {
|   sigset_t set;
|   pid_t pid = getpid ();
|   char command[80];
|   if (LONG_MAX < pid)
|     return 6;
|   signal (SIGINT, sigint_handler);
|   sigemptyset (&set);
|   sigaddset (&set, SIGINT);
|   if (!(pthread_sigmask (SIG_BLOCK, &set, NULL) == 0))
|     return 1;
|   sprintf (command, "sh -c 'sleep 1; kill -INT %ld' &", (long) pid);
|   if (!(system (command) == 0))
|     return 2;
|   sleep (2);
