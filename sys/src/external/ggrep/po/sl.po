#~ "  -c, --count               le skupno število vrstic v DATOTEKI, v "
#~ "katerih se\n"
#~ "                            pojavi VZOREC\n"
#~ "  -T, --initial-tab         dodaj začetni tabulator (če je potrebno)\n"
