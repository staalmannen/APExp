| /* Returns the value of iswdigit for the multibyte character s[0..n-1].  */
| static int
| for_character (const char *s, size_t n)
| {
|   mbstate_t state;
|   wchar_t wc;
|   size_t ret;
| 
|   memset (&state, '\0', sizeof (mbstate_t));
|   wc = (wchar_t) 0xBADFACE;
|   ret = mbrtowc (&wc, s, n, &state);
|   if (ret != n)
|     abort ();
| 
|   return iswdigit (wc);
| }
