| /* The length of this name must be 8.  */
| #define DIR_NAME "confdir3"
| #define DIR_NAME_LEN 8
| #define DIR_NAME_SIZE (DIR_NAME_LEN + 1)
| 
| /* The length of "../".  */
| #define DOTDOTSLASH_LEN 3
| 
| /* Leftover bytes in the buffer, to work around library or OS bugs.  */
| #define BUF_SLOP 20
