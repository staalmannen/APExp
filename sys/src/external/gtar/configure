fi


fi
{ printf "%s\n" "$as_me:${as_lineno-$LINENO}: result: $gl_cv_func_getcwd_path_max" >&5
printf "%s\n" "$gl_cv_func_getcwd_path_max" >&6; }

      case "$gl_cv_func_getcwd_null" in
        *yes)






      { printf "%s\n" "$as_me:${as_lineno-$LINENO}: checking for getpagesize" >&5
