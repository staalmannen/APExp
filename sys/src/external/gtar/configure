  "none needed") :
     ;; #(
  "supported through gnulib") :
     ;; #(
  "support not detected") :
    ac_have_largefile=no ;; #(
  "-D_FILE_OFFSET_BITS=64") :

printf "%s\n" "#define _FILE_OFFSET_BITS 64" >>confdefs.h
 ;; #(
  "-D_LARGE_FILES=1") :

printf "%s\n" "#define _LARGE_FILES 1" >>confdefs.h
 ;; #(
