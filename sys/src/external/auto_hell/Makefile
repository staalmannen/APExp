AR = ar
CC = clang
CURDIR := /home/srb/random/hell
CXX = g++
LEX = reflex --flex
MAKE = make
MAKECMDGOALS =
MAKE_VERSION = 4.2.1
OBJS = $(SRCS:.c=.o)
DEMIURGE_OBJS = demiurge/demiurge.o demiurge/macro.o macros/builtins.o satan/map.o satan/vec.o satan/str.o satan/util.o satan/conf.o
SHELL = /bin/sh
SRCS = satan/main.c \
	satan/gen.c \
	satan/probe.c \
	satan/am.c \
	satan/conf.c \
	satan/map.c \
	satan/vec.c \
	satan/str.c \
	satan/util.c \
	satan/amparse.c \
	satan/amlex.c
YACC = byacc

PREFIX = /usr
BINDIR = $(PREFIX)/bin

.PHONY: all clean install

all: satan/satan demiurge/demiurge

satan/satan: satan/main.o satan/gen.o satan/probe.o satan/am.o satan/conf.o satan/map.o satan/vec.o satan/str.o satan/util.o satan/amparse.o satan/amlex.o
	$(CC) $(LDFLAGS) -o $@ $(OBJS)

demiurge/demiurge: $(DEMIURGE_OBJS)
	$(CC) $(LDFLAGS) -o $@ $(DEMIURGE_OBJS)

.c.o:
	$(CC) $(CFLAGS) -c $< -o $@

