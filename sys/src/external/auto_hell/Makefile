	$(CC) $(CFLAGS) -c $< -o $@
satan/str.o: satan/str.c
	$(CC) $(CFLAGS) -c $< -o $@
satan/util.o: satan/util.c
	$(CC) $(CFLAGS) -c $< -o $@
satan/amparse.o: satan/amparse.c
	$(CC) $(CFLAGS) -c $< -o $@
satan/amlex.o: satan/amlex.c
	$(CC) $(CFLAGS) -c $< -o $@

demiurge/demiurge.o: demiurge/demiurge.c
	$(CC) $(CFLAGS) -Isatan -Imacros -Idemiurge -c $< -o $@

demiurge/macro.o: demiurge/macro.c
	$(CC) $(CFLAGS) -Isatan -Imacros -Idemiurge -c $< -o $@

macros/builtins.o: macros/builtins.c
	$(CC) $(CFLAGS) -Isatan -Idemiurge -c $< -o $@

satan/amparse.c: satan/amparse.y
	$(YACC) -d -o satan/amparse.c satan/amparse.y
	if [ -f y.tab.h ]; then mv y.tab.h satan/amparse.h; fi
	if [ -f satan/y.tab.h ]; then mv satan/y.tab.h satan/amparse.h; fi

satan/amparse.h: satan/amparse.y
	$(YACC) -d -o satan/amparse.c satan/amparse.y
	if [ -f y.tab.h ]; then mv y.tab.h satan/amparse.h; fi
	if [ -f satan/y.tab.h ]; then mv satan/y.tab.h satan/amparse.h; fi

satan/amlex.c: satan/amlex.l satan/amparse.h
	if command -v reflex >/dev/null 2>&1; then \
		reflex -o satan/amlex.c satan/amlex.l; \
	elif command -v flex >/dev/null 2>&1; then \
		flex -o satan/amlex.c satan/amlex.l; \
	else \
		echo "satan: need reflex or flex" >&2; exit 1; \
	fi

clean:
	rm -f satan/satan demiurge/demiurge $(OBJS) $(DEMIURGE_OBJS) satan/amparse.c satan/amparse.h satan/amlex.c

install: satan/satan demiurge/demiurge
	mkdir -p $(DESTDIR)$(BINDIR)
	cp satan/satan $(DESTDIR)$(BINDIR)/satan
	cp demiurge/demiurge $(DESTDIR)$(BINDIR)/demiurge
