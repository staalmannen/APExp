test-posix_spawn-dup2-stdout.sh: test-posix_spawn-dup2-stdout.in.sh
	$(AM_V_GEN)cp $(srcdir)/test-posix_spawn-dup2-stdout.in.sh $@-t
	$(AM_V_at)mv $@-t $@
test-posix_spawn-dup2-stdin.sh: test-posix_spawn-dup2-stdin.in.sh
