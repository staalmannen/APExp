	    # write_permuted_numbers
	    $ timeout 10 ./src/shuf -i 0-100000000 | pv -r > /dev/null
	    [ 308MiB/s]

	    # write_random_numbers
	    $ timeout 10 ./src/shuf -i 0-100000 -r | pv -r > /dev/null
	    [ 196MiB/s]

