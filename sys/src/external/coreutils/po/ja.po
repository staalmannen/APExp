"す。\n"
"\n"

#: src/uniq.c:171
msgid ""
"  -c, --count\n"
"         prefix lines by the number of occurrences\n"
msgstr "  -c, --count           行の前に出現回数を出力する\n"

#: src/uniq.c:175
msgid ""
"  -d, --repeated\n"
"         only print duplicate lines, one for each group\n"
