"   [-]iexten     enable non-POSIX special characters\n"
msgstr ""
"   [-]icanon     omogoči posebne znake: %s\n"
"   [-]iexten     omogoči posebne znake, ki niso del priporočila POSIX\n"

#: src/stty.c:873
msgid ""
