#: src/stty.c:878
msgid " * [-]prterase   same as [-]echoprt\n"
msgstr " * [-]prterase   isto kot [-]echoprt\n"

#: src/stty.c:883
msgid ""
" * [-]tostop     stop background jobs that try to write to the terminal\n"
msgstr ""
" * [-]tostop     ustavi vsa opravila v ozadju, ki poskušajo pisati na "
