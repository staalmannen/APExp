#: src/hostid.c:40
#, c-format
msgid ""
"Usage: %s [OPTION]\n"
"Print the numeric identifier (in hexadecimal) for the current host.\n"
"\n"
msgstr ""
"사용법: %s [<옵션>]\n"
"현재 호스트의 숫자 식별자(16진수)를 출력합니다.\n"
"\n"

#: src/hostname.c:58
#, c-format
msgid ""
"Usage: %s [NAME]\n"
"  or:  %s OPTION\n"
"Print or set the hostname of the current system.\n"
"\n"
msgstr ""
"사용법: %s [<이름>]\n"
"  또는: %s <옵션>\n"
"현재 시스템의 호스트 이름을 출력하거나 설정합니다.\n"
"\n"

