msgstr "대상 디렉터리 %s"

#: src/cp.c:736 src/install.c:1041 src/ln.c:664 src/mv.c:507
#, c-format
msgid "target %s"
msgstr "대상: %s"

#: src/cp.c:844
#, c-format
msgid "with --parents, the destination must be a directory"
msgstr "--parents 옵션에 같이 붙는 대상 값은 디렉터리여야 합니다"

#: src/cp.c:1185 src/install.c:925 src/ln.c:575 src/mv.c:401
#, c-format
