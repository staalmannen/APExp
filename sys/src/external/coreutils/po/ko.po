msgid_plural "up %jd days %2d:%02d,  "
msgstr[0] "가동시간 %jd 일 %2d:%02d,  "

#: src/uptime.c:94
#, c-format
msgid "up  %2d:%02d,  "
msgstr "가동시간  %2d:%02d,  "

#: src/uptime.c:97
