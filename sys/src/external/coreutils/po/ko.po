#: src/system.h:889
#, c-format
msgid "Full documentation <%s%s>\n"
msgstr "완전한 문서 <%s%s>\n"

#: src/system.h:891
#, c-format
msgid "or available locally via: info '(coreutils) %s%s'\n"
msgstr "또는 로컬 문서: info '(coreutils) %s%s'\n"

#: src/system.h:902
#, c-format
msgid "Try '%s --help' for more information.\n"
