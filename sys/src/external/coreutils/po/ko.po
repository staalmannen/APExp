#: src/cksum.c:1816
#, c-format
msgid "the --status option is meaningful only when verifying checksums"
msgstr "--status 옵션은 검사합을 검증할 때만 의미가 있습니다"

#: src/cksum.c:1823
#, c-format
msgid "the --warn option is meaningful only when verifying checksums"
