#~ msgid ""
#~ "Usage: %s [OPTION] [FILE]...\n"
#~ "  or:  %s [OPTION] --check [FILE]\n"
#~ "Print or check MD5 checksums.\n"
#~ "With no FILE, or when FILE is -, read standard input.\n"
#~ "\n"
#~ "  -b, --binary            read files in binary mode (default on DOS/"
