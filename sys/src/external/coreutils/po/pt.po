msgstr "  INTEIRO1 -ne INTEIRO2   INTEIRO1 é diferente de INTEIRO2\n"

#: src/test.c:734
msgid ""
"  FILE1 -ef FILE2   FILE1 and FILE2 have the same device and inode numbers\n"
msgstr ""
