msgstr "  -c FICH     FICH existe e é especial de caracteres\n"

#: src/test.c:752
msgid "  -d FILE     FILE exists and is a directory\n"
msgstr "  -d FICH     FICH existe e é uma pasta\n"

#: src/test.c:755
