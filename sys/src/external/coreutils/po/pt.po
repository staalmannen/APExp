msgstr "registo muito grande"

#: src/tac.c:409 src/tac.c:421
#, c-format
msgid "%s: write error"
msgstr "%s: erro de escrita"

#: src/tac.c:470
#, c-format
msgid "failed to open %s for reading"
msgstr "impossível abrir %s para leitura"

#: src/tac.c:534
#, c-format
