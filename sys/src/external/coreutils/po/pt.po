msgstr[0] "%s: remover %ju argumento recursivamente? "
msgstr[1] "%s: remover %ju argumentos recursivamente? "

#: src/rm.c:385
#, c-format
msgid "%s: remove %ju argument? "
msgid_plural "%s: remove %ju arguments? "
msgstr[0] "%s: remover %ju argumento? "
msgstr[1] "%s: remover %ju argumentos? "

#: src/rmdir.c:131 src/rmdir.c:242
#, c-format
