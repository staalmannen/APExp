"  STRING1 = STRING2    the strings are equal\n"
"  STRING1 != STRING2   the strings are not equal\n"
"  STRING1 > STRING2    STRING1 is greater than STRING2 in the current "
"locale\n"
"  STRING1 < STRING2    STRING1 is less than STRING2 in the current locale\n"
msgstr ""
"  CADEIA1 = CADEIA2    as cadeias são iguais\n"
"  CADEIA1 != CADEIA2   as cadeias não são iguais\n"
"  CADEIA1 > CADEIA2    CADEIA1 é maior que CADEIA2 no idioma actual\n"
"  CADEIA1 < CADEIA2    CADEIA1 é menor que CADEIA2 no idioma actual\n"

#: src/test.c:713
msgid "  INTEGER1 -eq INTEGER2   INTEGER1 is equal to INTEGER2\n"
msgstr "  INTEIRO1 -eq INTEIRO2   INTEIRO1 é igual a INTEIRO2\n"

#: src/test.c:716
msgid ""
"  INTEGER1 -ge INTEGER2   INTEGER1 is greater than or equal to INTEGER2\n"
msgstr "  INTEIRO1 -ge INTEIRO2   INTEIRO1 é maior ou igual a INTEIRO2\n"

#: src/test.c:719
