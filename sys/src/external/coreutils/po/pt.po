msgstr "  -k FICH     FICH existe e tem o seu bit sticky activado\n"

#: src/test.c:773
msgid "  -L FILE     FILE exists and is a symbolic link (same as -h)\n"
msgstr "  -L FICH     FICH existe e é uma ligação simbólica (como -h)\n"

#: src/test.c:776
msgid ""
"  -N FILE     FILE exists and has been modified since it was last read\n"
msgstr "  -N FICH     FICH existe e foi modificado desde a última leitura\n"

#: src/test.c:779
msgid "  -O FILE     FILE exists and is owned by the effective user ID\n"
msgstr "  -O FICH     FICH existe e é detido pela ID de utilizador efectiva\n"

#: src/test.c:782
