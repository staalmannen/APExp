msgstr "  INTEIRO1 -le INTEIRO2   INTEIRO1 é menor ou igual a INTEIRO2\n"

#: src/test.c:725
msgid "  INTEGER1 -lt INTEGER2   INTEGER1 is less than INTEGER2\n"
