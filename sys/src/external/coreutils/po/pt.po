#: src/test.c:740
msgid "  FILE1 -ot FILE2   FILE1 is older than FILE2\n"
msgstr "  FICH1 -ot FICH2   FICH1 é mais antigo que FICH2\n"

#: src/test.c:746
msgid "  -b FILE     FILE exists and is block special\n"
msgstr "  -b FICH     FICH existe e é especial de blocos\n"

#: src/test.c:749
