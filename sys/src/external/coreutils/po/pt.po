msgstr "Uso: %s [OPÇÃO]... [FICHEIRO]...\n"

#: src/cat.c:97
msgid "Concatenate FILE(s) to standard output.\n"
msgstr "Concatenar FICHEIRO(s) na saída padrão.\n"

#: src/cat.c:103
msgid "  -A, --show-all           equivalent to -vET\n"
msgstr "  -A, --show-all           equivalente a -vET\n"

#: src/cat.c:106
msgid "  -b, --number-nonblank    number nonempty output lines, overrides -n\n"
msgstr ""
"  -b, --number-nonblank    numera linhas de saída não vazias, sobrepõe-se a "
"-n\n"

#: src/cat.c:109
msgid "  -e                       equivalent to -vE\n"
msgstr "  -e                       equivalente a -vE\n"

#: src/cat.c:112
msgid "  -E, --show-ends          display $ or ^M$ at end of each line\n"
msgstr ""
"  -E, --show-ends\n"
"\t  mostra $ no fim de cada linha\n"

#: src/cat.c:115
msgid "  -n, --number             number all output lines\n"
msgstr "  -n, --number             numera todas as linhas de saída\n"

#: src/cat.c:118
msgid "  -s, --squeeze-blank      suppress repeated empty output lines\n"
msgstr "  -s, --squeeze-blank      suprime linhas vazias de saída repetidas\n"

#: src/cat.c:121
msgid "  -t                       equivalent to -vT\n"
msgstr "  -t                       equivalente a -vT\n"

#: src/cat.c:124
msgid "  -T, --show-tabs          display TAB characters as ^I\n"
msgstr "  -T, --show-tabs          mostra caracteres TAB como ^I\n"

#: src/cat.c:127
msgid "  -u                       (ignored)\n"
msgstr "  -u                       (ignorado)\n"

#: src/cat.c:130
msgid ""
"  -v, --show-nonprinting   use ^ and M- notation, except for LFD and TAB\n"
msgstr ""
"  -v, --show-nonprinting   usa a notação ^ e M-, excepto para LFD e TAB\n"

#: src/cat.c:135
#, c-format
msgid ""
"\n"
"Examples:\n"
"  %s f - g  Output f's contents, then standard input, then g's contents.\n"
"  %s        Copy standard input to standard output.\n"
msgstr ""
"\n"
"Exemplos:\n"
"  %s f - g  imprime conteúdo de f, depois a entrada padrão e depois conteúdo "
"de g.\n"
"  %s        copia a entrada padrão para a saída padrão.\n"

