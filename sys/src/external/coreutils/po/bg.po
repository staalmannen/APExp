msgstr ""
"  ⁃ „%h“:  брой твърди връзки\n"
"  ⁃ „%i“:  номер на i-възел\n"
"  ⁃ „%m“:  точка на монтиране\n"
"  ⁃ „%n“:  име на файла\n"
