msgstr ""
"  -f, --force    режимът за достъп се променя при нужда да се позволи запис\n"

#: src/shred.c:186
#, c-format
msgid ""
"  -n, --iterations=N\n"
"         overwrite N times instead of the default (%d)\n"
msgstr ""
"  -n, --iterations=ПЪТИ\n"
"                 заличаване този брой ПЪТИ (стандартно: %d)\n"

#: src/shred.c:190 src/sort.c:474
#, fuzzy
msgid ""
"      --random-source=FILE\n"
"         get random bytes from FILE\n"
msgstr ""
"#-#-#-#-#  - (coreutils 9.9-pre1)  #-#-#-#-#\n"
"      --random-source=ФАЙЛ\n"
"                 изчитане на случайните байтове от ФАЙЛа\n"
"#-#-#-#-#  - (coreutils 9.9-pre1)  #-#-#-#-#\n"
"      --random-source=ФАЙЛ    четене на случайни байтове от този ФАЙЛ\n"

#: src/shred.c:194
msgid ""
"  -s, --size=N\n"
