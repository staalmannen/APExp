#~ "  -u, --update                 copiază numai atunci când fișierul SURSĂ "
#~ "este mai nou decât\n"
#~ "                               fișierul destinație sau când fișierul "
#~ "destinație lipsește\n"
#~ "  -v, --verbose                explică ce se face pe parcursul "
#~ "procesului\n"
#~ "  -x, --one-file-system        rămâne pe acest sistem de fișiere\n"

