# R-GC, scrie:
# acest mesaj, și următoarele, pot să fie
# vizualizate, rulînd comanda:
# «test --help»
# ***
# Pare să fie minciună, dar nu e; în sistemul
# meu (Devuan), în acest moment, comanda
# de mai sus, nu funcționează...
# ===
# După ce-am tradus toate mesajele de «test»,
# am văzut de ce, comanda validă pentru
# vixzualizarea acestor mesaje, este:
# «/usr/bin/[ --help»
#: src/test.c:667
msgid ""
"Usage: test EXPRESSION\n"
"  or:  test\n"
"  or:  [ EXPRESSION ]\n"
"  or:  [ ]\n"
"  or:  [ OPTION\n"
msgstr ""
"Utilizare: test EXPRESIA\n"
"    sau:  test\n"
"    sau:  [ EXPRESIA ]\n"
"    sau:  [ ]\n"
"    sau:  [ OPȚIUNE\n"

#: src/test.c:674
msgid ""
"Exit with the status determined by EXPRESSION.\n"
"\n"
msgstr ""
"Iese cu starea determinată de EXPRESIE.\n"
"\n"

#: src/test.c:680
msgid ""
"\n"
"An omitted EXPRESSION defaults to false.  Otherwise,\n"
"EXPRESSION is true or false and sets exit status.  It is one of:\n"
msgstr ""
"\n"
"O EXPRESIE omisă, este considerată ca falsă.  În caz contrar, EXPRESIA \n"
"este adevărată sau falsă și stabilește starea de ieșire. Este una din:\n"

#: src/test.c:685
msgid ""
"\n"
"  ( EXPRESSION )               EXPRESSION is true\n"
"  ! EXPRESSION                 EXPRESSION is false\n"
"  EXPRESSION1 -a EXPRESSION2   both EXPRESSION1 and EXPRESSION2 are true\n"
"  EXPRESSION1 -o EXPRESSION2   either EXPRESSION1 or EXPRESSION2 is true\n"
msgstr ""
"\n"
"  ( EXPRESIA )             EXPRESIA este adevărată\n"
"  ! EXPRESIA               EXPRESIA este falsă\n"
"  EXPRESIA1 -a EXPRESIA2   atât EXPRESIA1 cât și EXPRESIA2 sunt adevărate\n"
"  EXPRESIA1 -o EXPRESIA2   oricare dintre EXPRESIA1 sau EXPRESIA2 este "
"adevărată\n"

#: src/test.c:695
msgid "  -n STRING            the length of STRING is nonzero\n"
msgstr "  -n ȘIR         lungimea lui ȘIR este diferită de zero\n"

#: src/test.c:698
msgid "  STRING               equivalent to -n STRING\n"
msgstr "  ȘIR            echivalent cu „-n ȘIR”\n"

#: src/test.c:701
msgid "  -z STRING            the length of STRING is zero\n"
msgstr "  -z ȘIR         lungimea lui ȘIR este zero\n"

#: src/test.c:704
msgid ""
"  STRING1 = STRING2    the strings are equal\n"
"  STRING1 != STRING2   the strings are not equal\n"
"  STRING1 > STRING2    STRING1 is greater than STRING2 in the current "
"locale\n"
"  STRING1 < STRING2    STRING1 is less than STRING2 in the current locale\n"
msgstr ""
"  ȘIR1 = ȘIR2    șirurile sunt egale\n"
"  ȘIR1 != ȘIR2   șirurile nu sunt egale\n"
"  ȘIR1 > ȘIR2    ȘIR1 este mai mare decât ȘIR2 în configurația regională "
"curentă\n"
"  ȘIR1 < ȘIR2    ȘIR1 este mai mic decât ȘIR2 în configurația regională "
"curentă\n"

#: src/test.c:713
msgid "  INTEGER1 -eq INTEGER2   INTEGER1 is equal to INTEGER2\n"
msgstr "  ÎNTREG1 -eq ÎNTREG2   ÎNTREG1 este egal cu ÎNTREG2\n"

#: src/test.c:716
msgid ""
"  INTEGER1 -ge INTEGER2   INTEGER1 is greater than or equal to INTEGER2\n"
msgstr "  ÎNTREG1 -ge ÎNTREG2   ÎNTREG1 este mai mare sau egal cu ÎNTREG2\n"

#: src/test.c:719
msgid "  INTEGER1 -gt INTEGER2   INTEGER1 is greater than INTEGER2\n"
msgstr "  ÎNTREG1 -gt ÎNTREG2   ÎNTREG1 este mai mare decât ÎNTREG2\n"

#: src/test.c:722
msgid "  INTEGER1 -le INTEGER2   INTEGER1 is less than or equal to INTEGER2\n"
msgstr "  ÎNTREG1 -le ÎNTREG2   ÎNTREG1 este mai mic sau egal cu ÎNTREG2\n"

#: src/test.c:725
msgid "  INTEGER1 -lt INTEGER2   INTEGER1 is less than INTEGER2\n"
msgstr "  ÎNTREG1 -lt ÎNTREG2   ÎNTREG1 este mai mic decât ÎNTREG2\n"

#: src/test.c:728
msgid "  INTEGER1 -ne INTEGER2   INTEGER1 is not equal to INTEGER2\n"
msgstr "  ÎNTREG1 -ne ÎNTREG2   ÎNTREG1 nu este egal cu ÎNTREG2\n"

#: src/test.c:734
msgid ""
"  FILE1 -ef FILE2   FILE1 and FILE2 have the same device and inode numbers\n"
msgstr ""
"  FIȘIER1 -ef FIȘIER2   FIȘIER1 și FIȘIER2 au aceleași numere de dispozitiv "
"și \n"
"                        de nod-i\n"

#: src/test.c:737
msgid "  FILE1 -nt FILE2   FILE1 is newer (modification date) than FILE2\n"
msgstr ""
"  FIȘIER1 -nt FIȘIER2   FIȘIER1 este mai recent (data modificării) decât "
"FIȘIER2\n"

#: src/test.c:740
msgid "  FILE1 -ot FILE2   FILE1 is older than FILE2\n"
msgstr "  FIȘIER1 -ot FIȘIER2   FIȘIER1 este mai vechi decât FIȘIER2\n"

#: src/test.c:746
msgid "  -b FILE     FILE exists and is block special\n"
msgstr "  -b FIȘIER     FIȘIERul există și este un fișier special de blocuri\n"

#: src/test.c:749
msgid "  -c FILE     FILE exists and is character special\n"
msgstr ""
"  -c FIȘIER     FIȘIERul există și este un fișier special de caractere\n"

#: src/test.c:752
msgid "  -d FILE     FILE exists and is a directory\n"
msgstr "  -d FIȘIER     FIȘIERul există și este un director\n"

#: src/test.c:755
msgid "  -e FILE     FILE exists\n"
msgstr "  -e FIȘIER     FIȘIERul există\n"

#: src/test.c:758
msgid "  -f FILE     FILE exists and is a regular file\n"
msgstr "  -f FIȘIER     FIȘIERul există și este un regular file\n"

#: src/test.c:761
msgid "  -g FILE     FILE exists and is set-group-ID\n"
msgstr "  -g FIȘIER     FIȘIERul există și are bitul set-GID activat\n"

#: src/test.c:764
msgid "  -G FILE     FILE exists and is owned by the effective group ID\n"
msgstr ""
"  -G FIȘIER     FIȘIERul există și este deținut de ID-ul efectiv al "
"grupului\n"

#: src/test.c:767
msgid "  -h FILE     FILE exists and is a symbolic link (same as -L)\n"
msgstr ""
"  -h FIȘIER     FIȘIERul există și este o legătură simbolică (la fel ca „-"
"L”)\n"

#: src/test.c:770
msgid "  -k FILE     FILE exists and has its sticky bit set\n"
msgstr "  -k FIȘIER     FIȘIERul există și are bitul lipicios activat\n"

#: src/test.c:773
msgid "  -L FILE     FILE exists and is a symbolic link (same as -h)\n"
msgstr ""
"  -L FIȘIER     FIȘIERul există și este o legătură simbolică (la fel ca „-"
"h”)\n"

#: src/test.c:776
msgid ""
"  -N FILE     FILE exists and has been modified since it was last read\n"
msgstr ""
"  -N FIȘIER     FIȘIERul există și a fost modificat de când a fost citit "
"ultima \n"
"                dată\n"

#: src/test.c:779
msgid "  -O FILE     FILE exists and is owned by the effective user ID\n"
msgstr ""
"  -O FIȘIER     FIȘIERul există și este deținut de ID-ul de utilizator "
"efectiv\n"

#: src/test.c:782
msgid "  -p FILE     FILE exists and is a named pipe\n"
msgstr "  -p FIȘIER     FIȘIERul există și este o conductă cu nume\n"

#: src/test.c:785
msgid "  -r FILE     FILE exists and the user has read access\n"
msgstr "  -r FIȘIER     FIȘIERul există și utilizatorul are acces de citire\n"

#: src/test.c:788
msgid "  -s FILE     FILE exists and has a size greater than zero\n"
msgstr ""
"  -s FIȘIER     FIȘIERul există și are o dimensiune mai mare decât zero\n"

#: src/test.c:791
msgid "  -S FILE     FILE exists and is a socket\n"
msgstr "  -S FIȘIER     FIȘIERul există și este un soclu\n"

#: src/test.c:794
msgid "  -t FD       file descriptor FD is opened on a terminal\n"
msgstr ""
"  -t DF         descriptorul de fișier DF este deschis pe un terminal\n"

#: src/test.c:797
msgid "  -u FILE     FILE exists and its set-user-ID bit is set\n"
msgstr "  -u FIȘIER     FIȘIERul există și are bitul set-UID activat\n"

#: src/test.c:800
msgid "  -w FILE     FILE exists and the user has write access\n"
msgstr ""
"  -w FIȘIER     FIȘIERul există și permisiunea de scriere este acordată\n"

#: src/test.c:803
msgid "  -x FILE     FILE exists and the user has execute (or search) access\n"
msgstr ""
"  -x FIȘIER     FIȘIERul există și utilizatorul are acces de execuție (sau \n"
"                căutare)\n"

#: src/test.c:806
msgid ""
"\n"
"Except for -h and -L, all FILE-related tests dereference symbolic links.\n"
"Beware that parentheses need to be escaped (e.g., by backslashes) for "
"shells.\n"
"INTEGER may also be -l STRING, which evaluates to the length of STRING.\n"
msgstr ""
"\n"
"Cu excepția a „-h” și „-L”, toate testele legate de FIȘIERe urmează "
"legăturile\n"
"simbolice.\n"
"Atenție că parantezele trebuie să fie eludate (de exemplu, cu bare oblice \n"
"inverse) pentru shell-uri.\n"
"ÎNTREG poate fi, de asemenea, „-l ȘIR”, care se evaluează la lungimea "
"ȘIRului.\n"

#: src/test.c:812
msgid ""
"\n"
"Binary -a and -o are ambiguous.  Use 'test EXPR1 && test EXPR2'\n"
"or 'test EXPR1 || test EXPR2' instead.\n"
msgstr ""
"\n"
"Binarele -a și -o sunt ambigue. Utilizați „test EXPRESIA && test EXPRESIA2”\n"
"sau „test EXPRESIA1 || test EXPRESIA2” în schimb.\n"

#: src/test.c:817
msgid ""
"\n"
"'[' honors --help and --version, but 'test' treats them as STRINGs.\n"
msgstr ""
"\n"
"«[» respectă opțiunile „--help” și „--version”, dar «test» le tratează ca "
"fiind ȘIRURI.\n"

#: src/test.c:821
msgid "test and/or ["
msgstr "test și/sau ["

