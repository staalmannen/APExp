msgstr ""
"avertisment: opțiunile „--appparent-size” și „-b” sunt ineficiente cu „--"
"inodes”"

#: src/du.c:1074 src/sort.c:4813 src/wc.c:882
msgid "file operands cannot be combined with --files0-from"
msgstr "operanzii fișierului nu pot fi combinați cu „--files0-from”"

#: src/du.c:1141 src/sort.c:4834 src/wc.c:946
#, c-format
