msgstr "%s: nu se poate urmări sfârșitul acestui tip de fișier%s"

#: src/tail.c:2228
msgid "invalid maximum number of unchanged stats between opens"
msgstr "număr maxim nevalid de stări neschimbate între deschideri"

#: src/tail.c:2246
