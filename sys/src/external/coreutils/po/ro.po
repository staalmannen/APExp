#: src/who.c:655
msgid ""
"  -m                only hostname and user associated with standard input\n"
msgstr ""
"  -m                      numai numele de gazdă și utilizatorul asociat cu \n"
"                          intrarea standard\n"

#: src/who.c:658
msgid "  -p, --process     print active processes spawned by init\n"
msgstr ""
"  -p, --process           afișează procesele active generate de «init»\n"

#: src/who.c:661
msgid "  -q, --count       all login names and number of users logged on\n"
msgstr ""
