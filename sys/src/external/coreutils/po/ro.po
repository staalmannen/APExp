msgstr "  -s, --strip, --no-symlinks   nu rezolvă legăturile simbolice\n"

#: src/realpath.c:103
msgid ""
"  -z, --zero                   end each output line with NUL, not newline\n"
msgstr ""
"  -z, --zero                   termină fiecare linie afișată cu NUL, nu cu o "
"nouă linie\n"

#: src/relpath.c:130
