#: src/sort.c:426
msgid "Write sorted concatenation of all FILE(s) to standard output.\n"
msgstr ""
"Scrie o concatenare ordonată a tuturor FIȘIERELOR la ieșirea standard..\n"

#: src/sort.c:433
msgid ""
"Ordering options:\n"
"\n"
msgstr ""
"Opțiuni de ordonare:\n"
"\n"

#: src/sort.c:437
msgid ""
"  -b, --ignore-leading-blanks\n"
"         ignore leading blanks when finding sort keys in each line\n"
msgstr ""
"  -b, --ignore-leading-blanks  ignoră spațiile de la începutul fiecărei "
"linii\n"
"                               atunci când se caută cheile de sortare\n"

#: src/sort.c:441
msgid ""
"  -d, --dictionary-order\n"
"         consider only blanks and alphanumeric characters\n"
msgstr ""
"  -d, --dictionary-order      ia în considerare doar spațiile libere și \n"
"                              caracterele alfanumerice\n"

#: src/sort.c:445
msgid ""
"  -f, --ignore-case\n"
"         fold lower case to upper case characters\n"
msgstr ""
"  -f, --ignore-case           transformă caracterele minuscule în majuscule\n"

#: src/sort.c:449
msgid ""
"  -g, --general-numeric-sort\n"
"         compare according to general numerical value\n"
msgstr ""
"  -g, --general-numeric-sort  compară conform valorii numerice generale\n"

#: src/sort.c:453
msgid ""
"  -i, --ignore-nonprinting\n"
"         consider only printable characters\n"
msgstr ""
"  -i, --ignore-nonprinting    ia în considerare doar caracterele "
"imprimabile\n"

#: src/sort.c:457
msgid ""
"  -M, --month-sort\n"
"         compare (unknown) < 'JAN' < ... < 'DEC'\n"
msgstr ""
"  -M, --month-sort            compară (necunoscută) < „IAN” < ... < „DEC”\n"

#: src/sort.c:461
msgid ""
"  -h, --human-numeric-sort\n"
"         compare human readable numbers (e.g., 2K 1G)\n"
msgstr ""
"  -h, --human-numeric-sort    compară numere care pot fi citite ușor de "
"către \n"
"                              om (de exemplu: 2K, 1G)\n"

#: src/sort.c:465
msgid ""
"  -n, --numeric-sort\n"
"         compare according to string numerical value;\n"
"         see full documentation for supported strings\n"
msgstr ""
"  -n, --numeric-sort          compară conform valorii numerice a șirului;\n"
"                              consultați manualul pentru a afla ce șiruri "
"de\n"
"                              caractere sunt acceptate\n"

#: src/sort.c:470
msgid ""
"  -R, --random-sort\n"
"         shuffle, but group identical keys.  See also shuf(1)\n"
msgstr ""
"  -R, --random-sort           amestecă, dar grupează chei identice;\n"
"                              a se vedea de asemenea shuf(1)\n"

#: src/sort.c:478
msgid ""
"  -r, --reverse\n"
"         reverse the result of comparisons\n"
msgstr "  -r, --reverse               inversează rezultatul comparațiilor\n"

#: src/sort.c:482
msgid ""
"      --sort=WORD\n"
"         sort according to WORD:\n"
"           general-numeric -g, human-numeric -h, month -M,\n"
"           numeric -n, random -R, version -V\n"
msgstr ""
"      --sort=CUVÂNT           sortează conform CUVÂNTului: general-numeric „-"
"g”, \n"
"                              human-numeric „-h”, month „-M”, numeric „-"
"n”, \n"
"                              random „-R” sau version „-V”\n"

#: src/sort.c:488
msgid ""
"  -V, --version-sort\n"
"         natural sort of (version) numbers within text\n"
msgstr ""
"  -V, --version-sort          sortare naturală de numere (de versiuni) din "
"text\n"

#: src/sort.c:492
msgid ""
"\n"
"Other options:\n"
"\n"
msgstr ""
"\n"
"Alte opțiuni:\n"
"\n"

#: src/sort.c:497
msgid ""
"      --batch-size=NMERGE\n"
"         merge at most NMERGE inputs at once; for more use temp files\n"
msgstr ""
"      --batch-size=NCOMBI combină cel mult NCOMBI intrări odată;\n"
"                          pentru mai multe, utilizează fișiere temporale\n"

#: src/sort.c:501
msgid ""
"  -c, --check, --check=diagnose-first\n"
"         check for sorted input; do not sort\n"
msgstr ""
"  -c, --check, --check=diagnose-first \n"
"                          verifică intrarea sortată; nu sortează\n"

#: src/sort.c:505
msgid ""
"  -C, --check=quiet, --check=silent\n"
"         like -c, but do not report first bad line\n"
msgstr ""
"  -C, --check=quiet, --check=silent \n"
"                          ca „-c”, dar nu raportează prima linie greșită\n"

#: src/sort.c:509
msgid ""
"      --compress-program=PROG\n"
"         compress temporaries with PROG; decompress them with PROG -d\n"
msgstr ""
"      --compress-program=PROG \n"
"                          comprimă fișierele temporale cu PROG;\n"
"                          le decomprimă cu PROG -d\n"

#: src/sort.c:513
msgid ""
"      --debug\n"
"         annotate the part of the line used to sort,\n"
"         and warn about questionable usage to standard error\n"
msgstr ""
"      --debug             adnotează partea de linie folosită pentru "
"sortare,\n"
"                          și avertizează despre utilizarea chestionabilă "
"la \n"
"                          ieșiriea de eroare standard\n"

#: src/sort.c:518
msgid ""
"      --files0-from=F\n"
