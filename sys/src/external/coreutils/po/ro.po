#, c-format
msgid "Usage: %s [OPTION]... FILE...\n"
msgstr "Utilizare: %s [OPȚIUNE]... FIȘIER...\n"

#: src/readlink.c:62
msgid ""
"Print value of a symbolic link or canonical file name\n"
"\n"
msgstr ""
"Afișează valoarea unei legături simbolice sau numele canonic al unui "
"fișier.\n"
"\n"

#: src/readlink.c:64
msgid ""
"  -f, --canonicalize\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively;\n"
"         all but the last component must exist\n"
msgstr ""
"  -f, --canonicalize            canonizează urmând recursiv fiecare "
"legătură \n"
"                                simbolică din fiecare componentă a numelui "
"dat; \n"
"                                toate, în afară de ultima componentă, "
"trebuie \n"
"                                să existe\n"

#: src/readlink.c:70
msgid ""
"  -e, --canonicalize-existing\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively;\n"
"         all components must exist\n"
msgstr ""
"  -e, --canonicalize-existing   canonizează urmând recursiv fiecare "
"legătură \n"
"                                simbolică din fiecare componentă a numelui "
"dat,\n"
"                                toate componentele trebuie să existe\n"

#: src/readlink.c:76
msgid ""
"  -m, --canonicalize-missing\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively,\n"
"         without requirements on components existence\n"
msgstr ""
"  -m, --canonicalize-missing    canonizează urmând recursiv fiecare "
"legătură \n"
"                                simbolică din fiecare componentă a numelui "
"dat,\n"
"                                fără cerințe privind existența "
"componentelor\n"

#: src/readlink.c:82
msgid ""
"  -n, --no-newline\n"
"         do not output the trailing delimiter\n"
msgstr "  -n, --no-newline              nu afișează delimitatorul final\n"

#: src/readlink.c:86
msgid "  -q, --quiet\n"
msgstr "  -q, --quiet\n"

#: src/readlink.c:89
msgid ""
"  -s, --silent\n"
"         suppress most error messages\n"
"         (on by default if POSIXLY_CORRECT is not set)\n"
msgstr ""
"  -s, --silent                  suprimă majoritatea mesajelor de eroare "
"(activată\n"
"                                implicit dacă POSIXLY_CORRECT nu este "
"definită)\n"

#: src/readlink.c:94
msgid ""
"  -v, --verbose\n"
"         report error messages\n"
"         (on by default if POSIXLY_CORRECT is set)\n"
msgstr ""
"  -v, --verbose                 raportează mesajele de eroare (activată "
"implicit\n"
"                                dacă POSIXLY_CORRECT este definită)\n"

#: src/readlink.c:169
