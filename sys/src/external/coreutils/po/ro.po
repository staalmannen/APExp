"  -L, --logical                resolve '..' components before symlinks\n"
msgstr ""
"  -L, --logical                rezolvă componentele „..” înainte de legături "
"simbolice\n"

#: src/realpath.c:88
msgid ""
"  -P, --physical               resolve symlinks as encountered (default)\n"
msgstr ""
"  -P, --physical               rezolvă legăturile simbolice așa cum au fost "
"întâlnite\n"
"                               (modul implicit)\n"

#: src/realpath.c:91
msgid "  -q, --quiet                  suppress most error messages\n"
msgstr ""
"  -q, --quiet                  suprimă majoritatea mesajelor de eroare\n"

#: src/realpath.c:94
