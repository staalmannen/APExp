msgstr "nu s-a putut obține starea lui %s. se omite %s"

#: src/remove.c:512 src/remove.c:562
#, c-format
msgid "skipping %s, since it's on a different device"
msgstr "se omite %s, deoarece se află pe un alt dispozitiv"

#: src/remove.c:514
#, c-format
