#, c-format
msgid "Usage: %s [OPTION]... DIRECTORY...\n"
msgstr "Utilizare: %s [OPȚIUNE]... DOSAR...\n"

#: src/mkdir.c:58
msgid "Create the DIRECTORY(ies), if they do not already exist.\n"
msgstr "Creează DIRECTORUL(ele), dacă acestea nu există deja.\n"

#: src/mkdir.c:64
msgid ""
"  -m, --mode=MODE\n"
"         set file mode (as in chmod), not a=rwx - umask\n"
msgstr ""
"  -m, --mode=MOD          stabilește modul fișierului (ca în chmod), nu ca "
"în a=rwx - umask\n"

#: src/mkdir.c:68
msgid ""
"  -p, --parents\n"
"         no error if existing, make parent directories as needed,\n"
"         with their file modes unaffected by any -m option\n"
msgstr ""
"  -p, --parents           creează directoare părinte după cum este necesar, "
"nu generează nicio\n"
"                          eroare dacă există, cu modurile lor de fișier "
"neafectate de nicio opțiune „-m”\n"

#: src/mkdir.c:73
msgid ""
"  -v, --verbose\n"
"         print a message for each created directory\n"
msgstr ""
"  -v, --verbose           afișează un mesaj pentru fiecare director creat\n"

#: src/mkdir.c:77
msgid ""
"  -Z\n"
"         set SELinux security context of each created directory\n"
"         to the default type\n"
msgstr ""
"  -Z                      stabilește contextul de securitate SELinux "
"pentru \n"
"                          fiecare director creat la tipul implicit\n"

#: src/mkdir.c:234
#, c-format
msgid "created directory %s"
msgstr "s-a creat directorul %s"

#: src/mkdir.c:257 src/mkfifo.c:123 src/mknod.c:139
#, c-format
msgid ""
"warning: ignoring --context; it requires an SELinux/SMACK-enabled kernel"
msgstr ""
"avertisment: se ignoră opțiunea „--context”; necesită un nucleu cu SELinux/"
"SMACK activat"

# R-GC, scrie:
# acest mesaj, și următoarele, pot să fie
# vizualizate, rulînd comanda:
# «mkfifo --help».
# NOTĂ: numai acest mesaj, poate să fie
# vizualizat, deasemenea, rulînd
