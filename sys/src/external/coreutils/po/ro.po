msgid "  -b, --boot        time of last system boot\n"
msgstr "  -b, --boot              ora ultimei porniri a sistemului\n"

#: src/who.c:643
msgid "  -d, --dead        print dead processes\n"
msgstr "  -d, --dead              afișează procesele moarte\n"

#: src/who.c:646
msgid "  -H, --heading     print line of column headings\n"
msgstr "  -H, --heading           afișează linia de titluri a coloanelor\n"

#: src/who.c:649
msgid "  -l, --login       print system login processes\n"
msgstr "  -l, --login             afișează procesele de conectare la sistem\n"

#: src/who.c:652
msgid "      --lookup      attempt to canonicalize hostnames via DNS\n"
msgstr ""
