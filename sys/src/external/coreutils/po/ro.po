"                          conectați\n"

#: src/who.c:664
msgid "  -r, --runlevel    print current runlevel\n"
msgstr "  -r, --runlevel          afișează nivelul de rulare curent\n"

#: src/who.c:667
msgid "  -s, --short       print only name, line, and time (default)\n"
msgstr ""
"  -s, --short             afișează numai numele, linia și ora (implicit)\n"

#: src/who.c:670
msgid "  -t, --time        print last system clock change\n"
msgstr ""
