#: src/uniq.c:158
#, c-format
msgid "Usage: %s [OPTION]... [INPUT [OUTPUT]]\n"
msgstr "Utilizare: %s [OPȚIUNE]... [INTRARE [IEȘIRE]]\n"

#: src/uniq.c:162
msgid ""
"Filter adjacent matching lines from INPUT (or standard input),\n"
"writing to OUTPUT (or standard output).\n"
"\n"
"With no options, matching lines are merged to the first occurrence.\n"
msgstr ""
"Filtrează liniile adiacente care se potrivesc din INTRARE (sau intrarea "
"standard),\n"
"scriind rezultatul la IEȘIRE (sau ieșirea standard).\n"
"\n"
"Fără opțiuni, liniile care se potrivesc sunt îmbinate la prima ocurență.\n"

#: src/uniq.c:171
msgid ""
"  -c, --count\n"
"         prefix lines by the number of occurrences\n"
msgstr ""
"  -c, --count             prefixează liniile după numărul de ocurențe\n"

#: src/uniq.c:175
msgid ""
"  -d, --repeated\n"
"         only print duplicate lines, one for each group\n"
msgstr ""
"  -d, --repeated          afișează doar linii duplicate, câte una pentru \n"
"                          fiecare grup\n"

#: src/uniq.c:179
msgid ""
"  -D\n"
"         print all duplicate lines\n"
msgstr "  -D                      afișează toate liniile duplicate\n"

#: src/uniq.c:183
msgid ""
"      --all-repeated[=METHOD]\n"
"         like -D, but allow separating groups with an empty line;\n"
"         METHOD={none(default),prepend,separate}\n"
msgstr ""
"      --all-repeated[=METODA] \n"
"                          ca „-D”, dar permite separarea grupurilor\n"
"                          cu o linie goală;\n"
"                          METODA={none(implicit), prepend, separate}\n"

#: src/uniq.c:188
msgid ""
"  -f, --skip-fields=N\n"
"         avoid comparing the first N fields\n"
msgstr "  -f, --skip-fields=N     evită compararea primelor N câmpuri\n"

#: src/uniq.c:192
msgid ""
"      --group[=METHOD]\n"
"         show all items, separating groups with an empty line;\n"
"         METHOD={separate(default),prepend,append,both}\n"
msgstr ""
"      --group[=METODA]    afișează toate elementele, separând grupurile\n"
"                          cu o linie goală;\n"
"                          METODA={separate(implicit), prepend, append, "
"both}\n"

#: src/uniq.c:197
msgid ""
"  -i, --ignore-case\n"
"         ignore differences in case when comparing\n"
msgstr ""
"  -i, --ignore-case       ignoră diferențele între majuscule și minuscule \n"
"                          când compară\n"

#: src/uniq.c:201
msgid ""
"  -s, --skip-chars=N\n"
"         avoid comparing the first N characters\n"
msgstr "  -s, --skip-chars=N      evită compararea primelor N caractere\n"

#: src/uniq.c:205
msgid ""
"  -u, --unique\n"
"         only print unique lines\n"
msgstr "  -u, --unique            afișează doar liniile unice\n"

#: src/uniq.c:213
msgid ""
"  -w, --check-chars=N\n"
"         compare no more than N characters in lines\n"
msgstr ""
"  -w, --check-chars=N     nu compară mai mult de N caractere în linii\n"

#: src/uniq.c:219
msgid ""
"\n"
"A field is a run of blanks (usually spaces and/or TABs), then non-blank\n"
"characters.  Fields are skipped before chars.\n"
msgstr ""
"\n"
"Un câmp este o serie de spații libere (de obicei spații și/sau "
"tabulatoare), \n"
"apoi caractere care nu sunt goale.  Câmpurile dinaintea caracterelor sunt "
"omise.\n"

