#: src/basename.c:47
#, c-format
msgid ""
"Usage: %s NAME [SUFFIX]\n"
"  or:  %s OPTION... NAME...\n"
msgstr ""
"Utilizare: %s NUME [SUFIX]\n"
"  sau: %s OPȚIUNE... NUME...\n"

#: src/basename.c:52
msgid ""
"Print NAME with any leading directory components removed.\n"
"If specified, also remove a trailing SUFFIX.\n"
msgstr ""
"Afișează NUME cu toate componentele ce preced directorul eliminate.\n"
"Dacă este specificat, elimină, de asemenea, un SUFIX final.\n"

#: src/basename.c:59
msgid ""
"  -a, --multiple\n"
"         support multiple arguments and treat each as a NAME\n"
msgstr ""
"  -a, --multiple       acceptă mai multe argumente și-le tratează pe fiecare "
"drept NUME\n"

#: src/basename.c:63
msgid ""
"  -s, --suffix=SUFFIX\n"
"         remove a trailing SUFFIX; implies -a\n"
msgstr "  -s, --suffix=SUFIX   elimină un SUFIX final; implică „-a”\n"

#: src/basename.c:67 src/dirname.c:58 src/readlink.c:99
msgid ""
"  -z, --zero\n"
"         end each output line with NUL, not newline\n"
msgstr ""
"  -z, --zero           termină fiecare linie de ieșire cu NUL, nu cu o nouă "
"linie\n"

#: src/basename.c:73
#, c-format
msgid ""
"\n"
"Examples:\n"
"  %s /usr/bin/sort          -> \"sort\"\n"
"  %s include/stdio.h .h     -> \"stdio\"\n"
"  %s -s .h include/stdio.h  -> \"stdio\"\n"
"  %s -a any/str1 any/str2   -> \"str1\" followed by \"str2\"\n"
msgstr ""
"\n"
"Exemple:\n"
"  %s /usr/bin/sort          -> „sort”\n"
"  %s include/stdio.h .h     -> „stdio”\n"
"  %s -s .h include/stdio.h  -> „stdio”\n"
"  %s -a any/str1 any/str2   -> „str1” urmat de „str2”\n"

