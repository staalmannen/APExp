msgstr "pseudo-adresa este prea mare pentru intrare"

#: src/od.c:1740
#, c-format
msgid "invalid output address radix '%c'; it must be one character from [doxn]"
msgstr ""
"cod de bază „%c” nevalid pentru adrese;”; trebuie să fie un caracter din "
"[doxn]"

#: src/od.c:1877
#, c-format
msgid "no type may be specified when dumping strings"
msgstr "nu poate fi specificat niciun tip pentru afișarea brută a șirurilor"

#: src/od.c:1952
msgid "compatibility mode supports at most one file"
msgstr "regimul de compatibilitate susține cel mult un fișier"

#: src/od.c:1971
#, c-format
msgid "skip-bytes + read-bytes is too large"
msgstr "skip-bytes + read-bytes este prea mare"

#: src/od.c:2013
#, c-format
msgid "warning: invalid width %td; using %d instead"
msgstr "atenție: lățime nevalidă %td; se utilizează %d în loc"

#: src/od.c:2032
#, c-format
msgid "%td is too large"
msgstr "%td este prea mare"

#: src/paste.c:227
#, c-format
msgid "standard input is closed"
msgstr "intrarea standard este închisă"

# R-GC, scrie:
# acest mesaj, și următoarele, pot să fie
# vizualizate, rulînd comanda:
# «paste --help».
#: src/paste.c:457
msgid ""
"Write lines consisting of the sequentially corresponding lines from\n"
"each FILE, separated by TABs, to standard output.\n"
"The newline of every line except the line from the last file\n"
"is replaced with a TAB.\n"
msgstr ""
"Scrie linii care constau din liniile corespunzătoare secvențial din\n"
"fiecare FIȘIER, separate prin tabulatoare, la ieșirea standard.\n"
"Caracterul de linie nouă din fiecare linie, cu excepția liniei din\n"
"ultimul fișier, este înlocuit cu un tabulator.\n"

#: src/paste.c:467
msgid ""
"  -d, --delimiters=LIST\n"
"         reuse characters from LIST instead of TABs;\n"
"         backslash escapes are supported\n"
msgstr ""
"  -d, --delimiters=LISTĂ  utilizează caracterele din LISTĂ în loc de "
"tabulatoare;\n"
"                          sunt acceptate caracterele de eludare bară oblică "
"inversă\n"

#: src/paste.c:472
msgid ""
"  -s, --serial\n"
"         paste one file at a time instead of in parallel; the newline of\n"
"         every line except the last line in each file is replaced with a "
"TAB\n"
msgstr ""
"  -s, --serial            lipește un singur fișier odată, în loc să le "
"lipească\n"
"                          mai multe fișiere în paralel; caracterul de linie "
"nouă\n"
"                          din fiecare linie, cu excepția ultimei linii din "
"fiecare\n"
"                          fișier, este înlocuit cu un tabulator\n"

#: src/paste.c:542
#, c-format
msgid "delimiter list ends with an unescaped backslash: %s"
msgstr ""
"lista delimitatorilor se termină cu o bară oblică inversă fără eludare: %s"

