#: src/wc.c:202
msgid ""
"\n"
"The options below may be used to select which counts are printed, always in\n"
"the following order: newline, word, character, byte, maximum line length.\n"
msgstr ""
"\n"
"Opțiunile de mai jos pot fi folosite pentru a selecta contoarele care sunt "
"afișate, \n"
"întotdeauna în următoarea ordine: \n"
"linie nouă, cuvânt, caracter, octet, lungime maximă a liniei.\n"

#: src/wc.c:207
msgid ""
"  -c, --bytes\n"
"         print the byte counts\n"
msgstr "  -c, --bytes             afișează contorul de octeți\n"

#: src/wc.c:211
msgid ""
"  -m, --chars\n"
"         print the character counts\n"
msgstr "  -m, --chars             afișează contorul de caractere\n"

#: src/wc.c:215
msgid ""
"  -l, --lines\n"
"         print the newline counts\n"
msgstr "  -l, --lines             afișează contorul de linie nouă\n"

#: src/wc.c:219
msgid ""
"      --debug\n"
"         indicate what line count acceleration is used\n"
msgstr ""
"      --debug            indică ce accelerare a numărului de linii este "
"utilizată\n"

#: src/wc.c:223
msgid ""
"      --files0-from=F\n"
"         read input from the files specified by\n"
"         NUL-terminated names in file F;\n"
"         If F is -, read names from standard input\n"
msgstr ""
"      --files0-from=F     citește intrarea din fișierele specificate de \n"
"                          numele terminate cu NUL din fișierul F;\n"
"                          dacă F este - atunci citește numele de la \n"
"                          intrarea standard\n"

#: src/wc.c:229
msgid ""
"  -L, --max-line-length\n"
"         print the maximum display width\n"
msgstr "  -L, --max-line-length   afișează lățimea maximă de afișare\n"

#: src/wc.c:233
msgid ""
"  -w, --words\n"
"         print the word counts\n"
msgstr "  -w, --words             afișează contorul de cuvinte\n"

#: src/wc.c:237
msgid ""
"      --total=WHEN\n"
"         when to print a line with total counts;\n"
"         WHEN can be: auto, always, only, never\n"
msgstr ""
"      --total=CÂND       când să se afișeze o linie cu contorizările "
"realizate;\n"
"                           CÂND poate fi: auto, always, only, never\n"

