#: src/dd.c:531
msgid ""
"Copy a file, converting and formatting according to the operands.\n"
"\n"
msgstr ""
"Sao chép tập tin, chuyển đổi và định dạng theo các toán hạng.\n"
"\n"

#: src/dd.c:535
msgid ""
"  bs=BYTES        read and write up to BYTES bytes at a time (default: "
"512);\n"
"                  overrides ibs and obs\n"
msgstr ""
"  bs=BYTES        đọc và ghi BYTES byte mỗi lần(mặc định: 512);\n"
"                  đè ibs và obs\n"

#: src/dd.c:539
msgid "  cbs=BYTES       convert BYTES bytes at a time\n"
msgstr "  cbs=BYTES       chuyển đổi BYTES byte mỗi lần\n"

#: src/dd.c:542
msgid ""
"  conv=CONVS      convert the file as per the comma separated symbol list\n"
msgstr ""
"  conv=CONVS      chuyển đổi tập tin tùy theo danh sách các ký hiệu,\n"
"                    phân cách nhau bởi dấu phẩy\n"

#: src/dd.c:545
msgid "  count=N         copy only N input blocks\n"
msgstr "  count=SỐ        chỉ sao chép SỐ khối đầu vào\n"

#: src/dd.c:548
msgid "  ibs=BYTES       read up to BYTES bytes at a time (default: 512)\n"
msgstr "  ibs=BYTES       đọc BYTES byte mỗi lần (mặc định: 512)\n"

#: src/dd.c:551
#, fuzzy
msgid "  if=FILE         read from FILE instead of standard input\n"
msgstr "  if=TẬP_TIN      đọc từ TẬP_TIN thay cho đầu vào tiêu chuẩn\n"

#: src/dd.c:554
msgid "  iflag=FLAGS     read as per the comma separated symbol list\n"
msgstr ""
"  iflag=CỜ        đọc tùy theo danh sách các ký hiệu phân cách bởi dấu phẩy\n"

#: src/dd.c:557
msgid "  obs=BYTES       write BYTES bytes at a time (default: 512)\n"
msgstr "  obs=BYTES       ghi BYTES byte mỗi lần (mặc định: 512)\n"

#: src/dd.c:560
#, fuzzy
msgid "  of=FILE         write to FILE instead of standard output\n"
