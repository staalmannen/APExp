#: src/tac.c:123
msgid "Write each FILE to standard output, last line first.\n"
msgstr "Skriv varje FIL till standard ut, sista raden först.\n"

#: src/tac.c:130
msgid ""
"  -b, --before             attach the separator before instead of after\n"
msgstr ""
"  -b, --before             sätt in skiljetecken före i stället för efter\n"

#: src/tac.c:133
msgid ""
"  -r, --regex              interpret the separator as a regular expression\n"
msgstr ""
"  -r, --regex              tolka skiljetecknet som ett reguljärt uttryck\n"

#: src/tac.c:136
msgid ""
"  -s, --separator=STRING   use STRING as the separator instead of newline\n"
msgstr ""
"  -s, --separator=STRÄNG   använd STRÄNG som skiljetecken i stället för ny "
"rad\n"

#: src/tac.c:141
msgid ""
"\n"
"Non-seekable input is buffered to $TMPDIR, defaulting to /tmp.\n"
msgstr ""
"\n"
"Ej sökbar indata buffras till $TMPDIR, som standard /tmp.\n"

#: src/tac.c:220 src/tac.c:230 src/tac.c:338
#, c-format
