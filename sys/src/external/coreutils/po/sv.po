#, c-format
msgid "Usage: %s [OPTION]... [FILE]\n"
msgstr "Användning: %s [FLAGGA]... [FIL]\n"

#: src/basenc.c:108
msgid "basenc encode or decode FILE, or standard input, to standard output.\n"
msgstr "basenc-koda eller -avkoda FIL, eller standard in, till standard ut.\n"

#: src/basenc.c:112
#, c-format
msgid "Base%d encode or decode FILE, or standard input, to standard output.\n"
msgstr "Base%d-koda eller -avkoda FIL, eller standard in, till standard ut.\n"

#: src/basenc.c:120
msgid ""
"      --base64\n"
"         same as 'base64' program (RFC4648 section 4)\n"
msgstr ""
"      --base64\n"
"         samma som programmet ”base64” (RFC4648 avsnitt 4)\n"

#: src/basenc.c:124
msgid ""
"      --base64url\n"
"         file- and url-safe base64 (RFC4648 section 5)\n"
msgstr ""
"      --base64url\n"
"         fil- och url-säker base64 (RFC4648 avsnitt 5)\n"

#: src/basenc.c:128
msgid ""
"      --base58\n"
"         visually unambiguous base58 encoding\n"
msgstr ""
"      --base58\n"
"         visuellt entydig base58-kodning\n"

#: src/basenc.c:132
msgid ""
"      --base32\n"
"         same as 'base32' program (RFC4648 section 6)\n"
msgstr ""
"      --base32\n"
"         samma som programmet ”base32” (RFC4648 avsnitt 6)\n"

#: src/basenc.c:136
msgid ""
"      --base32hex\n"
"         extended hex alphabet base32 (RFC4648 section 7)\n"
msgstr ""
"      --base32hex\n"
"         utökat hexalfabet base32 (RFC4648 avsnitt 7)\n"

#: src/basenc.c:140
msgid ""
"      --base16\n"
"         hex encoding (RFC4648 section 8)\n"
msgstr ""
"      --base16\n"
"         hexkodning (RFC4648 avsnitt 8)\n"

#: src/basenc.c:144
msgid ""
"      --base2msbf\n"
"         bit string with most significant bit (msb) first\n"
msgstr ""
"      --base2msbf\n"
"         bitsträng med mest signifikant bit (msb) först\n"

#: src/basenc.c:148
msgid ""
"      --base2lsbf\n"
"         bit string with least significant bit (lsb) first\n"
msgstr ""
"      --base2lsbf\n"
"         bitsträng med minst signifikant bit (lsb) först\n"

#: src/basenc.c:153
msgid ""
"  -d, --decode\n"
"         decode data\n"
msgstr ""
"  -d, --decode\n"
"         avkoda data\n"

#: src/basenc.c:157
msgid ""
"  -i, --ignore-garbage\n"
"         when decoding, ignore non-alphabet characters\n"
msgstr ""
"  -i, --ignore-garbage\n"
"         vid avkodning, bortse från ickealfabetiska tecken\n"

#: src/basenc.c:161
msgid ""
"  -w, --wrap=COLS\n"
"         wrap encoded lines after COLS character (default 76).\n"
"         Use 0 to disable line wrapping\n"
msgstr ""
"  -w, --wrap=KOL\n"
"         bryt kodade rader efter KOL tecken (76 som standard).\n"
"         Använd 0 för att slå av radbrytning\n"

#: src/basenc.c:167
msgid ""
"      --z85\n"
"         ascii85-like encoding (ZeroMQ spec:32/Z85);\n"
"         when encoding, input length must be a multiple of 4;\n"
"         when decoding, input length must be a multiple of 5\n"
msgstr ""
"      --z85\n"
"         ascii85-liknande kodning (ZeroMQ spec:32/Z85);\n"
"         vid kodning måste indatalängden vara en multipel av 4;\n"
"         vid avkodning måste indatalängden vara en multipel av 5\n"

#: src/basenc.c:177
msgid ""
"\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"Vid avkodning kan indata innehålla nyradstecken förutom de byte som\n"
"tillhör det formella alfabetet.  Använd --ignore-garbage för att försöka\n"
"återhämta från tecken utanför alfabetet i den kodade strömmen.\n"

#: src/basenc.c:184
#, c-format
msgid ""
"\n"
"The data are encoded as described for the %s alphabet in RFC 4648.\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal %s alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"Data kodas för %s-alfabetet enligt beskrivningen i RFC 3548.  Vid\n"
"avkodning kan indata innehålla nyradstecken förutom de byte som\n"
"tillhör det egentliga %s-alfabetet.  Använd --ignore-garbage för\n"
"att försöka återhämta från tecken utanför alfabetet i den kodade\n"
"strömmen.\n"

#: src/basenc.c:879
#, c-format
msgid "invalid input (length must be multiple of 4 characters)"
msgstr "felaktig indata (längden måste vara en multipel av 4 tecken)"

#: src/basenc.c:1479 src/cat.c:972 src/fmt.c:459
#, c-format
msgid "closing standard input"
msgstr "stänger standard in"

