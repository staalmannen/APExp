msgstr "standard in stängd"

#: src/paste.c:457
msgid ""
"Write lines consisting of the sequentially corresponding lines from\n"
"each FILE, separated by TABs, to standard output.\n"
"The newline of every line except the line from the last file\n"
"is replaced with a TAB.\n"
msgstr ""
"Skriv rader som består av sekventiellt korresponderande rader\n"
"från varje FIL, åtskilda med TAB, till standard ut.\n"
"Nyraden på varje rad utom raden från den sista filen ersätts\n"
"med en TAB.\n"

#: src/paste.c:467
msgid ""
"  -d, --delimiters=LIST\n"
"         reuse characters from LIST instead of TABs;\n"
"         backslash escapes are supported\n"
msgstr ""
"  -d, --delimiters=LISTA\n"
"         återanvänd tecken från LISTA istället för TAB;\n"
"         styrsekvenser med omvänt snedstreck stödjs\n"

#: src/paste.c:472
msgid ""
"  -s, --serial\n"
"         paste one file at a time instead of in parallel; the newline of\n"
"         every line except the last line in each file is replaced with a "
"TAB\n"
msgstr ""
"  -s, --serial\n"
"         klistra in en fil i taget i stället för parallellt; nyraden på\n"
"         varje rad utom den sista raden i varje fil ersätts med en TAB\n"

#: src/paste.c:542
#, c-format
msgid "delimiter list ends with an unescaped backslash: %s"
msgstr "avgränsningslistor avslutas med ett oskyddat omvänt snedstreck: %s"

