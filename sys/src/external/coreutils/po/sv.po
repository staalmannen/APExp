msgstr "Användning: %s [FLAGGA]… [FIL [PREFIX]]\n"

#: src/split.c:230
msgid ""
"Output pieces of FILE to PREFIXaa, PREFIXab, ...;\n"
"default size is 1000 lines, and default PREFIX is 'x'.\n"
msgstr ""
"Skriv ut delar av FIL till PREFIXaa, PREFIXab, …;\n"
"standardstorlek är 1000 rader, och standardPREFIX är ”x”.\n"

#: src/split.c:238
#, c-format
msgid ""
"  -a, --suffix-length=N\n"
"         generate suffixes of length N (default %d)\n"
msgstr ""
"  -a, --suffix-length=N\n"
"         använd ändelser av längd N (standard %d)\n"

#: src/split.c:242
msgid ""
"      --additional-suffix=SUFFIX\n"
"         append an additional SUFFIX to file names\n"
msgstr ""
"      --additional-suffix=ÄNDELSE\n"
"         lägg till en extra ÄNDELSE på filnamn\n"

#: src/split.c:246
msgid ""
"  -b, --bytes=SIZE\n"
"         put SIZE bytes per output file\n"
msgstr ""
"  -b, --bytes=STORLEK\n"
"         placera STORLEK byte i varje utfil\n"

#: src/split.c:250
msgid ""
"  -C, --line-bytes=SIZE\n"
"         put at most SIZE bytes of records per output file\n"
msgstr ""
"  -C, --line-bytes=STORLEK\n"
"         placera max STORLEK byte med poster per utfil\n"

#: src/split.c:254
msgid ""
"  -d\n"
"         use numeric suffixes starting at 0, not alphabetic\n"
