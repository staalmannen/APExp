msgstr "  nolinks   misslyckas ifall flera länkar\n"

#: src/dd.c:644
msgid "  binary    use binary I/O for data\n"
msgstr "  binary    använd binär I/O för data\n"

#: src/dd.c:646
msgid "  text      use text I/O for data\n"
msgstr "  text      använd text-I/O för data\n"

