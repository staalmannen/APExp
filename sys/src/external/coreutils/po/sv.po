#: src/pinky.c:490
msgid "  -b     omit the user's home directory and shell in long format\n"
msgstr ""
"  -b     utelämna användarens hemkatalog och skal i det långa formatet\n"

#: src/pinky.c:493
msgid "  -h     omit the user's project file in long format\n"
msgstr "  -h     utelämna användarens projektfil i det långa formatet\n"

#: src/pinky.c:496
msgid "  -p     omit the user's plan file in long format\n"
msgstr "  -p     utelämna användarens planfil i det långa formatet\n"

#: src/pinky.c:499
msgid "  -s     do short format output, this is the default\n"
msgstr "  -s     skriv ut i kort format, detta är standard\n"

#: src/pinky.c:502
msgid "  -f     omit the line of column headings in short format\n"
msgstr "  -f     utelämna raden med kolumnrubriker i kort format\n"

#: src/pinky.c:505
msgid "  -w     omit the user's full name in short format\n"
msgstr "  -w     utelämna användarens fullständiga namn i kort format\n"

#: src/pinky.c:508
msgid "  -i     omit the user's full name and remote host in short format\n"
msgstr ""
"  -i     utelämna användarens fullständiga namn och fjärrvärd i kort format\n"

#: src/pinky.c:511
msgid ""
"  -q     omit the user's full name, remote host and idle time in short "
"format\n"
msgstr ""
"  -q     utelämna användarens fullständiga namn, fjärrvärd och overksamma "
"tiden i kort format\n"

#: src/pinky.c:514
msgid ""
"      --lookup\n"
"         attempt to canonicalize hostnames via DNS\n"
msgstr ""
"      --lookup\n"
"         försök kvalificera värdnamn med hjälp av DNS\n"

#: src/pinky.c:520
