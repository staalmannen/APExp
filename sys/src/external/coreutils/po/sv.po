msgstr ""
"  -i, --ignore-file=FIL          läs lista av ord att ignorera från FIL\n"

#: src/ptx.c:1723
msgid "  -o, --only-file=FILE           read only word list from this FILE\n"
msgstr ""
"  -o, --only-file=FIL            läs lista av ord att endast använda från "
"FIL\n"

#: src/ptx.c:1726
msgid ""
"  -r, --references               first field of each line is a reference\n"
msgstr ""
"  -r, --references               första fältet på varje rad är en referens\n"

#: src/ptx.c:1729
msgid ""
"  -t, --typeset-mode             change the default width from 72 to 100\n"
msgstr ""
"  -t, --typeset-mode             ändra standardbredden från 72 till 100\n"

#: src/ptx.c:1732
msgid ""
"  -w, --width=NUMBER             output width in columns, reference "
