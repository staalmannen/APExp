msgstr "stöd för avx2 inte funnet"

#: src/wc.c:194
msgid ""
"Print newline, word, and byte counts for each FILE, and a total line if\n"
"more than one FILE is specified.  A word is a nonempty sequence of non "
"white\n"
"space delimited by white space characters or by start or end of input.\n"
msgstr ""
"Skriv antal nyrader, ord och byte för varje FIL, och en rad med totaler om\n"
"mer än en FIL angavs. Ett ord är en icketom sekvens av icke-mellanrum\n"
"avgränsade av mellanslag eller början elle slutet av indata.\n"

#: src/wc.c:202
msgid ""
"\n"
"The options below may be used to select which counts are printed, always in\n"
"the following order: newline, word, character, byte, maximum line length.\n"
msgstr ""
"\n"
"Flaggorna nedan kan användas för att välja vilka antal som skrivs, alltid\n"
"i följande ordning: nyrad, ord, tecken, byte, maximal radlängd.\n"

#: src/wc.c:207
msgid ""
"  -c, --bytes\n"
"         print the byte counts\n"
msgstr ""
"  -c, --bytes\n"
"         skriv antalet byte\n"

#: src/wc.c:211
msgid ""
"  -m, --chars\n"
"         print the character counts\n"
msgstr ""
"  -m, --chars\n"
"         skriv antalet tecken\n"

#: src/wc.c:215
msgid ""
"  -l, --lines\n"
"         print the newline counts\n"
msgstr ""
"  -l, --lines\n"
"         skriv antalet rader\n"

#: src/wc.c:219
msgid ""
"      --debug\n"
"         indicate what line count acceleration is used\n"
msgstr ""
"      --debug\n"
"         indikera vilken acceleration av radräkning som används\n"

#: src/wc.c:223
msgid ""
"      --files0-from=F\n"
"         read input from the files specified by\n"
"         NUL-terminated names in file F;\n"
"         If F is -, read names from standard input\n"
msgstr ""
"      --files0-from=F\n"
"         läs indata från filer som anges med\n"
"         NOLL-terminerade namn i filen F;\n"
"         Om F är - så läs namn från standard in\n"

#: src/wc.c:229
msgid ""
"  -L, --max-line-length\n"
"         print the maximum display width\n"
msgstr ""
"  -L, --max-line-length\n"
"         skriv den längsta utskriftsbredden\n"

#: src/wc.c:233
msgid ""
"  -w, --words\n"
"         print the word counts\n"
msgstr ""
"  -w, --words\n"
"         skriv antalet ord\n"

#: src/wc.c:237
msgid ""
"      --total=WHEN\n"
"         when to print a line with total counts;\n"
"         WHEN can be: auto, always, only, never\n"
msgstr ""
"      --total=NÄR\n"
"         när en rad med totala antal skall skrivas;\n"
"         NÄR kan vara: auto, always, only, never\n"

