"  -d,\n"
"         använd numeriska suffix från 0, inte alfabetiska\n"

#: src/split.c:258
msgid ""
"      --numeric-suffixes[=FROM]\n"
"         same as -d, but allow setting the start value\n"
msgstr ""
"      --numeric-suffixes[=FRÅN]\n"
"         samma som -d, men tillåt att startvärdet sätts\n"

#: src/split.c:262
msgid ""
"  -x\n"
"         use hex suffixes starting at 0, not alphabetic\n"
msgstr ""
"  -x\n"
"         använd hex-suffix från 0, inte alfabetiska\n"

#: src/split.c:266
msgid ""
"      --hex-suffixes[=FROM]\n"
"         same as -x, but allow setting the start value\n"
msgstr ""
"      --hex-suffixes[=FRÅN]\n"
"         samma som -x, men tillåt att startvärdet sätts\n"

#: src/split.c:270
msgid ""
"  -e, --elide-empty-files\n"
"         do not generate empty output files with '-n'\n"
msgstr ""
