"  -P, --portability\n"
"         use the POSIX output format\n"
msgstr ""
"  -P, --portability\n"
"         använd POSIX utmatningsformat\n"

#: src/df.c:1550
msgid ""
"      --sync\n"
"         invoke sync before getting usage info\n"
msgstr ""
"      --sync\n"
"         anropa sync för användningsinformation inhämtas\n"

#: src/df.c:1554
msgid ""
