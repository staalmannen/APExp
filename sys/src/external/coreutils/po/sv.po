#. TRANSLATORS: The thousands and decimal separators are best
#. adjusted to an appropriate default for your locale.
#: src/df.c:1508
msgid ""
"  -a, --all\n"
"         include pseudo, duplicate, inaccessible file systems\n"
msgstr ""
"  -a, --all\n"
"         tag med pseudo-, dubblett-, oåtkomliga filsystem\n"

#: src/df.c:1512
msgid ""
"  -B, --block-size=SIZE\n"
"         scale sizes by SIZE before printing them; see SIZE format below;\n"
"         E.g., '-BM' prints sizes in units of 1,048,576 bytes\n"
msgstr ""
"  -B, --block-size=STRL\n"
"         skala storlekar med STRL före de skrivs ut; se format på STRL "
"nedan;\n"
"         t.ex. skriver ”-BM” storlekar i enheter av 1 048 576 byte\n"

#: src/df.c:1517
msgid ""
"  -h, --human-readable\n"
"         print sizes in powers of 1024 (e.g., 1023M)\n"
msgstr ""
"  -h, --human-readable\n"
"         skriv storlekar i potenser av 1024 (t.ex. 1023M)\n"

#: src/df.c:1521
msgid ""
"  -H, --si\n"
"         print sizes in powers of 1000 (e.g., 1.1G)\n"
msgstr ""
"  -H, --si\n"
"         skriv storlekar i potenser av 1000 (t.ex. 1,1G)\n"

#: src/df.c:1525
msgid ""
"  -i, --inodes\n"
"         list inode information instead of block usage\n"
msgstr ""
"  -i, --inodes\n"
"         skriv inodinformation istället för blockinformation\n"

#: src/df.c:1529 src/du.c:344
msgid ""
"  -k\n"
"         like --block-size=1K\n"
msgstr ""
"  -k\n"
"         som --block-size=1K\n"

#: src/df.c:1533
msgid ""
"  -l, --local\n"
"         limit listing to local file systems\n"
msgstr ""
"  -l, --local\n"
"         visa endast lokala filsystem\n"

#: src/df.c:1537
msgid ""
"      --no-sync\n"
"         do not invoke sync before getting usage info (default)\n"
msgstr ""
"      --no-sync\n"
"         anropa inte sync innan information hämtas (normalfall)\n"

#: src/df.c:1541
msgid ""
"      --output[=FIELD_LIST]\n"
"         use the output format defined by FIELD_LIST,\n"
"         or print all fields if FIELD_LIST is omitted\n"
msgstr ""
