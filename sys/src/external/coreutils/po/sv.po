msgstr "  KONTEXT            Fullständig säkerhetskontext\n"

#: src/runcon.c:90
msgid ""
"  -c, --compute      compute process transition context before modifying\n"
msgstr ""
"  -c, --compute      beräkna processövergångskontext före modifiering\n"

#: src/runcon.c:93
