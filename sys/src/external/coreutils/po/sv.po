msgstr "Användning: %s [FLAGGA]...\n"

#: src/nproc.c:57
msgid ""
"Print the number of processing units available to the current process,\n"
"which may be less than the number of online processors.\n"
"If the 'OMP_NUM_THREADS' or 'OMP_THREAD_LIMIT' environment variables are "
"set,\n"
"then they will determine the minimum and maximum returned value "
"respectively.\n"
"\n"
msgstr ""
"Skriv antalet processorenheter som är tillgängliga för den aktuella "
"processen,\n"
"vilket kan vara mindre än antalet inkopplade processorer.\n"
"Om miljövariablerna ”OMP_NUM_THREADS” eller ”OMP_THREAD_LIMIT” är satta,\n"
"då styr de det minsta respektive högsta returnerade värdet.\n"
"\n"

#: src/nproc.c:64
msgid ""
"      --all\n"
"         print the number of installed processors,\n"
"         disregarding any OpenMP environment variables, or CPU quotas.\n"
msgstr ""
"      --all\n"
"         skriv antalet installerade processorer,\n"
"         bortse från eventuella OpenMP-miljövariaber eller CPU-kvoter.\n"

#: src/nproc.c:69
msgid ""
"      --ignore=N\n"
"         if possible, exclude N processing units.\n"
"         The result is guaranteed to be at least 1.\n"
msgstr ""
"      --ignore=N\n"
"         om möjligt, uteslut N processorenheter.\n"
"         Resultatet garanteras att vara minst 1.\n"

#: src/numfmt.c:749
#, c-format
