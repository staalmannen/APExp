"  -z, --zero\n"
"         end each output line with NUL, not newline\n"
msgstr ""
"  -z, --zero\n"
"         إنهاء كل سطر مخرج بـ NUL، وليس بسطر جديد\n"

#: src/basename.c:73
#, c-format
