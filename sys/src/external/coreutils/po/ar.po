msgstr "‏%s: تعذر إعادة ضبط نمط عدم الحظر"

#: src/stty.c:1448
#, c-format
msgid "indx: mode: actual mode"
msgstr "‏indx: نمط: النمط الفعلي"

#: src/stty.c:1459
#, c-format
msgid "%s: unable to perform all requested operations"
msgstr "‏%s: تعذر تنفيذ جميع العمليات المطلوبة"

#: src/stty.c:1731
