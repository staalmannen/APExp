msgstr "يتطلب طبع الأسماء فقط أو المعرفات الحقيقية الخيارات -u أو -g أو -G"

#: src/id.c:227
#, c-format
msgid "option --zero not permitted in default format"
msgstr "الخيار --zero غير مسموح به في التنسيق المبدئي"

#: src/id.c:243
