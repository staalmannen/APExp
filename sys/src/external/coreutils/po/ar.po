msgstr "خيارات أنماط الإخراج المسهب والمقروء لـ stty متعارضة"

#: src/stty.c:1388
#, c-format
msgid "when specifying an output style, modes may not be set"
msgstr "عند تحديد نمط إخراج، لا يمكن ضبط الأنماط (modes)"

#: src/stty.c:1406
