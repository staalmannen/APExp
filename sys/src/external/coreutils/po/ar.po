"      --groups=قائمة_المجموعات\n"
"   تحديد مجموعات إضافية كـ g1,g2,..,gN\n"

#: src/chroot.c:197
msgid ""
"      --userspec=USER:GROUP\n"
"         specify user and group (ID or name) to use\n"
msgstr ""
"      --userspec=المستخدم:المجموعة\n"
"  تحديد المستخدم والمجموعة (رقم أو اسم) للاستخدام\n"

#: src/chroot.c:201
