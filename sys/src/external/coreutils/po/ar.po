msgid ""
"Usage: %s [OPTION]... [FILE]\n"
"  or:  %s -e [OPTION]... [ARG]...\n"
"  or:  %s -i LO-HI [OPTION]...\n"
msgstr ""
"الاستخدام: %s [خيار]... [ملف]\n"
"  أو:  %s -e [خيار]... [وسيط]...\n"
"  أو:  %s -i أدنى-أعلى [خيار]...\n"

#: src/shuf.c:62
