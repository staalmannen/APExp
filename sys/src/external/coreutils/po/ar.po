msgstr "  -a, --multiple       يدعم معطيات متعددة ويعامل كل منها كاسم\n"

#: src/basename.c:63
msgid ""
"  -s, --suffix=SUFFIX\n"
"         remove a trailing SUFFIX; implies -a\n"
msgstr ""
"  -s, --suffix=لاحقة \n"
"يحذف اللاحقة من النهاية؛ يقتضي تفعيل -a\n"

#: src/basename.c:67 src/dirname.c:58 src/readlink.c:99
