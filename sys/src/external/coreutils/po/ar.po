msgstr "‏%s: هل تريد الولوج إلى الدليل المحمي من الكتابة %s؟ "

#: src/remove.c:279
#, c-format
msgid "%s: descend into directory %s? "
msgstr "‏%s: هل تريد الولوج إلى الدليل %s؟ "

#: src/remove.c:298
