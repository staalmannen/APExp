msgid "Warning: "
msgstr "تحذير: "

#: src/df.c:1808 src/stat.c:960
msgid "cannot read table of mounted file systems"
msgstr "يتعذر قراءة جدول أنظمة الملفات الموصولة"

#: src/df.c:1843
#, c-format
msgid "no file systems processed"
msgstr "لم تُعالج أي أنظمة ملفات"

