msgstr "попередження: неправильна ширина %td; буде використана %d"

#: src/od.c:2032
#, c-format
msgid "%td is too large"
msgstr "%td є надто великим"

#: src/paste.c:227
#, c-format
msgid "standard input is closed"
msgstr "стандартний ввід закритий"

#: src/paste.c:457
msgid ""
"Write lines consisting of the sequentially corresponding lines from\n"
"each FILE, separated by TABs, to standard output.\n"
"The newline of every line except the line from the last file\n"
"is replaced with a TAB.\n"
msgstr ""
"Вивести рядки, що складаються з послідовності відповідних рядків із\n"
"кожного ФАЙЛа, відокремлені табуляціями, до стандартного виведення.\n"
"Символ розриву рядків кожного рядка, окрім рядка з останнього файла,\n"
"буде замінено на табуляцію.\n"

#: src/paste.c:467
msgid ""
"  -d, --delimiters=LIST\n"
"         reuse characters from LIST instead of TABs;\n"
"         backslash escapes are supported\n"
msgstr ""
"  -d, --delimiters=СПИСОК\n"
"         використовувати замість табуляції знаки зі СПИСКУ,\n"
"         передбачено підтримку керівних послідовностей зі\n"
"         зворотною похилою рискою\n"

#: src/paste.c:472
msgid ""
"  -s, --serial\n"
"         paste one file at a time instead of in parallel; the newline of\n"
"         every line except the last line in each file is replaced with a "
"TAB\n"
msgstr ""
"  -s, --serial\n"
"         обробляти файли послідовно.\n"
"         Символ розриву рядків кожного рядка, окрім рядка з останнього "
"файла,\n"
"         буде замінено на табуляцію.\n"

#: src/paste.c:542
#, c-format
msgid "delimiter list ends with an unescaped backslash: %s"
msgstr "список роздільників завершується неекранованою зворотною рискою: %s"

#: src/pathchk.c:88
msgid ""
"Diagnose invalid or non-portable file names.\n"
"\n"
msgstr ""
"Виявляє некоректні та непереносні конструкції у назвах файлів.\n"
"\n"

#: src/pathchk.c:92
msgid "  -p     check for most POSIX systems\n"
msgstr "  -p     перевірка для більшості POSIX-систем\n"

#: src/pathchk.c:95
msgid "  -P     check for empty names and leading \"-\"\n"
msgstr "  -P     перевірка на порожні назви та початковий «-»\n"

#: src/pathchk.c:98
msgid ""
"      --portability\n"
"         check for all POSIX systems (equivalent to -p -P)\n"
msgstr ""
"      --portability   перевірка для усіх POSIX-систем (еквівалентно до -p "
"-P)\n"

#: src/pathchk.c:173
#, c-format
msgid "leading '-' in a component of file name %s"
msgstr "початковий '-' у компоненті назві файла %s"

#: src/pathchk.c:199
#, c-format
msgid "non-portable character %s in file name %s"
msgstr "непереносний знак %s у назві файла %s"

#: src/pathchk.c:274
#, c-format
msgid "empty file name"
msgstr "порожня назва файла"

#: src/pathchk.c:316
#, c-format
msgid "%s: unable to determine maximum file name length"
msgstr "%s: не вдалося визначити максимальну довжину назви файла"

#: src/pathchk.c:325
#, c-format
msgid "limit %td exceeded by length %td of file name %s"
msgstr "межу %td перевищено довжиною %td у назві файла %s"

#: src/pathchk.c:409
#, c-format
msgid "limit %td exceeded by length %td of file name component %s"
msgstr "перевищено обмеження %td довжиною %td у компоненті імені файла %s"

