msgstr "  -f ФАЙЛ     ФАЙЛ існує та є звичайним файлом\n"

#: src/test.c:761
msgid "  -g FILE     FILE exists and is set-group-ID\n"
msgstr "  -g ФАЙЛ     ФАЙЛ існує та має ознака set-group-ID\n"

#: src/test.c:764
msgid "  -G FILE     FILE exists and is owned by the effective group ID\n"
msgstr "  -G ФАЙЛ     ФАЙЛ існує та належить поточної ефективній групі\n"

#: src/test.c:767
msgid "  -h FILE     FILE exists and is a symbolic link (same as -L)\n"
msgstr "  -h ФАЙЛ     ФАЙЛ існує та є символьним посиланням (еквівалент -L)\n"

#: src/test.c:770
msgid "  -k FILE     FILE exists and has its sticky bit set\n"
msgstr "  -k ФАЙЛ     ФАЙЛ існує та має ознака sticky\n"

#: src/test.c:773
msgid "  -L FILE     FILE exists and is a symbolic link (same as -h)\n"
msgstr "  -L ФАЙЛ     ФАЙЛ існує та є символьним посиланням (еквівалент -h)\n"

#: src/test.c:776
msgid ""
"  -N FILE     FILE exists and has been modified since it was last read\n"
msgstr ""
"  -N FILE     ФАЙЛ існує, і його було змінено з часу останнього читання\n"

#: src/test.c:779
msgid "  -O FILE     FILE exists and is owned by the effective user ID\n"
msgstr ""
"  -O ФАЙЛ     ФАЙЛ існує та належить поточному ефективному користувачу\n"

#: src/test.c:782
msgid "  -p FILE     FILE exists and is a named pipe\n"
msgstr "  -p ФАЙЛ     ФАЙЛ існує та є іменованим каналом\n"

#: src/test.c:785
msgid "  -r FILE     FILE exists and the user has read access\n"
msgstr "  -r ФАЙЛ     ФАЙЛ існує і користувач має доступ до читання\n"

#: src/test.c:788
msgid "  -s FILE     FILE exists and has a size greater than zero\n"
msgstr "  -s ФАЙЛ     ФАЙЛ існує та має ненульовий розмір\n"

#: src/test.c:791
msgid "  -S FILE     FILE exists and is a socket\n"
msgstr "  -S ФАЙЛ     ФАЙЛ існує та є сокетом\n"

#: src/test.c:794
msgid "  -t FD       file descriptor FD is opened on a terminal\n"
msgstr "  -t [ДФ]     дескриптор файла ДФ відкритий на терміналі\n"

#: src/test.c:797
msgid "  -u FILE     FILE exists and its set-user-ID bit is set\n"
msgstr "  -u ФАЙЛ     ФАЙЛ існує та має ознака set-user-ID\n"

#: src/test.c:800
msgid "  -w FILE     FILE exists and the user has write access\n"
msgstr "  -w ФАЙЛ     ФАЙЛ існує і користувач має право на запис\n"

#: src/test.c:803
msgid "  -x FILE     FILE exists and the user has execute (or search) access\n"
msgstr ""
"  -x ФАЙЛ     ФАЙЛ існує і користувач має право на виконання (або пошук)\n"

#: src/test.c:806
msgid ""
"\n"
"Except for -h and -L, all FILE-related tests dereference symbolic links.\n"
"Beware that parentheses need to be escaped (e.g., by backslashes) for "
"shells.\n"
"INTEGER may also be -l STRING, which evaluates to the length of STRING.\n"
msgstr ""
"\n"
"Всі тести, що відносяться до ФАЙЛА, крім -h та -L розіменовують\n"
"символьні посилання.  Пам'ятайте, що ви повинні скасувати спеціальне\n"
"значення дужок для командного інтерпретатора (наприклад, за допомогою\n"
"знаку '\\').  ЦІЛЕ може також бути вказане як \"-l РЯДОК\", при цьому\n"
"воно приймає значення довжини РЯДКА.\n"

#: src/test.c:812
msgid ""
"\n"
"Binary -a and -o are ambiguous.  Use 'test EXPR1 && test EXPR2'\n"
"or 'test EXPR1 || test EXPR2' instead.\n"
msgstr ""
"\n"
"Двійкові -a і -o є неоднозначними. Слід користуватися\n"
"«test ВИРАЗ1 && test ВИРАЗ2» або «test ВИРАЗ1 || test ВИРАЗ2».\n"

#: src/test.c:817
msgid ""
"\n"
"'[' honors --help and --version, but 'test' treats them as STRINGs.\n"
msgstr ""
"\n"
"«[» бере до уваги --help і --version, але «test» обробляє їх як РЯДКИ.\n"

#: src/test.c:821
msgid "test and/or ["
msgstr "test та/або ["

