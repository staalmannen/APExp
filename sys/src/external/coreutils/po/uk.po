#: src/pinky.c:487
msgid "  -l     produce long format output for the specified USERs\n"
msgstr "  -l      використовувати докладний формат виводу\n"

#: src/pinky.c:490
msgid "  -b     omit the user's home directory and shell in long format\n"
msgstr ""
"  -b     опустити у докладному форматі початковий каталог та\n"
"         оболонку цього користувача\n"

#: src/pinky.c:493
msgid "  -h     omit the user's project file in long format\n"
msgstr ""
"  -h     опустити у докладному форматі файл проекту цього\n"
"         користувача\n"

#: src/pinky.c:496
msgid "  -p     omit the user's plan file in long format\n"
msgstr ""
"  -p    опустити у докладному форматі файл плану цього\n"
"        користувача\n"

#: src/pinky.c:499
msgid "  -s     do short format output, this is the default\n"
msgstr "  -s     короткий формат виводу, типово використовується\n"

#: src/pinky.c:502
msgid "  -f     omit the line of column headings in short format\n"
msgstr "  -f     опустити у короткому форматі рядок з заголовками колонок\n"

#: src/pinky.c:505
msgid "  -w     omit the user's full name in short format\n"
msgstr "  -w     опустити у короткому форматі повне ім'я користувача\n"

#: src/pinky.c:508
msgid "  -i     omit the user's full name and remote host in short format\n"
msgstr ""
"  -i     опустити у короткому форматі повне ім'я користувача та\n"
"         назву віддаленої машини\n"

#: src/pinky.c:511
msgid ""
"  -q     omit the user's full name, remote host and idle time in short "
"format\n"
msgstr ""
"  -q      опустити у короткому форматі повне ім'я користувача,\n"
"          назву віддаленої машини та час неактивності\n"

#: src/pinky.c:514
msgid ""
"      --lookup\n"
"         attempt to canonicalize hostnames via DNS\n"
msgstr ""
"      --lookup\n"
"         намагатись канонізувати назви вузлів через DNS\n"

#: src/pinky.c:520
#, c-format
msgid ""
"\n"
"A lightweight 'finger' program;  print user information.\n"
"The utmp file will be %s.\n"
msgstr ""
"\n"
"Спрощена програма 'finger';  виводить відомості про користувача.\n"
"У складі файла utmp буде використовуватися %s.\n"

#: src/pinky.c:607
#, c-format
msgid "no username specified; at least one must be specified when using -l"
msgstr ""
"не вказано ім'я користувача; при використанні параметра -l треба вказати "
"хоча б одне"

