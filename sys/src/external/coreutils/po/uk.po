#: src/who.c:630
#, c-format
msgid "Usage: %s [OPTION]... [ FILE | ARG1 ARG2 ]\n"
msgstr "Використання: %s [ПАРАМЕТР]... [ ФАЙЛ | АРГ1 АРГ2]\n"

#: src/who.c:631
msgid "Print information about users who are currently logged in.\n"
msgstr "Вивести дані щодо користувачів, які працюють у системі.\n"

#: src/who.c:637
msgid "  -a, --all         same as -b -d --login -p -r -t -T -u\n"
msgstr "  -a, --all         еквівалент -b -d --login -p -r -t -T -u\n"

#: src/who.c:640
msgid "  -b, --boot        time of last system boot\n"
msgstr "  -b, --boot        час останнього звантаження системи\n"

#: src/who.c:643
msgid "  -d, --dead        print dead processes\n"
msgstr "  -d, --dead        виводити мертві процеси\n"

#: src/who.c:646
msgid "  -H, --heading     print line of column headings\n"
msgstr "  -H, --heading     виводити рядок з заголовками стовпчиків\n"

#: src/who.c:649
msgid "  -l, --login       print system login processes\n"
msgstr "  -l, --login       виводити процеси входу у систему\n"

#: src/who.c:652
msgid "      --lookup      attempt to canonicalize hostnames via DNS\n"
msgstr "      --lookup      намагатись канонізувати назви вузлів через DNS\n"

#: src/who.c:655
msgid ""
"  -m                only hostname and user associated with standard input\n"
msgstr ""
"  -m                лише назва вузлі та користувач, пов'язані з\n"
"                    стандартним вводом\n"

#: src/who.c:658
msgid "  -p, --process     print active processes spawned by init\n"
msgstr "  -p, --process     виводити активні процеси, які породжені init\n"

#: src/who.c:661
msgid "  -q, --count       all login names and number of users logged on\n"
msgstr ""
"  -q, --count       всі назви та кількість користувачів, які увійшли до "
"системи\n"

#: src/who.c:664
msgid "  -r, --runlevel    print current runlevel\n"
msgstr "  -r, --runlevel    виводити поточний рівень виконання\n"

#: src/who.c:667
msgid "  -s, --short       print only name, line, and time (default)\n"
msgstr ""
"  -s, --short       виводити лише назву, лінію та час (приймається типово)\n"

#: src/who.c:670
msgid "  -t, --time        print last system clock change\n"
msgstr "  -t, --time        виводити останню зміна системного часу\n"

#: src/who.c:673
msgid "  -T, -w, --mesg    add user's message status as +, - or ?\n"
msgstr ""
"  -T, -w, --mesg    додавати статус отримання повідомлень як  +, - або ?\n"

#: src/who.c:676
msgid "  -u, --users       list users logged in, including idle time\n"
msgstr ""
"  -u, --users       вивести список користувачів, які увійшли до системи,\n"
"                    включно із часом бездіяльності\n"

#: src/who.c:679
msgid "      --message     same as -T\n"
msgstr "      --message     еквівалент -T\n"

#: src/who.c:682
msgid "      --writable    same as -T\n"
msgstr "      --writable    еквівалент -T\n"

#: src/who.c:687
#, c-format
msgid ""
"\n"
"If FILE is not specified, use %s.  %s as FILE is common.\n"
"If ARG1 ARG2 given, -m presumed: 'am i' or 'mom likes' are usual.\n"
msgstr ""
"\n"
"Якщо ФАЙЛ не вказаний, використовується %s. Часто як ФАЙЛ вказують %s.\n"
"Якщо вказані АРГ1 та АРГ2, вважається використання -m: наприклад 'am i'\n"
"та 'mom likes'.\n"

#: src/whoami.c:43
msgid ""
"Print the user name associated with the current effective user ID.\n"
"Same as id -un.\n"
"\n"
msgstr ""
"Вивести ім'я користувача, що відповідає поточному ефективному id\n"
"користувача.  Аналогічно виклику id -un.\n"
"\n"

#: src/yes.c:45
#, c-format
msgid ""
"Usage: %s [STRING]...\n"
"  or:  %s OPTION\n"
msgstr ""
"Використання: %s [РЯДОК]...\n"
"       або:    %s КЛЮЧ\n"

#: src/yes.c:51
msgid ""
"Repeatedly output a line with all specified STRING(s), or 'y'.\n"
"\n"
msgstr ""
"Безперервно виводити вказаний РЯДОК (РЯДКИ) або, якщо РЯДОК не вказано, "
"'y'.\n"
"\n"

