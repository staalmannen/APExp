msgstr "Використання: %s [ПАРАМЕТР]... [ФАЙЛ]\n"

#: src/basenc.c:108
msgid "basenc encode or decode FILE, or standard input, to standard output.\n"
msgstr ""
"Кодування чи декодування файла чи стандартного потоку вводу у форматі\n"
"baseenc, і запис у стандартний потік виводу.\n"

#: src/basenc.c:112
#, c-format
msgid "Base%d encode or decode FILE, or standard input, to standard output.\n"
msgstr ""
"Кодування чи декодування файла чи стандартного потоку вводу у форматі\n"
"Base%d, і запис у стандартний потік виводу.\n"

#: src/basenc.c:120
msgid ""
"      --base64\n"
"         same as 'base64' program (RFC4648 section 4)\n"
msgstr ""
"      --base64\n"
"          те саме, що і програма base64 (RFC4648, розділ 4)\n"

#: src/basenc.c:124
msgid ""
"      --base64url\n"
"         file- and url-safe base64 (RFC4648 section 5)\n"
msgstr ""
"      --base64url\n"
"       безпечний варіант base64 для файлів і адрес (RFC4648, розділ 5)\n"

#: src/basenc.c:128
msgid ""
"      --base58\n"
"         visually unambiguous base58 encoding\n"
msgstr ""
"      --base58\n"
"          візуально однозначне кодування base58\n"

#: src/basenc.c:132
msgid ""
"      --base32\n"
"         same as 'base32' program (RFC4648 section 6)\n"
msgstr ""
"      --base32\n"
"         те саме, що і програма base32 (RFC4648, розділ 6)\n"

#: src/basenc.c:136
msgid ""
"      --base32hex\n"
"         extended hex alphabet base32 (RFC4648 section 7)\n"
msgstr ""
"      --base32hex\n"
"         розширена шістнадцяткова абетна для base32 (RFC4648, розділ 7)\n"

#: src/basenc.c:140
msgid ""
"      --base16\n"
"         hex encoding (RFC4648 section 8)\n"
msgstr ""
"      --base16\n"
"         шістнадцяткове кодування (RFC4648, розділ 8)\n"

#: src/basenc.c:144
msgid ""
"      --base2msbf\n"
"         bit string with most significant bit (msb) first\n"
msgstr ""
"      --base2msbf\n"
"         рядок бітів, у якому першим є найбільший біт (msb)\n"

#: src/basenc.c:148
msgid ""
"      --base2lsbf\n"
"         bit string with least significant bit (lsb) first\n"
msgstr ""
"      --base2lsbf\n"
"         рядок бітів, у якому останнім є найбільший біт (lsb)\n"

#: src/basenc.c:153
msgid ""
"  -d, --decode\n"
"         decode data\n"
msgstr "  -d, --decode          декодувати дані\n"

#: src/basenc.c:157
msgid ""
"  -i, --ignore-garbage\n"
"         when decoding, ignore non-alphabet characters\n"
msgstr ""
"  -i, --ignore-garbage  під час декодування пропускати символи поза абеткою\n"

#: src/basenc.c:161
msgid ""
"  -w, --wrap=COLS\n"
"         wrap encoded lines after COLS character (default 76).\n"
"         Use 0 to disable line wrapping\n"
msgstr ""
"  -w, --wrap=СТОВПЧИК\n"
"         переносити кодовані рядки після символу СТОВПЧИК (типово 76).\n"
"         0 вимикає перенесення рядків.\n"

#: src/basenc.c:167
msgid ""
"      --z85\n"
"         ascii85-like encoding (ZeroMQ spec:32/Z85);\n"
"         when encoding, input length must be a multiple of 4;\n"
"         when decoding, input length must be a multiple of 5\n"
msgstr ""
"      --z85\n"
"         ascii85-подібне кодування (ZeroMQ spec:32/Z85);\n"
"         при кодуванні довжина вхідних даних має бути кратною до 4;\n"
"         при декодуванні довжина вхідних даних має бути кратною до 5\n"

#: src/basenc.c:177
msgid ""
"\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"При декодуванні ввід може містити і символи розриву рядків, окрім байтів\n"
"формальної абетки. Вкажіть параметр --ignore-garbage, щоб спробувати\n"
"ігнорувати неабеткові знаки у закодованому потоці.\n"

#: src/basenc.c:184
#, c-format
msgid ""
"\n"
"The data are encoded as described for the %s alphabet in RFC 4648.\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal %s alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"Дані закодовані символами з алфавіту %s, відповідно до RFC 4648. При\n"
"декодуванні ввід може містити також переведення рядків окрім байтів\n"
"формального алфавіту %s. Вкажіть параметр --ignore-garbage, щоб\n"
"спробувати ігнорувати неалфавітні знаки в закодованому потоці.\n"

#: src/basenc.c:879
#, c-format
msgid "invalid input (length must be multiple of 4 characters)"
msgstr "некоректні вхідні дані (довжина має бути кратною до 4 символів)"

