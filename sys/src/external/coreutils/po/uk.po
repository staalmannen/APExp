#: src/head.c:112
#, c-format
msgid ""
"Print the first %d lines of each FILE to standard output.\n"
"With more than one FILE, precede each with a header giving the file name.\n"
msgstr ""
"Виводить перші %d рядків кожного з ФАЙЛІВ до стандартного виведення.\n"
"Якщо задано декілька ФАЙЛІВ, спочатку виводить перед даними заголовок із "
"назвою файла.\n"

#: src/head.c:120
msgid ""
"  -c, --bytes=[-]NUM\n"
"         print the first NUM bytes of each file;\n"
"         with the leading '-', print all but the last NUM bytes of each "
"file\n"
msgstr ""
"  -c, --bytes=[-]K\n"
"         вивести перші K байтів кожного файла;\n"
"         якщо перед K стоїть «-», вивести всі, крім K\n"
"         останніх байтів кожного файла\n"

#: src/head.c:125
#, c-format
msgid ""
"  -n, --lines=[-]NUM\n"
"         print the first NUM lines instead of the first %d;\n"
"         with the leading '-', print all but the last NUM lines of each "
"file\n"
msgstr ""
"  -n, --lines=[-]K\n"
"         вивести перші K рядків кожного файла, а не %d;\n"
"         якщо перед K стоїть «-», вивести всі, крім K\n"
"         останніх рядків кожного файла\n"

#: src/head.c:130
msgid ""
"  -q, --quiet, --silent\n"
"         never print headers giving file names\n"
msgstr ""
"  -q, --quiet, --silent\n"
"         не виводити заголовки з назвами файлів\n"

#: src/head.c:134
msgid ""
"  -v, --verbose\n"
"         always print headers giving file names\n"
msgstr "  -v, --verbose           завжди виводити заголовки з назвами файлів\n"

#: src/head.c:144
