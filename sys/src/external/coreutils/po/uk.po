"виведення.\n"

#: src/fold.c:87
msgid ""
"  -b, --bytes\n"
"         count bytes rather than columns\n"
msgstr "  -b, --bytes         прочитати байти, а не стовпчики\n"

#: src/fold.c:91
msgid ""
"  -c, --characters\n"
"         count characters rather than columns\n"
msgstr "  -c, --characters    рахувати символи, а не стовпчики\n"

#: src/fold.c:95
msgid ""
"  -s, --spaces\n"
"         break after blanks, or in words greater than WIDTH\n"
msgstr ""
"  -s, --spaces\n"
"         розбивати на пробілах або словах, довжина яких перевищує ДОВЖИНУ\n"

#: src/fold.c:99
msgid ""
