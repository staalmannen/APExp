"  FILE1 -ef FILE2   FILE1 and FILE2 have the same device and inode numbers\n"
msgstr ""
"  ФАЙЛ1 -ef ФАЙЛ2   ФАЙЛ1 та ФАЙЛ2 мають одинакові пристрої та номери inode\n"

#: src/test.c:737
msgid "  FILE1 -nt FILE2   FILE1 is newer (modification date) than FILE2\n"
msgstr "  ФАЙЛ1 -nt ФАЙЛ2   ФАЙЛ1 змінювався пізніше ніж ФАЙЛ2\n"

#: src/test.c:740
msgid "  FILE1 -ot FILE2   FILE1 is older than FILE2\n"
msgstr "  ФАЙЛ1 -ot ФАЙЛ2   ФАЙЛ1 створений пізніше ніж ФАЙЛ2\n"

#: src/test.c:746
msgid "  -b FILE     FILE exists and is block special\n"
msgstr "  -b ФАЙЛ     ФАЙЛ існує та є спеціальним з блоковим доступом\n"

#: src/test.c:749
msgid "  -c FILE     FILE exists and is character special\n"
msgstr "  -c ФАЙЛ     ФАЙЛ існує та є спеціальним з символьним доступом\n"

#: src/test.c:752
msgid "  -d FILE     FILE exists and is a directory\n"
msgstr "  -d ФАЙЛ     ФАЙЛ існує та є каталогом\n"

