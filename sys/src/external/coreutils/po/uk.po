#: src/cksum.c:501
#, c-format
msgid "Print or check %s checksums.\n"
msgstr "Вивести або перевірити контрольні суми %s.\n"

#: src/cksum.c:504 src/cksum.c:519
msgid "Legacy interface to the cksum utility.\n"
msgstr "Застарілий інтерфейс до допоміжної програми cksum.\n"

#: src/cksum.c:509
msgid ""
"Print or verify checksums.\n"
"By default use the 32 bit CRC algorithm.\n"
msgstr ""
"Вивести або перевірити контрольні суми.\n"
"Типово, використовується 32-бітовий алгоритм CRC.\n"

#: src/cksum.c:514
#, c-format
msgid "Print or check %s (%d-bit) checksums.\n"
msgstr "Вивести або перевірити %s (%d-бітові) контрольні суми.\n"

#: src/cksum.c:526
msgid ""
"  -r\n"
"         use BSD sum algorithm (the default), use 1K blocks\n"
msgstr ""
"  -r              використовувати метод обчислення контрольних сум BSD "
"(типовий),\n"
"                  розмір блоку 1 кБ\n"

#: src/cksum.c:530
msgid ""
"  -s, --sysv\n"
"         use System V sum algorithm, use 512 bytes blocks\n"
msgstr ""
"  -s, --sysv      використовувати метод обчислення контрольних сум System "
"V,\n"
"                  розмір блоку 512 байт\n"

#: src/cksum.c:540
msgid ""
"  -a, --algorithm=TYPE\n"
"         select the digest type to use.  See DIGEST below\n"
msgstr ""
"  -a, --algorithm=ТИП\n"
"         вибрати тип використаної контрольної суми. Див. СУМА нижче\n"

#: src/cksum.c:545
msgid ""
"      --base64\n"
"         emit base64-encoded digests, not hexadecimal\n"
msgstr ""
"      --base64          видавати контрольні суми у кодуванні base64, не "
"шістнадцяткові\n"

#: src/cksum.c:556
msgid ""
"  -b, --binary\n"
"         read in binary mode (default unless reading tty stdin)\n"
msgstr ""
"  -b, --binary\n"
"         читати у двійковому режимі (типово, якщо\n"
"         читається не термінальне введення)\n"

#: src/cksum.c:561
msgid ""
"  -b, --binary\n"
"         read in binary mode\n"
msgstr ""
"  -b, --binary\n"
"         читати у двійковому режимі\n"

#: src/cksum.c:568
msgid ""
"  -c, --check\n"
"         read checksums from the FILEs and check them\n"
msgstr ""
"  -c, --check\n"
"         прочитати контрольні суми з ФАЙЛІВ та порівняти їх\n"

#: src/cksum.c:576
msgid ""
"  -l, --length=BITS\n"
"         digest length in bits; must not exceed the max size\n"
"         and must be a multiple of 8 for blake2b;\n"
"         must be 224, 256, 384, or 512 for sha2 or sha3\n"
msgstr ""
"  -l, --length=БІТИ\n"
"         довжина контрольної суми у бітах; має не перевищувати максимуму\n"
"         і має бути кратною до 8 для blake2b;\n"
"         має бути 224, 256, 384 або 512 для sha2 або sha3\n"

#: src/cksum.c:585
msgid ""
"      --raw\n"
"         emit a raw binary digest, not hexadecimal\n"
msgstr ""
"      --raw\n"
"         вивести просту двійкову контрольну суму, не шістнадцяткову\n"

#: src/cksum.c:590 src/cksum.c:605
msgid ""
"      --tag\n"
"         create a BSD-style checksum\n"
msgstr ""
"      --tag\n"
"         створити контрольну суму у форматі BSD\n"

#: src/cksum.c:595
msgid ""
"      --tag\n"
"         create a BSD-style checksum (the default)\n"
msgstr ""
"      --tag\n"
"         створити контрольну суму у форматі BSD (типову)\n"

#: src/cksum.c:600
msgid ""
"      --untagged\n"
"         create a reversed style checksum, without digest type\n"
msgstr ""
"      --untagged\n"
"         створити контрольну суму у оберненому стилі без типу суми\n"

#: src/cksum.c:615
msgid ""
"  -t, --text\n"
"         read in text mode (default if reading tty stdin)\n"
msgstr ""
"  -t, --text\n"
"         читати у текстовому режимі (типово, якщо\n"
"         читається термінальний ввід)\n"

#: src/cksum.c:620
msgid ""
"  -t, --text\n"
"         read in text mode (default)\n"
msgstr ""
"  -t, --text\n"
"         читати у текстовому режимі (типово)\n"

#: src/cksum.c:627
msgid ""
"  -z, --zero\n"
"         end each output line with NUL, not newline,\n"
"         and disable file name escaping\n"
msgstr ""
"  -z, --zero\n"
"         завершувати кожен рядок нуль-байтом замість розриву рядка\n"
"         і вимкнути екранування назв файлів\n"

#: src/cksum.c:632
msgid ""
"\n"
"The following five options are useful only when verifying checksums:\n"
msgstr ""
"\n"
"П’ять наведених нижче параметрів використовуються лише під час перевірки "
"контрольних сум:\n"

#: src/cksum.c:636
msgid ""
"      --ignore-missing\n"
"         don't fail or report status for missing files\n"
msgstr ""
"      --ignore-missing  не завершувати роботу і не повідомляти про стан для "
"файлів, які\n"
"                         не виявлено\n"

#: src/cksum.c:640
msgid ""
"      --quiet\n"
"         don't print OK for each successfully verified file\n"
msgstr ""
"      --quiet           не виводити підтвердження для кожного успішно "
"перевіреного\n"
"                          файла\n"

#: src/cksum.c:644
msgid ""
"      --status\n"
"         don't output anything, status code shows success\n"
msgstr ""
"      --status          не виконувати вивід, код завершення показує\n"
"                          успіх перевірки\n"

#: src/cksum.c:648
msgid ""
"      --strict\n"
"         exit non-zero for improperly formatted checksum lines\n"
msgstr ""
"      --strict          виводити ненульовий код завершення для рядків "
"контрольних\n"
"                          сум з помилками у форматуванні\n"

#: src/cksum.c:652
msgid ""
"  -w, --warn\n"
"         warn about improperly formatted checksum lines\n"
msgstr ""
"  -w, --warn\n"
"         попереджувати про неправильно сформовані рядки у\n"
"         списку контрольних сум\n"

#: src/cksum.c:659
msgid ""
"      --debug\n"
"         indicate which implementation used\n"
msgstr ""
"      --debug\n"
"         вказати, яку реалізацію використано\n"

#: src/cksum.c:668
msgid ""
"\n"
"DIGEST determines the digest algorithm and default output format:\n"
"  sysv      (equivalent to sum -s)\n"
"  bsd       (equivalent to sum -r)\n"
"  crc       (equivalent to cksum)\n"
"  crc32b    (only available through cksum)\n"
"  md5       (equivalent to md5sum)\n"
"  sha1      (equivalent to sha1sum)\n"
"  sha2      (equivalent to sha{224,256,384,512}sum)\n"
"  sha3      (only available through cksum)\n"
"  blake2b   (equivalent to b2sum)\n"
"  sm3       (only available through cksum)\n"
"\n"
msgstr ""
"\n"
"СУМА визначає алгоритм обчислення контрольної суми і типовий формат "
"виведення:\n"
"  sysv      (те саме, що і sum -s)\n"
"  bsd       (те саме, що і sum -r)\n"
"  crc       (те саме, що і cksum)\n"
"  crc32b    (доступне лише через cksum)\n"
"  md5       (те саме, що і md5sum)\n"
"  sha1      (те саме, що і sha1sum)\n"
"  sha2      (еквівалент sha{224,256,384,512}sum)\n"
"  sha3      (доступне лише через cksum)\n"
"  blake2b   (те саме, що і b2sum)\n"
"  sm3       (доступне лише через cksum)\n"
"\n"

#: src/cksum.c:684
#, c-format
msgid ""
"\n"
"The sums are computed as described in %s.\n"
msgstr ""
"\n"
"Опис обчислення сум наведено у %s.\n"

#: src/cksum.c:687
msgid ""
"When checking, the input should be a former output of this program.\n"
"The default mode is to print a line with: checksum, a space,\n"
"a character indicating input mode ('*' for binary, ' ' for text\n"
"or where binary is insignificant), and name for each FILE.\n"
"\n"
"There is no difference between binary mode and text mode on GNU systems.\n"
msgstr ""
"Вхідними даними при перевірці мають бути отримані раніше дані виводу\n"
"цієї програми.\n"
"Типово виводить рядок з контрольною сумою, пробіл, символ, що вказує на\n"
"тип файла («*» для двійкових, « » для текстових або тих, де двійкові\n"
"дані є несуттєвими) та назву кожного ФАЙЛа.\n"
"\n"
"У системах GNU немає відмінностей між двійковим і\n"
"текстовими режимами.\n"

#: src/cksum.c:697
msgid ""
"When checking, the input should be a former output of this program,\n"
"or equivalent standalone program.\n"
msgstr ""
"При перевірці вхідні дані мають бути попередніми вихідними даними\n"
"цієї або еквівалентної окремої програм.\n"

