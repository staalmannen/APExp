#: src/df.c:1499
msgid ""
"Show information about the file system on which each FILE resides,\n"
"or all file systems by default.\n"
msgstr ""
"Показати інформацію про файлову систему, на якій розташований кожен\n"
"з ФАЙЛІВ, або, типово, про усі файлові системи.\n"

#. TRANSLATORS: The thousands and decimal separators are best
#. adjusted to an appropriate default for your locale.
#: src/df.c:1508
msgid ""
"  -a, --all\n"
"         include pseudo, duplicate, inaccessible file systems\n"
msgstr ""
"  -a, --all             включати несправжні, дубльовані, недоступні файлові "
"системи\n"

#: src/df.c:1512
msgid ""
"  -B, --block-size=SIZE\n"
"         scale sizes by SIZE before printing them; see SIZE format below;\n"
"         E.g., '-BM' prints sizes in units of 1,048,576 bytes\n"
msgstr ""
"  -B, --block-size=РОЗМІР\n"
"         використовувати блоки вказаного РОЗМІРУ. Приклад:\n"
"         «-BM» виводить розміри у одиницях у 1.048.576 байтів.\n"
"         Формат РОЗМІР описано нижче.\n"

#: src/df.c:1517
msgid ""
"  -h, --human-readable\n"
"         print sizes in powers of 1024 (e.g., 1023M)\n"
msgstr ""
"  -h, --human-readable  виводити розміри у зручному для людини вигляді\n"
"                         (наприклад, 1023M)\n"

#: src/df.c:1521
msgid ""
"  -H, --si\n"
"         print sizes in powers of 1000 (e.g., 1.1G)\n"
msgstr ""
"  -H, --si              те саме, але використовувати степені 1000 "
"(наприклад, 1.1G)\n"

#: src/df.c:1525
msgid ""
"  -i, --inodes\n"
"         list inode information instead of block usage\n"
msgstr ""
"  -i, --inodes          вивести інформацію про індексні дескриптори, а не "
"про\n"
"                        використання блоків\n"

#: src/df.c:1529 src/du.c:344
msgid ""
"  -k\n"
"         like --block-size=1K\n"
msgstr ""
"  -k\n"
"         аналог --block-size=1K\n"

#: src/df.c:1533
msgid ""
"  -l, --local\n"
"         limit listing to local file systems\n"
msgstr "  -l, --local           перерахувати лише локальні файлові системи\n"

#: src/df.c:1537
msgid ""
"      --no-sync\n"
"         do not invoke sync before getting usage info (default)\n"
msgstr ""
"      --no-sync         не викликати sync перед отриманням інформації про\n"
"                        використання блоків (типово)\n"

#: src/df.c:1541
msgid ""
"      --output[=FIELD_LIST]\n"
"         use the output format defined by FIELD_LIST,\n"
"         or print all fields if FIELD_LIST is omitted\n"
msgstr ""
"      --output[=СПИСОК_ПОЛІВ]\n"
"         використовувати формат виведення, визначений СПИСКОМ_ПОЛІВ,\n"
"         або вивести всі поля, якщо СПИСОК_ПОЛІВ не вказано.\n"

#: src/df.c:1546
msgid ""
"  -P, --portability\n"
"         use the POSIX output format\n"
msgstr ""
"  -P, --portability\n"
"         скористатися форматом виведення POSIX\n"

#: src/df.c:1550
msgid ""
"      --sync\n"
"         invoke sync before getting usage info\n"
msgstr ""
"      --sync\n"
"         виконувати синхронізацію перед отриманням інформації про "
"використання\n"

#: src/df.c:1554
msgid ""
"      --total\n"
"         elide all entries insignificant to available space,\n"
"         and produce a grand total\n"
msgstr ""
"      --total\n"
"         пропустити усі записи, які не пов’язано із доступним місцем,\n"
"         і вивести загальні підсумки\n"

#: src/df.c:1559
msgid ""
"  -t, --type=TYPE\n"
"         limit listing to file systems of type TYPE\n"
msgstr ""
"  -t, --type=ТИП        перерахувати лише файлові системи вказаного ТИПУ\n"

#: src/df.c:1563
msgid ""
"  -T, --print-type\n"
"         print file system type\n"
msgstr "  -T, --print-type      виводити тип файлової системи\n"

#: src/df.c:1567
msgid ""
"  -x, --exclude-type=TYPE\n"
"         limit listing to file systems not of type TYPE\n"
msgstr "  -x, --exclude-type=ТИП  виключати файлові системи вказаного ТИПУ\n"

#: src/df.c:1571
msgid ""
"  -v\n"
"         (ignored)\n"
msgstr "  -v                    (ігнорується)\n"

#: src/df.c:1579
msgid ""
"\n"
"FIELD_LIST is a comma-separated list of columns to be included.  Valid\n"
"field names are: 'source', 'fstype', 'itotal', 'iused', 'iavail', 'ipcent',\n"
"'size', 'used', 'avail', 'pcent', 'file' and 'target' (see info page).\n"
msgstr ""
"\n"
"СПИСОК_ПОЛІВ — відокремлений комами список стовпчиків, які слід включити.\n"
"Можливі назви стовпчиків: 'source', 'fstype', 'itotal', 'iused', 'iavail', "
"'ipcent',\n"
"'size', 'used', 'avail', 'pcent', 'file'  і 'target' (див. сторінку info).\n"

#: src/df.c:1605
#, c-format
msgid "options %s and %s are mutually exclusive"
msgstr "параметри %s і %s не можна використовувати одночасно"

#: src/df.c:1755
#, c-format
msgid "file system type %s both selected and excluded"
msgstr "файлова система типа %s і вибрана, і виключена"

#: src/df.c:1806
msgid "Warning: "
msgstr "Попередження: "

#: src/df.c:1808 src/stat.c:960
msgid "cannot read table of mounted file systems"
msgstr "%помилка при читані змонтованих файлових систем"

#: src/df.c:1843
#, c-format
msgid "no file systems processed"
msgstr "не вказана жодна файлова система"

#. This is a proper name. See the gettext manual, section Names.
#: src/dircolors.c:35
msgid "H. Peter Anvin"
msgstr "H. Peter Anvin"

#: src/dircolors.c:103
msgid ""
"Output commands to set the LS_COLORS environment variable.\n"
"\n"
"Determine format of output:\n"
msgstr ""
"Видає команди для встановлення змінної середовища LS_COLORS.\n"
"\n"
"Визначення формат виводу:\n"

#: src/dircolors.c:108
msgid ""
"  -b, --sh, --bourne-shell\n"
"         output Bourne shell code to set LS_COLORS\n"
msgstr ""
"  -b, --sh, --bourne-shell\n"
"         вивести код для встановлення LS_COLORS у\n"
"         Bourne shell\n"

#: src/dircolors.c:112
msgid ""
"  -c, --csh, --c-shell\n"
"         output C shell code to set LS_COLORS\n"
msgstr ""
"  -c, --csh, --c-shell\n"
"         вивести код для встановлення LS_COLORS у C shell\n"

#: src/dircolors.c:116
msgid ""
"  -p, --print-database\n"
"         output defaults\n"
msgstr "  -p, --print-database        вивести типові параметри\n"

#: src/dircolors.c:120
msgid ""
"      --print-ls-colors\n"
"         output fully escaped colors for display\n"
msgstr ""
"      --print-ls-colors       вивести повністю екрановані кольори для "
"показу\n"

#: src/dircolors.c:126
msgid ""
"\n"
"If FILE is specified, read it to determine which colors to use for which\n"
"file types and extensions.  Otherwise, a precompiled database is used.\n"
"For details on the format of these files, run 'dircolors --print-database'.\n"
msgstr ""
"\n"
"Якщо вказаний FILE, то читати його щоб дізнатись які кольори яким\n"
"розширенням призначені. Інакше використовувати типову базу даних. Для\n"
"докладнішого опису формату FILE запустите dircolors --print-database.\n"

#: src/dircolors.c:338
#, c-format
msgid "%s:%td: invalid line;  missing second token"
msgstr "%s:%td: некоректний рядок; пропущена друга лексема"

#: src/dircolors.c:393
#, c-format
msgid "%s:%td: unrecognized keyword %s"
msgstr "%s:%td ключове слово %s не розпізнано"

#: src/dircolors.c:394
msgid "<internal>"
msgstr "<внутрішній>"

#: src/dircolors.c:479
#, c-format
msgid ""
"the options to output non shell syntax,\n"
"and to select a shell syntax are mutually exclusive"
msgstr ""
"параметри для виводу синтаксичних конструкцій, які не\n"
"є конструкціями оболонки і вибору синтаксису оболонки є взаємно виключними"

#: src/dircolors.c:487
#, c-format
msgid "options --print-database and --print-ls-colors are mutually exclusive"
msgstr ""
"параметри --print-database і --print-ls-colors не можна використовувати "
"одночасно"

#: src/dircolors.c:498
msgid "file operands cannot be combined with --print-database (-p)"
msgstr ""
"Операнди-файли не можна одночасно використовувати з --print-database (-p)"

#: src/dircolors.c:520
#, c-format
msgid "no SHELL environment variable, and no shell type option given"
msgstr ""
"або змінна середовища SHELL відсутня, або не вказаний тип інтерпретатору"

#: src/dirname.c:49
#, c-format
msgid "Usage: %s [OPTION] NAME...\n"
msgstr "Використання: %s [ПАРАМЕТР] НАЗВА...\n"

#: src/dirname.c:53
msgid ""
"Output each NAME with its last non-slash component and trailing slashes\n"
"removed; if NAME contains no /'s, output '.' (meaning the current "
"directory).\n"
"\n"
msgstr ""
"Виводить всі НАЗВИ, вилучаючи компоненту праворуч від останньої похилої "
"риски;\n"
"якщо НАЗВА не містить похилої риски, виводить «.» (тобто поточний каталог).\n"
"\n"

#: src/dirname.c:64
#, c-format
msgid ""
"\n"
"Examples:\n"
"  %s /usr/bin/          -> \"/usr\"\n"
"  %s dir1/str dir2/str  -> \"dir1\" followed by \"dir2\"\n"
"  %s stdio.h            -> \".\"\n"
msgstr ""
"\n"
"Приклади:\n"
"  %s /usr/bin/          -> «/usr»\n"
"  %s dir1/str dir2/str  -> «dir1», потім «dir2»\n"
"  %s stdio.h            -> «.»\n"

#: src/du.c:279 src/sort.c:421 src/wc.c:189
#, c-format
msgid ""
"Usage: %s [OPTION]... [FILE]...\n"
"  or:  %s [OPTION]... --files0-from=F\n"
msgstr ""
"Використання: %s [ПАРАМЕТР]... [ФАЙЛ]...\n"
"       або:    %s [ПАРАМЕТР]... --files0-from=Ф\n"

#: src/du.c:283
msgid ""
"Summarize device usage of the set of FILEs, recursively for directories.\n"
msgstr ""
"Сумарне використання простору на пристрої набору ФАЙЛів, рекурсивно для "
"каталогів.\n"

#: src/du.c:289 src/env.c:130 src/printenv.c:69
msgid ""
"  -0, --null\n"
"         end each output line with NUL, not newline\n"
msgstr ""
"  -0, --null\n"
"         завершувати кожен рядок виведених даних нуль-байтом замість "
"символу\n"
"         нового рядка\n"

#: src/du.c:293
msgid ""
"  -a, --all\n"
"         write counts for all files, not just directories\n"
msgstr ""
"  -a, --all             виводить обсяг для усіх файлів, а не лише каталогів\n"

#: src/du.c:297
msgid ""
"  -A, --apparent-size\n"
"         print apparent sizes rather than device usage;\n"
"         although the apparent size is usually smaller, it may be\n"
"         larger due to holes in ('sparse') files,\n"
"         internal fragmentation, indirect blocks, etc.\n"
msgstr ""
"  -A, --apparent-size\n"
"         виводить дійсні розміри, а не зайнятий простір на\n"
"         пристрої; хоча справжній розмір звичайно менший,\n"
"         іноді він може бути більшим через дірки у файлах,\n"
"         внутрішньої фрагментації, непрямих блоків тощо.\n"

#: src/du.c:304
msgid ""
"  -B, --block-size=SIZE\n"
"         scale sizes by SIZE before printing them; See SIZE format below;\n"
"         E.g., '-BM' prints sizes in units of 1,048,576 bytes\n"
msgstr ""
"  -B, --block-size=РОЗМІР\n"
"         використовувати блоки вказаного РОЗМІРУ. Приклад:\n"
"         «-BM» виводить розміри у одиницях у 1.048.576 байтів.\n"
"         Формат РОЗМІР описано нижче.\n"

#: src/du.c:309
msgid ""
"  -b, --bytes\n"
"         equivalent to '--apparent-size --block-size=1'\n"
msgstr "  -b, --bytes           еквівалент «--apparent-size --block-size=1»\n"

#: src/du.c:313
msgid ""
"  -c, --total\n"
"         produce a grand total\n"
msgstr "  -c, --total           підбивати підсумок\n"

#: src/du.c:317
msgid ""
"  -D, --dereference-args\n"
"         dereference only symlinks that are listed on the command line\n"
msgstr ""
"  -D, --dereference-args \n"
"         розіменовувати символьні посилання у командному\n"
"         рядку\n"

#: src/du.c:321
msgid ""
"  -d, --max-depth=N\n"
"         print the total for a directory (or file, with --all)\n"
"         only if it is N or fewer levels below the command\n"
"         line argument;  --max-depth=0 is the same as --summarize\n"
msgstr ""
"  -d, --max-depth=Н\n"
"         виводити підсумки для каталогу (або файла, якщо вказано --all),\n"
"         лише, якщо він перебуває на Н-му або нижчому рівні відносно\n"
"         аргументу командного рядка;  --max-depth=0 — те саме, що і для\n"
"         --summarize\n"

#: src/du.c:327
msgid ""
"      --files0-from=F\n"
"         summarize device usage of the NUL-terminated file names\n"
"         specified in file F;  if F is -, read names from standard input\n"
msgstr ""
"      --files0-from=Ф\n"
"         вивести звіт про файли, чиї назви (завершені\n"
"         нулем) перераховані у файлі Ф\n"
"         Якщо Ф вказано - назви беруться зі стандартного вводу\n"

#: src/du.c:332
msgid ""
"  -H\n"
"         equivalent to --dereference-args (-D)\n"
msgstr "  -H                    еквівалент параметра --dereference-args (-D)\n"

#: src/du.c:336
msgid ""
"  -h, --human-readable\n"
"         print sizes in human readable format (e.g., 1K 234M 2G)\n"
msgstr ""
"  -h, --human-readable  виводити розміри у зручному для людини вигляді\n"
"                          (наприклад 1K 234M 2G)\n"

#: src/du.c:340
msgid ""
"      --inodes\n"
"         list inode usage information instead of block usage\n"
msgstr ""
"      --inodes          вивести дані щодо використання inode замість даних "
"щодо використання блоків\n"

#: src/du.c:348
msgid ""
"  -L, --dereference\n"
"         dereference all symbolic links\n"
msgstr "  -L, --dereference     розіменувати всі символічні посилання\n"

#: src/du.c:352
msgid ""
"  -l, --count-links\n"
"         count sizes many times if hard linked\n"
msgstr ""
"  -l, --count-links     прочитати кожне жорстке посилання як окремий файл\n"

#: src/du.c:356
msgid ""
"  -m\n"
"         like --block-size=1M\n"
msgstr "  -m                    як --block-size=1M\n"

#: src/du.c:360
msgid ""
"  -P, --no-dereference\n"
"         don't follow any symbolic links (this is the default)\n"
msgstr ""
"  -P, --no-dereference  не слідувати за символьним посиланням (типово)\n"

#: src/du.c:364
msgid ""
"  -S, --separate-dirs\n"
"         for directories do not include size of subdirectories\n"
msgstr "  -S, --separate-dirs   не включати розмір підкаталогів\n"

#: src/du.c:368
msgid ""
"      --si\n"
"         like -h, but use powers of 1000 not 1024\n"
msgstr ""
"      --si              подібне до -h, але з використанням мір, кратних до "
"1000, а не 1024\n"

#: src/du.c:372
msgid ""
"  -s, --summarize\n"
"         display only a total for each argument\n"
msgstr "  -s, --summarize       виводити лише зведення для кожного аргументу\n"

#: src/du.c:376
msgid ""
"  -t, --threshold=SIZE\n"
"         exclude entries smaller than SIZE if positive,\n"
"         or entries greater than SIZE if negative\n"
msgstr ""
"  -t, --threshold=РОЗМІР\n"
"         виключити записи, менші за РОЗМІР, якщо додатне,\n"
"         або записи, більші за РОЗМІР, якщо від'ємне\n"

#: src/du.c:381
msgid ""
"      --time\n"
"         show time of the last modification of any file in the directory,\n"
"         or any of its subdirectories\n"
msgstr ""
"      --time\n"
"         виводити час останньої зміни будь-якого файла у\n"
"         каталозі або усіх його підкаталогів\n"

#: src/du.c:386
msgid ""
"      --time=WORD\n"
"         show time as WORD instead of modification time:\n"
"         atime, access, use, ctime or status\n"
msgstr ""
"      --time=СЛОВО\n"
"         виводити вказаний у СЛОВО час, а не час \n"
"         зміни: atime, access, use, ctime або status\n"

#: src/du.c:391
msgid ""
"      --time-style=STYLE\n"
"         time/date format with --time; see TIME_STYLE below\n"
msgstr ""
"      --time-style=СТИЛЬ_ЧАСУ\n"
"         формат часу і дати у -l; див. СТИЛЬ_ЧАСУ нижче\n"

#: src/du.c:395
msgid ""
"  -X, --exclude-from=FILE\n"
"         exclude files that match any pattern in FILE\n"
msgstr ""
"  -X, --exclude-from=ФАЙЛ         виключити файли, назви яких відповідають "
"зразку з ФАЙЛа\n"

#: src/du.c:399
msgid ""
"      --exclude=PATTERN\n"
"         exclude files that match PATTERN\n"
msgstr ""
"      --exclude=ВЗІРЕЦЬ    виключити файли, назви яких відповідають ВЗІРЦЮ\n"

#: src/du.c:403
msgid ""
"  -x, --one-file-system\n"
"         skip directories on different file systems\n"
msgstr ""
"  -x, --one-file-system    пропускати каталоги на різних файлових системах\n"

#: src/du.c:411
msgid ""
"\n"
"The --time-style STYLE argument can be full-iso, long-iso, iso, or +FORMAT.\n"
"FORMAT is interpreted like in date(1).\n"
"Also the TIME_STYLE environment variable sets the default style to use.\n"
msgstr ""
"\n"
"Значенням аргументу СТИЛЬ_ЧАСУ -time-style може бути full-iso, long-iso, iso "
"або +ФОРМАТ.\n"
"Значення ФОРМАТ обробляється як у date(1).\n"
"Крім того, змінна середовища TIME_STYLE встановлює\n"
"типовий стиль, який використовує програма.\n"

#: src/du.c:742
#, c-format
msgid "fts_read failed: %s"
msgstr "помилка fts_read: %s"

#: src/du.c:870
#, c-format
msgid "invalid maximum depth %s"
msgstr "неприпустима максимальна глибина %s"

#: src/du.c:900
#, c-format
msgid "invalid --threshold argument '-0'"
msgstr "некоректний аргумент --threshold «-0»"

#: src/du.c:983
#, c-format
msgid "cannot both summarize and show all entries"
msgstr "не можна одночасно підбивати зведення та виводити всі елементи"

#: src/du.c:990
#, c-format
msgid "warning: summarizing is the same as using --max-depth=0"
msgstr "попередження: підбиття зведення це те ж саме, що й --max-depth=0"

#: src/du.c:995
#, c-format
msgid "warning: summarizing conflicts with --max-depth=%td"
msgstr "попередження: підбиття зведення конфліктує з --max-depth=%td"

#: src/du.c:1007
#, c-format
msgid "warning: options --apparent-size and -b are ineffective with --inodes"
msgstr ""
"попередження: параметри --apparent-size і -b не працюватимуть з --inodes"

#: src/du.c:1074 src/sort.c:4813 src/wc.c:882
msgid "file operands cannot be combined with --files0-from"
msgstr "операнди-файли не можна використовувати разом з --files0-from"

#: src/du.c:1141 src/sort.c:4834 src/wc.c:946
#, c-format
msgid "when reading file names from standard input, no file name of %s allowed"
msgstr ""
"при читанні імен файлів зі стандартного введення, не допускаються назви "
"файлів %s"

#: src/du.c:1158 src/du.c:1166 src/wc.c:959 src/wc.c:966
msgid "invalid zero-length file name"
msgstr "неправильна назва файла нульової довжини"

#. This is a proper name. See the gettext manual, section Names.
#: src/echo.c:28
msgid "Brian Fox"
msgstr "Brian Fox"

#. This is a proper name. See the gettext manual, section Names.
#: src/echo.c:29
msgid "Chet Ramey"
msgstr "Chet Ramey"

#: src/echo.c:43
#, c-format
msgid ""
"Usage: %s [SHORT-OPTION]... [STRING]...\n"
"  or:  %s LONG-OPTION\n"
msgstr ""
"Використання: %s [СКОРОЧЕНИЙ-ПАРАМЕТР]... [РЯДОК]...\n"
"  або  %s ДОВГИЙ-ПАРАМЕТР\n"

#: src/echo.c:47
msgid ""
"Echo the STRING(s) to standard output.\n"
"\n"
msgstr ""
"Виводить РЯДОК(РЯДКА) на стандартний вивід.\n"
"\n"

#: src/echo.c:51
msgid "  -n     do not output the trailing newline\n"
msgstr "  -n      не виводити завершальне переведення рядка\n"

#: src/echo.c:55
msgid "  -e     enable interpretation of backslash escapes (default)\n"
msgstr "  -e     інтерпретувати керівні послідовності (типово)\n"

#: src/echo.c:58
msgid "  -e     enable interpretation of backslash escapes\n"
msgstr "  -e     інтерпретувати керівні послідовності\n"

#: src/echo.c:62
msgid "  -E     disable interpretation of backslash escapes\n"
msgstr "  -E     не інтерпретувати керівні послідовності\n"

#: src/echo.c:65
msgid "  -E     disable interpretation of backslash escapes (default)\n"
msgstr "  -E      не інтерпретувати керівні послідовності (типово)\n"

#: src/echo.c:70
msgid ""
"\n"
"If -e is in effect, the following sequences are recognized:\n"
"\n"
msgstr ""
"\n"
"Якщо задіяно -e, розпізнаються такі послідовності:\n"
"\n"

#: src/echo.c:75 src/printf.c:70
msgid ""
"  \\\\      backslash\n"
"  \\a      alert (BEL)\n"
"  \\b      backspace\n"
"  \\c      produce no further output\n"
"  \\e      escape\n"
"  \\f      form feed\n"
"  \\n      new line\n"
"  \\r      carriage return\n"
"  \\t      horizontal tab\n"
"  \\v      vertical tab\n"
msgstr ""
"  \\\\      зворотна риска\n"
"  \\a      дзвінок (BEL)\n"
"  \\b      backspace\n"
"  \\c      не виводити завершальний символ нового рядка\n"
"  \\e      escape\n"
"  \\f      нова сторінка\n"
"  \\n      новий рядок\n"
"  \\r      переведення каретки\n"
"  \\t      горизонтальна табуляція\n"
"  \\v      вертикальна табуляція\n"

#: src/echo.c:87
msgid ""
"  \\0NNN   byte with octal value NNN (1 to 3 digits)\n"
"  \\xHH    byte with hexadecimal value HH (1 to 2 digits)\n"
msgstr ""
"  \\0NNN   байт з вісімковим значенням NNN (від 1 до 3 цифр)\n"
"  \\xHH    байт з шістнадцятковим значенням HH (від 1 до 2 цифр)\n"

#: src/echo.c:92
msgid ""
"\n"
"Consider using the printf(1) command instead,\n"
"as it avoids problems when outputting option-like strings.\n"
msgstr ""
"\n"
"Вам варто натомість скористатися командою printf(1),\n"
"оскільки у неї немає проблем із виведенням параметроподібних рядків.\n"

