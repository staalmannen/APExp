#: src/shuf.c:56
#, c-format
msgid ""
"Usage: %s [OPTION]... [FILE]\n"
"  or:  %s -e [OPTION]... [ARG]...\n"
"  or:  %s -i LO-HI [OPTION]...\n"
msgstr ""
"Використання: %s [ПАРАМЕТР]... [ФАЙЛ]\n"
"  або:  %s -e [ПАРАМЕТР]... [АРГУМЕНТ]...\n"
"  або:  %s -i НИЖ-ВИЩ [ПАРАМЕТР]...\n"

#: src/shuf.c:62
msgid "Write a random permutation of the input lines to standard output.\n"
msgstr "Виводить випадково переставлені вхідні рядки на стандартний вивід.\n"

#: src/shuf.c:69
msgid "  -e, --echo                treat each ARG as an input line\n"
msgstr "  -e, --echo                вважати кожен АРГУМЕНТ вхідним рядком\n"

#: src/shuf.c:72
msgid ""
"  -i, --input-range=LO-HI   treat each number LO through HI as an input "
"line\n"
msgstr ""
"  -i, --input-range=НИЖ-ВИЩ вважати числа від НИЖ до ВИЩ вхідним рядком\n"

#: src/shuf.c:75
msgid "  -n, --head-count=COUNT    output at most COUNT lines\n"
msgstr "  -n, --head-lines=РЯДКІВ   виводити принаймні кількість РЯДКІВ\n"

#: src/shuf.c:78
msgid ""
"  -o, --output=FILE         write result to FILE instead of standard output\n"
msgstr ""
"  -o, --output=ФАЙЛ         вивести результат у ФАЙЛ, а не стандартний "
"вивід\n"

#: src/shuf.c:81
msgid "      --random-source=FILE  get random bytes from FILE\n"
msgstr "      --random-source=ФАЙЛ  випадкові дані з ФАЙЛа\n"

#: src/shuf.c:84
msgid "  -r, --repeat              output lines can be repeated\n"
msgstr ""
"  -r, --repeat              рядки у виведених даних можуть повторюватися\n"

#: src/shuf.c:87
msgid "  -z, --zero-terminated     line delimiter is NUL, not newline\n"
msgstr ""
"  -z, --zero-terminated     завершувати рядки нульовим байтом, а не символом "
"нового рядка\n"

#: src/shuf.c:227
#, c-format
msgid "too many input lines"
msgstr "занадто багато рядків вхідних даних"

#: src/shuf.c:420
#, c-format
msgid "multiple -i options specified"
msgstr "задано декілька параметрів -i"

#: src/shuf.c:449
msgid "invalid input range"
msgstr "некоректний діапазон вхідних даних"

#: src/shuf.c:461
#, c-format
msgid "invalid line count: %s"
msgstr "некоректна кількість рядків: %s"

#: src/shuf.c:468 src/sort.c:4712
#, c-format
msgid "multiple output files specified"
msgstr "задано декілька файлів для виводу"

#: src/shuf.c:498
#, c-format
msgid "cannot combine -e and -i options"
msgstr "не можна одночасно використовувати параметри -e та -i"

#: src/shuf.c:588
#, c-format
msgid "no lines to repeat"
msgstr "немає рядків для повторення"

#: src/sleep.c:42
#, c-format
msgid ""
"Usage: %s NUMBER[SUFFIX]...\n"
"  or:  %s OPTION\n"
"Pause for NUMBER seconds, where NUMBER is an integer or floating-point.\n"
"SUFFIX may be 's','m','h', or 'd', for seconds, minutes, hours, days.\n"
"With multiple arguments, pause for the sum of their values.\n"
"\n"
msgstr ""
"Використання: %s ЧИСЛО[СУФІКС]\n"
"         або: %s ПАРАМЕТР\n"
"Призупиняє виконання на вказане ціле або дробове ЧИСЛО одиниць часу.\n"
"СУФІКС може приймати значення 's','m','h' або 'd', для секунд, хвилин, годин "
"і днів.\n"
"Якщо вказано декілька аргументів, буде додано паузу,\n"
"тривалість якої буде сумою вказаних значень.\n"
"\n"

#: src/sleep.c:131 src/timeout.c:386
#, c-format
msgid "invalid time interval %s"
msgstr "некоректний інтервал часу %s"

#: src/sleep.c:142 src/tail.c:1345
#, c-format
msgid "cannot read realtime clock"
msgstr "не вдалося прочитати значення таймеру реального часу"

#: src/sort.c:426
msgid "Write sorted concatenation of all FILE(s) to standard output.\n"
msgstr "Вивести сортоване сполучення усіх ФАЙЛ(ів) на стандартний вивід.\n"

#: src/sort.c:433
msgid ""
"Ordering options:\n"
"\n"
msgstr ""
"Ключі, що вказують порядок:\n"
"\n"

#: src/sort.c:437
msgid ""
"  -b, --ignore-leading-blanks\n"
"         ignore leading blanks when finding sort keys in each line\n"
msgstr ""
"  -b, --ignore-leading-blanks\n"
"         ігнорувати початкові пробіли при пошуку ключів упорядкування у всіх "
"рядках\n"

#: src/sort.c:441
msgid ""
"  -d, --dictionary-order\n"
"         consider only blanks and alphanumeric characters\n"
msgstr ""
"  -d, --dictionary-order      розглядати лише пропуски, літери та цифри\n"

#: src/sort.c:445
msgid ""
"  -f, --ignore-case\n"
"         fold lower case to upper case characters\n"
msgstr "  -f, --ignore-case           ігнорувати регістр літер\n"

#: src/sort.c:449
msgid ""
"  -g, --general-numeric-sort\n"
"         compare according to general numerical value\n"
msgstr "  -g, --general-numeric-sort  порівнювати числа у загальному форматі\n"

#: src/sort.c:453
msgid ""
"  -i, --ignore-nonprinting\n"
"         consider only printable characters\n"
msgstr "  -i, --ignore-nonprinting    розглядати лише друковані знаки\n"

#: src/sort.c:457
msgid ""
"  -M, --month-sort\n"
"         compare (unknown) < 'JAN' < ... < 'DEC'\n"
msgstr ""
"  -M, --month-sort            порівнювати (невідомо) < 'JAN' < ... < 'DEC'\n"

#: src/sort.c:461
msgid ""
"  -h, --human-numeric-sort\n"
"         compare human readable numbers (e.g., 2K 1G)\n"
msgstr ""
"  -h, --human-numeric-sort\n"
"         порівнювати значення у зручному для читання форматі (приклад: 2к "
"1Г)\n"

#: src/sort.c:465
msgid ""
"  -n, --numeric-sort\n"
"         compare according to string numerical value;\n"
"         see full documentation for supported strings\n"
msgstr ""
"  -n, --numeric-sort\n"
"         порівняти за числовим значенням рядка;\n"
"         див. повну документацію щодо підтримуваних рядків\n"

#: src/sort.c:470
msgid ""
"  -R, --random-sort\n"
"         shuffle, but group identical keys.  See also shuf(1)\n"
msgstr ""
"  -R, --random-sort\n"
"         перемішати, але згрупувати ідентичні параметрі. Див. також shuf(1)\n"

#: src/sort.c:478
msgid ""
"  -r, --reverse\n"
"         reverse the result of comparisons\n"
msgstr "  -r, --reverse               зворотний порядок порівняння\n"

#: src/sort.c:482
msgid ""
"      --sort=WORD\n"
"         sort according to WORD:\n"
"           general-numeric -g, human-numeric -h, month -M,\n"
"           numeric -n, random -R, version -V\n"
msgstr ""
"      --sort=СЛОВО\n"
"         сортувати відповідно до СЛОВО:\n"
"           general-numeric -g, human-numeric -h, month -M,\n"
"           numeric -n, random -R, version -V\n"

#: src/sort.c:488
msgid ""
"  -V, --version-sort\n"
"         natural sort of (version) numbers within text\n"
msgstr ""
"  -V, --version-sort\n"
"         сортувати за номером версії\n"

#: src/sort.c:492
msgid ""
"\n"
"Other options:\n"
"\n"
msgstr ""
"\n"
"Інші параметри:\n"
"\n"

#: src/sort.c:497
msgid ""
"      --batch-size=NMERGE\n"
"         merge at most NMERGE inputs at once; for more use temp files\n"
msgstr ""
"      --batch-size=NMERGE\n"
"         об'єднувати не більше NMERGE джерел введення одразу;\n"
"         для решти використовувати тимчасові файли\n"

#: src/sort.c:501
msgid ""
"  -c, --check, --check=diagnose-first\n"
"         check for sorted input; do not sort\n"
msgstr ""
"  -c, --check, --check=diagnose-first\n"
"         перевіряти, чи сортовані вхідні\n"
"         файли; не сортувати\n"

#: src/sort.c:505
msgid ""
"  -C, --check=quiet, --check=silent\n"
"         like -c, but do not report first bad line\n"
msgstr ""
"  -C, --check=quiet, --check=silent\n"
"         як -c, але не повідомляти про перший\n"
"         помилковий рядок\n"

#: src/sort.c:509
msgid ""
"      --compress-program=PROG\n"
"         compress temporaries with PROG; decompress them with PROG -d\n"
msgstr ""
"      --compress-program=ПРОГ\n"
"         стискати тимчасові файли командою ПРОГ;\n"
"         розпаковувати командою ПРОГ -d\n"

#: src/sort.c:513
msgid ""
"      --debug\n"
"         annotate the part of the line used to sort,\n"
"         and warn about questionable usage to standard error\n"
msgstr ""
"      --debug\n"
"         коментувати частину рядка, використану для\n"
"         впорядковування, попереджати щодо сумнівного\n"
"         використання до стандартної помилки\n"

#: src/sort.c:518
msgid ""
"      --files0-from=F\n"
"         read input from the files specified by NUL-terminated names in file "
"F;\n"
"         If F is -, read names from standard input\n"
msgstr ""
"      --files0-from=F\n"
"         читати вхідні дані з файлів, вказаних\n"
"         назвами зі списку, розділеного символами\n"
"         NUL у файлі F. Якщо F дорівнює «-», назви\n"
"         буде прочитано зі стандартного джерела даних\n"

#: src/sort.c:524
msgid ""
"  -k, --key=KEYDEF\n"
"         sort via a key; KEYDEF gives location and type\n"
msgstr ""
"  -k, --key=ВИЗНКЛ          впорядкувати за параметром, ВИЗНКЛ визначає "
"місце і тип\n"

#: src/sort.c:528
msgid ""
"  -m, --merge\n"
"         merge already sorted files; do not sort\n"
msgstr ""
"  -m, --merge               об'єднати вже впорядковані файли; не "
"впорядковувати\n"

#: src/sort.c:532
msgid ""
"  -o, --output=FILE\n"
"         write result to FILE instead of standard output\n"
msgstr "  -o, --output=ФАЙЛ  виводити у ФАЙЛ, а не на стандартний вивід\n"

#: src/sort.c:536
msgid ""
"  -s, --stable\n"
"         stabilize sort by disabling last-resort comparison\n"
msgstr ""
"  -s, --stable     стабілізувати сортування, виключивши перевірку на "
"рівність\n"

#: src/sort.c:540
msgid ""
"  -S, --buffer-size=SIZE\n"
"         use SIZE for main memory buffer\n"
msgstr ""
"  -S, --buffer-size=РОЗМІР\n"
"                   використовувати в пам'яті буфер вказаного РОЗМІРУ\n"

#: src/sort.c:544
msgid ""
"  -t, --field-separator=SEP\n"
"         use SEP instead of non-blank to blank transition\n"
msgstr ""
"  -t, --field-separator=РОЗДІЛЮВАЧ\n"
"                   використовувати при пошуку ключових полів РОЗДІЛЮВАЧ, а "
"не\n"
"                   перехід від непробільних знаків до пробільних\n"

#: src/sort.c:548
#, c-format
msgid ""
"  -T, --temporary-directory=DIR\n"
"         use DIR for temporaries, not $TMPDIR or %s;\n"
"         multiple options specify multiple directories\n"
msgstr ""
"  -T, --temporary-directory=КАТАЛОГ\n"
"         використовувати для тимчасових файлів КАТАЛОГ, а не $TMPDIR\n"
"         або %s; декілька таких параметрів задають декілька каталогів\n"

#: src/sort.c:553
msgid ""
"      --parallel=N\n"
"         change the number of sorts run concurrently to N\n"
msgstr ""
"  -u, --unique     виводити лише перші рядки з відповідними ключами;\n"
"                     з -c перевіряти порядок суворо\n"

#: src/sort.c:557
msgid ""
"  -u, --unique\n"
"         output only the first of lines with equal keys;\n"
"         with -c, check for strict ordering\n"
msgstr ""
"  -u, --unique\n"
"         виводити лише перший з рядків з однаковими ключами;\n"
"         з -c перевірити щодо строгого упорядкування\n"

#: src/sort.c:568
msgid ""
"\n"
"KEYDEF is F[.C][OPTS][,F[.C][OPTS]] for start and stop position, where F is "
"a\n"
"field number and C a character position in the field; both are origin 1, "
"and\n"
"the stop position defaults to the line's end.  If neither -t nor -b is in\n"
"effect, characters in a field are counted from the beginning of the "
"preceding\n"
"whitespace.  OPTS is one or more single-letter ordering options "
"[bdfgiMhnRrV],\n"
"which override global ordering options for that key.  If no key is given, "
"use\n"
"the entire line as the key.  Use --debug to diagnose incorrect key usage.\n"
"\n"
"SIZE may be followed by the following multiplicative suffixes:\n"
msgstr ""
"\n"
"ВИЗНКЛ вказується як П[.З][ПАРАМ][П[.З][ПАРАМ]] для початкової і\n"
"кінцевої позицій, де П -- номер поля, а З -- позиція\n"
"символу у цьому поле, відлік обох ведеться з 1, типовою кінцевою\n"
"позицією є позиція кінця рядка. Якщо не використано ні -t, ні -b,\n"
"відлік символів у полі вестиметься з початку попереднього полю пробілу.\n"
"ПАРАМ визначається одним або декількома параметрами впорядковування з\n"
"набору [bdfgiMhnRrV]. ПАРАМ перевизначає загальні параметри впорядковування\n"
"для відповідного параметра. Якщо поле параметра не вказано, як параметр "
"буде\n"
"використано увесь рядок. Для діагностування помилкового використання "
"параметрів\n"
"скористайтеся параметром --debug.\n"
"\n"
"Після РОЗМІРУ можна вказувати такі суфікси-мультиплікатори:\n"

#: src/sort.c:581
msgid ""
"% 1% of memory, b 1, K 1024 (default), and so on for M, G, T, P, E, Z, Y, R, "
"Q.\n"
"\n"
"*** WARNING ***\n"
