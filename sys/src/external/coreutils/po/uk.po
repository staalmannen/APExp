msgstr "  -u                       (ігнорується)\n"

#: src/cat.c:130
msgid ""
"  -v, --show-nonprinting   use ^ and M- notation, except for LFD and TAB\n"
msgstr ""
"  -v, --show-nonprinting   використовувати нотацію ^ та M-, за винятком\n"
"                           переведення рядка та табуляції\n"

