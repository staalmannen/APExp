#: src/test.c:667
msgid ""
"Usage: test EXPRESSION\n"
"  or:  test\n"
"  or:  [ EXPRESSION ]\n"
"  or:  [ ]\n"
"  or:  [ OPTION\n"
msgstr ""
"Використання: test ВИРАЗ\n"
"  або:  test\n"
"  або:  [ ВИРАЗ ]\n"
"  або:  [ ]\n"
"  або:  [ КЛЮЧ\n"

#: src/test.c:674
msgid ""
"Exit with the status determined by EXPRESSION.\n"
"\n"
msgstr "Вихідний статус визначається ВИРАЗОМ.\n"

#: src/test.c:680
msgid ""
"\n"
"An omitted EXPRESSION defaults to false.  Otherwise,\n"
"EXPRESSION is true or false and sets exit status.  It is one of:\n"
msgstr ""
"\n"
"Якщо ВИРАЗ не вказаний, він вважається хибним.  У іншому випадку\n"
"ВИРАЗ може бути істинним або хибним; він встановлює статус\n"
"завершення програми.  Код завершення визначається наступним образом:\n"

#: src/test.c:685
msgid ""
"\n"
"  ( EXPRESSION )               EXPRESSION is true\n"
"  ! EXPRESSION                 EXPRESSION is false\n"
"  EXPRESSION1 -a EXPRESSION2   both EXPRESSION1 and EXPRESSION2 are true\n"
"  EXPRESSION1 -o EXPRESSION2   either EXPRESSION1 or EXPRESSION2 is true\n"
msgstr ""
"\n"
"  ( ВИРАЗ )               ВИРАЗ істинний\n"
"  ! ВИРАЗ                 ВИРАЗ хибний\n"
"  ВИРАЗ1 -a ВИРАЗ2        ВИРАЗ1 та ВИРАЗ2 обидва істинні\n"
"  ВИРАЗ1 -o ВИРАЗ2        ВИРАЗ1 або ВИРАЗ2 істинний\n"

#: src/test.c:695
msgid "  -n STRING            the length of STRING is nonzero\n"
msgstr "  -n РЯДОК          довжина РЯДКА відмінна від нуля\n"

#: src/test.c:698
msgid "  STRING               equivalent to -n STRING\n"
msgstr "  РЯДОК               еквівалентно -n РЯДОК\n"

#: src/test.c:701
msgid "  -z STRING            the length of STRING is zero\n"
msgstr "  -z РЯДОК            довжина РЯДКА дорівнює нулеві\n"

#: src/test.c:704
msgid ""
"  STRING1 = STRING2    the strings are equal\n"
"  STRING1 != STRING2   the strings are not equal\n"
"  STRING1 > STRING2    STRING1 is greater than STRING2 in the current "
"locale\n"
"  STRING1 < STRING2    STRING1 is less than STRING2 in the current locale\n"
msgstr ""
"  РЯДОК1 = РЯДОК2     рядки еквівалентні\n"
"  РЯДОК1 != РЯДОК2    рядки не еквівалентні\n"
"  РЯДОК1 > РЯДОК2     РЯДОК1 є більшим за РЯДОК2 у поточній локалі\n"
"  РЯДОК1 < РЯДОК2     РЯДОК1 є меншим за РЯДОК2 у поточній локалі\n"

#: src/test.c:713
msgid "  INTEGER1 -eq INTEGER2   INTEGER1 is equal to INTEGER2\n"
msgstr "  ЦІЛЕ1 -eq ЦІЛЕ2   ЦІЛЕ1 дорівнює ЦІЛОМУ2\n"

#: src/test.c:716
msgid ""
"  INTEGER1 -ge INTEGER2   INTEGER1 is greater than or equal to INTEGER2\n"
msgstr "  ЦІЛЕ1 -ge ЦІЛЕ2   ЦІЛЕ1 більше або дорівнює ЦІЛОМУ2\n"

#: src/test.c:719
msgid "  INTEGER1 -gt INTEGER2   INTEGER1 is greater than INTEGER2\n"
msgstr "  ЦІЛЕ1 -gt ЦІЛЕ2   ЦІЛЕ1 більше ЦІЛОГО2\n"

#: src/test.c:722
msgid "  INTEGER1 -le INTEGER2   INTEGER1 is less than or equal to INTEGER2\n"
msgstr "  ЦІЛЕ1 -le ЦІЛЕ2   ЦІЛЕ1 менше або дорівнює ЦІЛОМУ2\n"

#: src/test.c:725
msgid "  INTEGER1 -lt INTEGER2   INTEGER1 is less than INTEGER2\n"
msgstr "  ЦІЛЕ1 -lt ЦІЛЕ2   ЦІЛЕ1 менше ЦІЛОГО2\n"

#: src/test.c:728
msgid "  INTEGER1 -ne INTEGER2   INTEGER1 is not equal to INTEGER2\n"
msgstr "  ЦІЛЕ1 -ne ЦІЛЕ2   ЦІЛЕ1 відмінне від ЦІЛОГО2\n"

#: src/test.c:734
