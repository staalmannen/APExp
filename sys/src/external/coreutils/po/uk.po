#, c-format
msgid "%s: unknown program %s\n"
msgstr "%s: невідома програма %s\n"

#: src/cp.c:160 src/mv.c:253
#, c-format
msgid ""
"Usage: %s [OPTION]... [-T] SOURCE DEST\n"
"  or:  %s [OPTION]... SOURCE... DIRECTORY\n"
"  or:  %s [OPTION]... -t DIRECTORY SOURCE...\n"
msgstr ""
"Використання: %s [ПАРАМЕТР]... [-T] ДЖЕРЕЛО ЦІЛЬ\n"
"       або:    %s [ПАРАМЕТР]... ДЖЕРЕЛО... КАТАЛОГ\n"
"       або:    %s [ПАРАМЕТР]... -t КАТАЛОГ ДЖЕРЕЛО...\n"

#: src/cp.c:166
msgid "Copy SOURCE to DEST, or multiple SOURCE(s) to DIRECTORY.\n"
msgstr "Копіює ДЖЕРЕЛО у ЦІЛЬ, або декілька ДЖЕРЕЛ у КАТАЛОГ.\n"

#: src/cp.c:172
msgid ""
"  -a, --archive\n"
"         same as -dR --preserve=all\n"
msgstr "  -a, --archive                те саме що та -dR --preserve=all\n"

#: src/cp.c:176
msgid ""
"      --attributes-only\n"
"         don't copy the file data, just the attributes\n"
msgstr ""
"      --attributes-only        не копіювати даних файла, лише атрибути\n"

#: src/cp.c:180 src/install.c:615 src/ln.c:441 src/mv.c:265
msgid ""
"      --backup[=CONTROL]\n"
"         make a backup of each existing destination file\n"
msgstr ""
"      --backup[=КОНТРОЛЬ]\n"
"         робити резервну копію кожного цільового файла\n"

#: src/cp.c:184 src/install.c:619 src/ln.c:445 src/mv.c:269
msgid ""
"  -b\n"
"         like --backup but does not accept an argument\n"
msgstr ""
"  -b\n"
"         те ж, що й --backup, але не приймає аргумент\n"

#: src/cp.c:188
msgid ""
"      --copy-contents\n"
"         copy contents of special files when recursive\n"
msgstr ""
"      --copy-contents          копіює зміст спеціальних файлів при\n"
"                               рекурсивному використанні\n"

#: src/cp.c:192
msgid ""
"  -d\n"
"         same as --no-dereference --preserve=links\n"
msgstr ""
"  -d                           те саме, що й --no-dereference --"
"preserve=link\n"

#: src/cp.c:196 src/install.c:644 src/mv.c:273
msgid ""
"      --debug\n"
"         explain how a file is copied.  Implies -v\n"
msgstr ""
"      --debug\n"
"         пояснити як скопійовано файл. Неявним чином задає -v\n"

#: src/cp.c:200
msgid ""
"  -f, --force\n"
"         if an existing destination file cannot be opened, remove it and "
"try\n"
"         again (this option is ignored when the -n option is also used)\n"
msgstr ""
"  -f, --force\n"
"         якщо не можна відкрити наявний файл,\n"
"         вилучити його та спробувати ще раз\n"
"         (буде проігноровано, якщо вказано\n"
"         параметр -n )\n"

#: src/cp.c:205
msgid ""
"  -i, --interactive\n"
"         prompt before overwrite (overrides a previous -n option)\n"
msgstr ""
"  -i, --interactive\n"
"         запитувати підтвердження перед переписом\n"
"         (перевизначає раніше вказаний параметр -n )\n"

#: src/cp.c:209
msgid ""
"  -H\n"
"         follow command-line symbolic links in SOURCE\n"
msgstr ""
"  -H                           переходити за символічним посиланням у "
"ДЖЕРЕЛО\n"

#: src/cp.c:213
msgid ""
"  -L, --dereference\n"
"         always follow symbolic links in SOURCE\n"
msgstr ""
"  -L, --dereference            завжди слідувати за символічним посиланням у "
"ДЖЕРЕЛО\n"

#: src/cp.c:217
msgid ""
"  -P, --no-dereference\n"
"         never follow symbolic links in SOURCE\n"
msgstr ""
"  -P, --no-dereference\n"
"         ніколи не переходити за символічними посиланнями у ДЖЕРЕЛІ\n"

#: src/cp.c:221
msgid ""
"      --keep-directory-symlink\n"
"         follow existing symlinks to directories\n"
msgstr ""
"      --keep-directory-symlink\n"
"         переходити за наявними символічними посиланнями до каталогів\n"

#: src/cp.c:225
msgid ""
"  -l, --link\n"
"         hard link files instead of copying\n"
msgstr ""
"  -l, --link                   створювати жорсткі посилання, а не копіювати\n"

#: src/cp.c:229
msgid ""
"  -n, --no-clobber\n"
"         (deprecated) silently skip existing files.  See also --update\n"
msgstr ""
"  -n, --no-clobber\n"
"         (застарілий) без повідомлень пропустити наявні\n"
"         файли. Див. також --update\n"

#: src/cp.c:233
msgid ""
"  -p\n"
"         same as --preserve=mode,ownership,timestamps\n"
msgstr ""
"  -p                           те саме, що і --"
"preserve=mode,ownership,timestamps\n"

#: src/cp.c:237
msgid ""
"      --preserve[=ATTR_LIST]\n"
"         preserve the specified attributes\n"
msgstr "      --preserve[=СПИСОК_АТРИБУТІВ]   зберегти вказані атрибути\n"

#: src/cp.c:241
msgid ""
"      --no-preserve=ATTR_LIST\n"
"         don't preserve the specified attributes\n"
msgstr "      --no-preserve=СПИС_АТТР  не зберігати вказані атрибути\n"

#: src/cp.c:245
msgid ""
"      --parents\n"
"         use full source file name under DIRECTORY\n"
msgstr "      --parents                добавить вихідний шлях до КАТАЛОГУ\n"

#: src/cp.c:249
msgid ""
"  -R, -r, --recursive\n"
"         copy directories recursively\n"
msgstr ""
"  -R, -r, --recursive\n"
"         копіювати каталоги рекурсивно\n"

#: src/cp.c:253
msgid ""
"      --reflink[=WHEN]\n"
"         control clone/CoW copies. See below\n"
msgstr ""
"      --reflink[=КОЛИ]         керувати копіями clone/CoW. Див. нижче.\n"

#: src/cp.c:257
msgid ""
"      --remove-destination\n"
"         remove each existing destination file before attempting to open it\n"
"         (contrast with --force)\n"
msgstr ""
"      --remove-destination\n"
"         вилучати кожен цільовий файл, перш ніж\n"
"         копіювати його (протилежність до --force)\n"

#: src/cp.c:262
msgid ""
"      --sparse=WHEN\n"
"         control creation of sparse files. See below\n"
msgstr ""
"      --sparse=КОЛИ            керує створенням розріджених файлів. Див. "
"нижче.\n"

#: src/cp.c:266 src/mv.c:300
msgid ""
"      --strip-trailing-slashes\n"
"         remove any trailing slashes from each SOURCE argument\n"
msgstr ""
"      --strip-trailing-slashes\n"
"         вилучає усі кінцеві похилі риски з кожного\n"
"         аргументу ДЖЕРЕЛО\n"

#: src/cp.c:270
msgid ""
"  -s, --symbolic-link\n"
"         make symbolic links instead of copying\n"
msgstr ""
"  -s, --symbolic-link          створювати символьні посилання а не "
"копіювати\n"

#: src/cp.c:274 src/install.c:673 src/ln.c:483 src/mv.c:304
msgid ""
"  -S, --suffix=SUFFIX\n"
"         override the usual backup suffix\n"
msgstr ""
"  -S, --suffix=СУФІКС\n"
"         використовувати для резервних копій заданий СУФІКС\n"

#: src/cp.c:278 src/install.c:677
msgid ""
"  -t, --target-directory=DIRECTORY\n"
"         copy all SOURCE arguments into DIRECTORY\n"
msgstr ""
"  -t, --target-directory=КАТАЛОГ\n"
"         копіювати всі аргументи-ДЖЕРЕЛА у КАТАЛОГ\n"

#: src/cp.c:282 src/install.c:681 src/mv.c:312
msgid ""
"  -T, --no-target-directory\n"
"         treat DEST as a normal file\n"
msgstr ""
"  -T, --no-target-directory\n"
"         вважати ЦІЛЬ звичайним файлом\n"

#: src/cp.c:286 src/mv.c:316
msgid ""
"      --update[=UPDATE]\n"
"         control which existing files are updated;\n"
"         UPDATE={all,none,none-fail,older(default)}\n"
msgstr ""
"      --update[=ОНОВЛЕННЯ]         керувати тим, які наявні файли буде "
"оновлення;\n"
"         ОНОВЛЕННЯ={all,none,none-fail,older(типовий)}\n"

#: src/cp.c:291 src/mv.c:321
msgid ""
"  -u\n"
"         equivalent to --update[=older].  See below\n"
msgstr ""
"  -u                           те саме, що і --update[=older]. Див. нижче\n"

#: src/cp.c:295 src/mv.c:325 src/rm.c:179
msgid ""
"  -v, --verbose\n"
"         explain what is being done\n"
msgstr ""
"  -v, --verbose\n"
"         пояснювати дії, що виконуються\n"

#: src/cp.c:299
msgid ""
"  -x, --one-file-system\n"
"         stay on this file system\n"
msgstr ""
"  -x, --one-file-system\n"
"         лишатися на цій файловій системі\n"

#: src/cp.c:303
msgid ""
"  -Z\n"
"         set SELinux security context of destination file to default type\n"
msgstr ""
"  -Z\n"
"         встановити типовий тип контексту безпеки SELinux\n"

#: src/cp.c:307 src/install.c:698 src/mkdir.c:82 src/mkfifo.c:67 src/mknod.c:69
msgid ""
"      --context[=CTX]\n"
"         like -Z, or if CTX is specified then set the\n"
"         SELinux or SMACK security context to CTX\n"
msgstr ""
"      --context[=CTX]\n"
"         подібний до -Z, якщо вказано CTX, встановити контекст безпеки\n"
"         SELinux або SMACK відповідно до вказаного значення\n"
"         контексту CTX\n"

#: src/cp.c:314
msgid ""
"\n"
"ATTR_LIST is a comma-separated list of attributes. Attributes are 'mode' "
"for\n"
"permissions (including any ACL and xattr permissions), 'ownership' for user\n"
"and group, 'timestamps' for file timestamps, 'links' for hard links, "
"'context'\n"
"for security context, 'xattr' for extended attributes, and 'all' for all\n"
"attributes.\n"
msgstr ""
"\n"
"СПИСОК_АТРИБУТІВ є списком відокремлених комами атрибутів. Атрибутами є\n"
"«mode» для прав доступу (включно з усіма правами доступу ACL і xattr),\n"
"«ownership» для користувача і групи, «timestamps» для часових позначок\n"
"файлів, «links» для жорстких посилань, «context» для контексту безпеки,\n"
"«xattr» для розширених атрибутів і «all» для усіх атрибутів.\n"

#: src/cp.c:322
msgid ""
"\n"
"By default, sparse SOURCE files are detected by a crude heuristic and the\n"
"corresponding DEST file is made sparse as well.  That is the behavior\n"
"selected by --sparse=auto.  Specify --sparse=always to create a sparse DEST\n"
"file whenever the SOURCE file contains a long enough sequence of zero "
"bytes.\n"
"Use --sparse=never to inhibit creation of sparse files.\n"
msgstr ""
"\n"
"Типово розріджені файли ДЖЕРЕЛА розпізнається за допомогою грубої\n"
"евристичної процедури та відповідно створюється розріджений файл\n"
"ПРИЗНАЧЕННЯ. Таку поведінку можна визначити за допомогою\n"
"параметра --sparse=auto. З параметром --sparse=always ПРТИЗНАЧЕННЯ\n"
"завжди створюється розрідженим, незалежно від того, чи містить\n"
"файл ДЖЕРЕЛА довгі послідовності нульових байтів.\n"
"Скористайтеся параметром --sparse=never для заборони створення розріджених\n"
"файлів.\n"

#: src/cp.c:331
msgid ""
"\n"
"By default or with --reflink=auto, cp will try a lightweight copy, where "
"the\n"
"data blocks are copied only when modified, falling back to a standard copy\n"
"if this is not possible.  With --reflink[=always] cp will fail if CoW is "
"not\n"
"supported, while --reflink=never ensures a standard copy is performed.\n"
msgstr ""
"\n"
"Типово або з --reflink=auto cp спробує невибагливе копіювання, де блоки\n"
"даних буде скопійовано, лише при модифікації, з резервним варіантом\n"
"стандартного копіювання, якщо це неможливе. З --reflink[=always] cp "
"повідомить\n"
"про помилку, якщо підтримки CoW не передбачено, а --reflink=never "
"забезпечує\n"
"виконання стандартного копіювання.\n"

#: src/cp.c:339
msgid ""
"\n"
"As a special case, cp makes a backup of SOURCE when the force and backup\n"
"options are given and SOURCE and DEST are the same name for an existing,\n"
"regular file.\n"
msgstr ""
"\n"
"Коли вказані параметри -f та -b, та ДЖЕРЕЛО збігається з ПРИЗНАЧЕННЯ, cp\n"
"створює резервну копію ПРИЗНАЧЕННЯ.\n"

