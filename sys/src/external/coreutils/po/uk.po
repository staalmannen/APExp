msgstr "%s: нові права доступу %s, а не %s"

#: src/chmod.c:413
#, c-format
msgid ""
"Usage: %s [OPTION]... MODE[,MODE]... FILE...\n"
"  or:  %s [OPTION]... OCTAL-MODE FILE...\n"
"  or:  %s [OPTION]... --reference=RFILE FILE...\n"
msgstr ""
"Використання: %s [ПАРАМЕТР]... РЕЖИМ[,РЕЖИМ]... ФАЙЛ\n"
"       або:    %s [ПАРАМЕТР]... ВІСІМК-РЕЖИМ ФАЙЛ...\n"
"       або:    %s [ПАРАМЕТР]... --reference=ЗФАЙЛ ФАЙЛ...\n"

#: src/chmod.c:419
msgid ""
"Change the mode of each FILE to MODE.\n"
"With --reference, change the mode of each FILE to that of RFILE.\n"
"\n"
msgstr ""
"Змінити режим для всіх файлів на РЕЖИМ.\n"
"З параметром  --reference, змінює контекст безпеки кожного ФАЙЛУ на контекст "
"ЗФАЙЛА.\n"
"\n"

#: src/chmod.c:424 src/chown.c:98
msgid ""
"  -c, --changes\n"
"         like verbose but report only when a change is made\n"
msgstr ""
"  -c, --changes          подібний до verbose, але повідомити про них, лише "
"якщо внесено зміни\n"

#: src/chmod.c:428 src/chown.c:102
msgid ""
"  -f, --silent, --quiet\n"
"         suppress most error messages\n"
msgstr ""
"  -f, --silent, --quiet\n"
"         придушити всі повідомлення про помилки\n"

#: src/chmod.c:436
msgid ""
"      --dereference\n"
"         affect the referent of each symbolic link,\n"
"         rather than the symbolic link itself\n"
msgstr ""
"      --dereference\n"
"         впливає на ціль кожного символічного посилання,\n"
"         а не на саме символічне посилання\n"

#: src/chmod.c:441
msgid ""
"  -h, --no-dereference\n"
"         affect each symbolic link, rather than the referent\n"
msgstr ""
"  -h, --no-dereference   обробити символічні посилання замість файлів, на "
"які вони посилаються\n"

#: src/chmod.c:453
msgid ""
"      --reference=RFILE\n"
"         use RFILE's mode instead of specifying MODE values.\n"
"         RFILE is always dereferenced if a symbolic link.\n"
msgstr ""
"      --reference=ЗФАЙЛа\n"
"         використовувати режим ЗФАЙЛа замість явного\n"
"         вказування РЕЖИМу. ЗФАЙЛа завжди буде розіменовано,\n"
"         якщо це символічне посилання.\n"

#: src/chmod.c:458
msgid ""
"  -R, --recursive\n"
"         change files and directories recursively\n"
msgstr ""
"  -R, --recursive\n"
"         змінювати файли і каталоги рекурсивно\n"

#: src/chmod.c:465
msgid ""
"\n"
"Each MODE is of the form '[ugoa]*([-+=]([rwxXst]*|[ugo]))+|[-+=][0-7]+'.\n"
msgstr ""
"\n"
"РЕЖИМ вказується у формі '[ugoa]*([-+=]([rwxXst]*|[ugo]))+|[-+=][0-7]+'.\n"

#: src/chmod.c:613
#, c-format
msgid "cannot combine mode and --reference options"
msgstr "не можна використовувати разом параметри режиму та --reference"

#: src/chmod.c:644
#, c-format
