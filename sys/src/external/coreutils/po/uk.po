#: src/fmt.c:268
#, c-format
msgid "Usage: %s [-WIDTH] [OPTION]... [FILE]...\n"
msgstr "Використання: %s [-ШИРИНА] [ПАРАМЕТР]... [ФАЙЛ]...\n"

#: src/fmt.c:269
msgid ""
"Reformat each paragraph in the FILE(s), writing to standard output.\n"
"The option -WIDTH is an abbreviated form of --width=DIGITS.\n"
msgstr ""
"Переформатує кожен абзац у ФАЙЛІ(ах) та виводить на стандартне виведення.\n"
"Параметр -ШИРИНА є скороченою формою --width=ЧИСЛО.\n"

#: src/fmt.c:277
msgid ""
"  -c, --crown-margin\n"
"         preserve indentation of first two lines\n"
msgstr "  -c, --crown-margin       зберігати відступи двох перших рядків\n"

#: src/fmt.c:281
msgid ""
"  -p, --prefix=STRING\n"
"         reformat only lines beginning with STRING,\n"
"         reattaching the prefix to reformatted lines\n"
msgstr ""
"  -p, --prefix=РЯДОК\n"
"         форматувати лише рядки, що починаються з РЯДОК,\n"
"         зберігаючи при цьому префікс рядків\n"

#: src/fmt.c:286
msgid ""
"  -s, --split-only\n"
"         split long lines, but do not refill\n"
msgstr "  -s, --split-only         розбивати довгі рядки, але не заповнювати\n"

#: src/fmt.c:290
msgid ""
"  -t, --tagged-paragraph\n"
"         indentation of first line different from second\n"
msgstr ""
"  -t, --tagged-paragraph   відступ першого рядка, відмінний від другого\n"

#: src/fmt.c:294
msgid ""
"  -u, --uniform-spacing\n"
"         one space between words, two after sentences\n"
msgstr ""
"  -u, --uniform-spacing    один пробіл після слова, два після речення\n"

#: src/fmt.c:298
msgid ""
"  -w, --width=WIDTH\n"
"         maximum line width (default of 75 columns)\n"
msgstr ""
"  -w, --width=ЧИСЛО        максимальна довжина рядка (типово 75 позицій)\n"

#: src/fmt.c:304
#, no-c-format
msgid ""
"  -g, --goal=WIDTH\n"
"         goal width (default of 93% of width)\n"
msgstr ""
"  -g, --goal=ДОВЖИНА\n"
"         остаточна довжина (типово 93% oдовжини)\n"

#: src/fmt.c:365
#, c-format
msgid ""
"invalid option -- %c; -WIDTH is recognized only when it is the first\n"
"option; use -w N instead"
msgstr ""
"некоректний параметр -- %c; -ШИРИНА розпізнається, лише якщо це перший\n"
"аргумент, у іншому випадку вказуйте -w N"

#: src/fmt.c:409 src/fmt.c:416
msgid "invalid width"
msgstr "некоректна ширина"

#: src/fold.c:80
msgid "Wrap input lines in each FILE, writing to standard output.\n"
msgstr ""
