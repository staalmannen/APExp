msgid "  -A, --show-all           equivalent to -vET\n"
msgstr "  -A, --show-all           еквівалент -vET\n"

#: src/cat.c:106
msgid "  -b, --number-nonblank    number nonempty output lines, overrides -n\n"
msgstr "  -b, --number-nonblank    кількість непорожніх рядків виводу\n"

#: src/cat.c:109
msgid "  -e                       equivalent to -vE\n"
msgstr "  -e                       еквівалент -vE\n"

#: src/cat.c:112
msgid "  -E, --show-ends          display $ or ^M$ at end of each line\n"
msgstr ""
"  -E, --show-ends         показувати $ або ^M$ наприкінці кожного рядка\n"

#: src/cat.c:115
msgid "  -n, --number             number all output lines\n"
msgstr "  -n, --number             кількість усіх рядків виводу\n"

#: src/cat.c:118
msgid "  -s, --squeeze-blank      suppress repeated empty output lines\n"
msgstr "  -s, --squeeze-blank      не більше ніж один порожній рядок\n"

#: src/cat.c:121
