#: src/env.c:35 src/printenv.c:45 src/whoami.c:33
msgid "Richard Mlynarik"
msgstr "Richard Mlynarik"

#: src/env.c:113
#, c-format
msgid "Usage: %s [OPTION]... [-] [NAME=VALUE]... [COMMAND [ARG]...]\n"
msgstr ""
"Використання: %s [ПАРАМЕТР]... [-] [НАЗВА=ЗНАЧЕННЯ]... [КОМАНДА [АРГ]...]\n"

#: src/env.c:116
msgid "Set each NAME to VALUE in the environment and run COMMAND.\n"
msgstr ""
"Встановлює кожній НАЗВІ відповідне ЗНАЧЕННЯ та запускає КОМАНДУ у цьому\n"
"середовищі.\n"

#: src/env.c:122
msgid ""
"  -a, --argv0=ARG\n"
"         pass ARG as the zeroth argument of COMMAND\n"
msgstr ""
"  -a, --argv0=АРГ\n"
"         передати АРГ як нульових аргумент КОМАНДИ\n"

#: src/env.c:126
msgid ""
"  -i, --ignore-environment\n"
"         start with an empty environment\n"
msgstr "  -i, --ignore-environment   почати з порожнім середовищем\n"

#: src/env.c:134
msgid ""
"  -u, --unset=NAME\n"
"         remove variable from the environment\n"
msgstr "  -u, --unset=НАЗВА          вилучити з середовища НАЗВИ\n"

#: src/env.c:138
msgid ""
"  -C, --chdir=DIR\n"
"         change working directory to DIR\n"
msgstr ""
"  -C, --chdir=КАТАЛОГ\n"
"         змінити робочий каталог на вказаний\n"

#: src/env.c:142
msgid ""
"  -S, --split-string=S\n"
"         process and split S into separate arguments;\n"
"         used to pass multiple arguments on shebang lines\n"
msgstr ""
"  -S, --split-string=S\n"
"         обробити і поділити S на окремі аргументи;\n"
"         використовується для передавання декількох аргументів\n"
"         у рядках із #!\n"

#: src/env.c:147
msgid ""
"      --block-signal[=SIG]\n"
"         block delivery of SIG signal(s) to COMMAND\n"
msgstr ""
"      --block-signal[=СИГНАЛ]\n"
"         блокувати доставлення сигналів СИГНАЛ до КОМАНДИ\n"

#: src/env.c:151
msgid ""
"      --default-signal[=SIG]\n"
"         reset handling of SIG signal(s) to the default\n"
msgstr ""
"      --default-signal[=СИГ]\n"
"         відновити типовий режим обробки сигналів СИГ\n"

#: src/env.c:155
msgid ""
"      --ignore-signal[=SIG]\n"
"         set handling of SIG signal(s) to do nothing\n"
msgstr ""
"      --ignore-signal[=СИГ]\n"
"         встановити режим «нічого не робити» для сигналів СИГ\n"

#: src/env.c:159
msgid ""
"      --list-signal-handling\n"
"         list non default signal handling to standard error\n"
msgstr ""
"      --list-signal-handling\n"
"         вивести список нетипової обробки сигналів до стандартної помилки\n"

#: src/env.c:163
msgid ""
"  -v, --debug\n"
"         print verbose information for each processing step\n"
msgstr ""
"  -v, --debug\n"
"         вивести діагностичні дані для кожного кроку обробки\n"

#: src/env.c:169
msgid ""
"\n"
"A mere - implies -i.  If no COMMAND, print the resulting environment.\n"
msgstr ""
"\n"
"Просто '-' -- синонім для '-i'.  Якщо не вказана КОМАНДА, виводить отримане\n"
"середовища.\n"

#: src/env.c:173
msgid ""
"\n"
"SIG may be a signal name like 'PIPE', or a signal number like '13'.\n"
"Without SIG, all known signals are included.  Multiple signals can be\n"
"comma-separated.  An empty SIG argument is a no-op.\n"
msgstr ""
"\n"
"СИГ може бути назвою сигналу, як PIPE, або номером сигналу, як\n"
"13. Без значення СИГ, буде включено усі відомі сигнали. Сигнали\n"
"у списку слід відокремлювати комами. Порожній аргумент СИГ не\n"
"призводитиме до будь-яких дій.\n"

