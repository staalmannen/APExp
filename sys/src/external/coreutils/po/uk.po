#: src/chcon.c:354
#, c-format
msgid ""
"Usage: %s [OPTION]... CONTEXT FILE...\n"
"  or:  %s [OPTION]... [-u USER] [-r ROLE] [-l RANGE] [-t TYPE] FILE...\n"
"  or:  %s [OPTION]... --reference=RFILE FILE...\n"
msgstr ""
"Використання:  %s [ПАРАМЕТР]... КОНТЕКСТ ФАЙЛ\n"
"       або:    %s [ПАРАМЕТР]... [-u КОРИСТУВАЧ] [-r РОЛЬ] [-l ДІАПАЗОН] [-t "
"ТИП] ФАЙЛ...\n"
"       або:    %s [ПАРАМЕТР]... --reference=ЗФАЙЛ ФАЙЛ...\n"

#: src/chcon.c:360
msgid ""
"Change the SELinux security context of each FILE to CONTEXT.\n"
"With --reference, change the security context of each FILE to that of "
"RFILE.\n"
msgstr ""
"Змінює контекст захисту SELinux кожного файла ФАЙЛ на КОНТЕКСТ.\n"
"З параметром  --reference, змінює контекст безпеки кожного ФАЙЛа на контекст "
"ЗФАЙЛа.\n"

#: src/chcon.c:367 src/chown.c:110
msgid ""
"      --dereference\n"
"         affect the referent of each symbolic link (this is\n"
"         the default), rather than the symbolic link itself\n"
msgstr ""
"      --dereference\n"
"         впливає на ціль кожного символічного посилання,\n"
"         а не на саме символічне посилання\n"

#: src/chcon.c:372
msgid ""
"  -h, --no-dereference\n"
"         affect symbolic links instead of any referenced file\n"
msgstr ""
"  -h, --no-dereference   обробити символічні посилання замість файлів, на "
"які вони посилаються\n"

#: src/chcon.c:376
msgid ""
"  -u, --user=USER\n"
"         set user USER in the target security context\n"
msgstr ""
"  -u, --user=КОРИСТУВАЧ  встановити користувача КОРИСТУВАЧ у цільовому "
"контексті безпеки\n"

#: src/chcon.c:380
msgid ""
"  -r, --role=ROLE\n"
"         set role ROLE in the target security context\n"
msgstr ""
"  -r, --role=РОЛЬ        встановити роль РОЛЬ у цільовому контексті безпеки\n"

#: src/chcon.c:384
msgid ""
"  -t, --type=TYPE\n"
"         set type TYPE in the target security context\n"
msgstr ""
"  -t, --type=ТИП         встановити тип ТИП у цільовому контексті безпеки\n"

#: src/chcon.c:388
msgid ""
"  -l, --range=RANGE\n"
"         set range RANGE in the target security context\n"
msgstr ""
"  -l, --range=ДІАПАЗОН   встановити діапазон ДІАПАЗОН у цільовому контексті "
"безпеки\n"

#: src/chcon.c:392 src/chmod.c:445 src/chown.c:127
msgid ""
"      --no-preserve-root\n"
"         do not treat '/' specially (the default)\n"
msgstr "      --no-preserve-root  не трактувати '/' особливим чином (типово)\n"

#: src/chcon.c:396 src/chmod.c:449 src/chown.c:131
msgid ""
"      --preserve-root\n"
"         fail to operate recursively on '/'\n"
msgstr "      --preserve-root    перешкоджати рекурсивному виконанню на '/'\n"

#: src/chcon.c:400
msgid ""
"      --reference=RFILE\n"
"         use RFILE's security context rather than specifying a CONTEXT "
"value\n"
msgstr ""
"      --reference=ЗФАЙЛА\n"
"         використовувати контекст ЗФАЙЛА замість явного вказування КОНТЕКСТ\n"

#: src/chcon.c:404 src/chown.c:140
msgid ""
"  -R, --recursive\n"
"         operate on files and directories recursively\n"
msgstr ""
"  -R, --recursive\n"
"         обробляти файли і каталоги рекурсивно\n"

#: src/chcon.c:408 src/chmod.c:432 src/chown.c:106
msgid ""
"  -v, --verbose\n"
"         output a diagnostic for every file processed\n"
msgstr ""
"  -v, --verbose          вивести діагностичні дані для кожного з оброблених "
"файлів\n"

#: src/chcon.c:528 src/chmod.c:601 src/chown.c:285
#, c-format
msgid "-R --dereference requires either -H or -L"
msgstr "Для комбінації параметрів -R --dereference слід вказати -H або -L"

#: src/chcon.c:534
#, c-format
msgid "-R -h requires -P"
msgstr "при вказуванні -R -h потрібно вказати -P"

