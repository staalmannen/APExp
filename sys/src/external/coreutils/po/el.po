#~ "                                 κατάλογο σα να ήταν κανονικό αρχείο\n"
#~ "  -i, --interactive            επιβεβαίωση για διαγραφή προορισμών\n"
#~ "  -s, --symbolic               δημιουργία συμβολικών συνδέσμων αντί "
#~ "σθεναρών\n"
#~ "  -S, --suffix=ΚΑΤΑΛΗΞΗ        παράκαμψη της συνηθησμένης κατάληξης "
