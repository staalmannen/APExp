#~ "  -d, -F, --directory          σθεναροί σύνδεσμοι σε καταλόγους (μόνο\n"
#~ "                                 υπερχρήστης)\n"
#~ "  -f, --force                  διαγραφή υπαρχόντων αρχείων προορισμού\n"
#~ "  -n, --no-dereference         μεταχείρηση προορισμών που είναι σύνδεσμος "
