#: src/cksum.c:501
#, c-format
msgid "Print or check %s checksums.\n"
msgstr "显示或检验 %s 校验和。\n"

#: src/cksum.c:504 src/cksum.c:519
msgid "Legacy interface to the cksum utility.\n"
msgstr "cksum 实用程序的旧式接口。\n"

#: src/cksum.c:509
msgid ""
"Print or verify checksums.\n"
"By default use the 32 bit CRC algorithm.\n"
msgstr ""
"显示或验证校验和。\n"
"默认使用 32 位 CRC 算法。\n"

#: src/cksum.c:514
#, c-format
msgid "Print or check %s (%d-bit) checksums.\n"
msgstr "显示或检验 %s（%d 位）校验和。\n"

#: src/cksum.c:526
msgid ""
"  -r\n"
"         use BSD sum algorithm (the default), use 1K blocks\n"
msgstr ""
"  -r\n"
"         使用 BSD 校验和算法（默认），使用 1K 的块\n"

#: src/cksum.c:530
msgid ""
"  -s, --sysv\n"
"         use System V sum algorithm, use 512 bytes blocks\n"
msgstr ""
"  -s, --sysv\n"
"         使用 System V 校验和算法，使用 512 字节的块\n"

#: src/cksum.c:540
msgid ""
"  -a, --algorithm=TYPE\n"
"         select the digest type to use.  See DIGEST below\n"
msgstr ""
"  -a, --algorithm=类型\n"
"         选择要使用的摘要类型。参见下文中的 \"摘要\" 一段\n"

#: src/cksum.c:545
msgid ""
"      --base64\n"
"         emit base64-encoded digests, not hexadecimal\n"
msgstr ""
"      --base64\n"
"         生成 base64 编码的摘要，而不是十六进制\n"

#: src/cksum.c:556
msgid ""
"  -b, --binary\n"
"         read in binary mode (default unless reading tty stdin)\n"
msgstr ""
"  -b, --binary\n"
"         以二进制模式读取（除非从 tty 标准输入读取，否则为默认）\n"

#: src/cksum.c:561
msgid ""
"  -b, --binary\n"
"         read in binary mode\n"
msgstr ""
"  -b, --binary\n"
"         以二进制模式读取\n"

#: src/cksum.c:568
msgid ""
"  -c, --check\n"
"         read checksums from the FILEs and check them\n"
msgstr ""
"  -c, --check\n"
"         从 <文件> 中读取校验和并进行检验\n"

#: src/cksum.c:576
msgid ""
"  -l, --length=BITS\n"
"         digest length in bits; must not exceed the max size\n"
"         and must be a multiple of 8 for blake2b;\n"
"         must be 224, 256, 384, or 512 for sha2 or sha3\n"
msgstr ""
"  -l, --length=位数\n"
"         指定摘要长度（位数）；对于 blake2 算法，不能超出\n"
"         最大值且必须是 8 的倍数；\n"
"         对于 sha2 或 sha3 算法，必须是 224、256、384 或 512\n"

#: src/cksum.c:585
msgid ""
"      --raw\n"
"         emit a raw binary digest, not hexadecimal\n"
msgstr ""
"      --raw\n"
"         生成原始的二进制摘要，而不是十六进制\n"

#: src/cksum.c:590 src/cksum.c:605
msgid ""
"      --tag\n"
"         create a BSD-style checksum\n"
msgstr ""
"      --tag\n"
"         输出 BSD 风格的校验和\n"

#: src/cksum.c:595
msgid ""
"      --tag\n"
"         create a BSD-style checksum (the default)\n"
msgstr ""
"      --tag\n"
"         输出 BSD 风格的校验和（默认）\n"

#: src/cksum.c:600
msgid ""
"      --untagged\n"
"         create a reversed style checksum, without digest type\n"
msgstr ""
"      --untagged\n"
"         输出逆序风格的校验和，且不带摘要类型\n"

#: src/cksum.c:615
msgid ""
"  -t, --text\n"
"         read in text mode (default if reading tty stdin)\n"
msgstr ""
"  -t, --text\n"
"         以纯文本模式读取（从 tty 标准输入读取时为默认）\n"

#: src/cksum.c:620
msgid ""
"  -t, --text\n"
"         read in text mode (default)\n"
msgstr ""
"  -t, --text\n"
"         以纯文本模式读取（默认）\n"

#: src/cksum.c:627
msgid ""
"  -z, --zero\n"
"         end each output line with NUL, not newline,\n"
"         and disable file name escaping\n"
msgstr ""
"  -z, --zero\n"
"         以 NUL 空字符而非换行符结束每个输出行，\n"
"         同时禁用文件名转义\n"

#: src/cksum.c:632
msgid ""
"\n"
"The following five options are useful only when verifying checksums:\n"
msgstr ""
"\n"
"以下五个选项只能在验证校验和时使用：\n"

#: src/cksum.c:636
msgid ""
"      --ignore-missing\n"
"         don't fail or report status for missing files\n"
msgstr ""
"      --ignore-missing\n"
"         找不到文件时，不要退出或者返回失败状态\n"

#: src/cksum.c:640
msgid ""
"      --quiet\n"
