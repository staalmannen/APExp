msgstr "用法：%s [选项]... [文件]...\n"

#: src/cat.c:97
msgid "Concatenate FILE(s) to standard output.\n"
msgstr "连接一个或多个 <文件> 并输出到标准输出。\n"

#: src/cat.c:103
msgid "  -A, --show-all           equivalent to -vET\n"
msgstr "  -A, --show-all           等价于 -vET\n"

#: src/cat.c:106
msgid "  -b, --number-nonblank    number nonempty output lines, overrides -n\n"
msgstr "  -b, --number-nonblank    对非空输出行编号，使 -n 失效\n"

#: src/cat.c:109
msgid "  -e                       equivalent to -vE\n"
msgstr "  -e                       等价于 -vE\n"

#: src/cat.c:112
msgid "  -E, --show-ends          display $ or ^M$ at end of each line\n"
msgstr "  -E, --show-ends          在每行行末显示 $ 或 ^M$\n"

#: src/cat.c:115
msgid "  -n, --number             number all output lines\n"
msgstr "  -n, --number             对输出的所有行编号\n"

#: src/cat.c:118
msgid "  -s, --squeeze-blank      suppress repeated empty output lines\n"
msgstr "  -s, --squeeze-blank      不重复输出空行\n"

#: src/cat.c:121
msgid "  -t                       equivalent to -vT\n"
msgstr "  -t                       等价于 -vT\n"

#: src/cat.c:124
msgid "  -T, --show-tabs          display TAB characters as ^I\n"
msgstr "  -T, --show-tabs          将 TAB 显示为 ^I\n"

#: src/cat.c:127
msgid "  -u                       (ignored)\n"
msgstr "  -u                       （被忽略）\n"

#: src/cat.c:130
msgid ""
"  -v, --show-nonprinting   use ^ and M- notation, except for LFD and TAB\n"
msgstr "  -v, --show-nonprinting   使用 ^ 和 M- 表示法，LFD 和 TAB 字符除外\n"

#: src/cat.c:135
#, c-format
msgid ""
"\n"
"Examples:\n"
"  %s f - g  Output f's contents, then standard input, then g's contents.\n"
"  %s        Copy standard input to standard output.\n"
msgstr ""
"\n"
"示例：\n"
"  %s f - g  先输出 f 的内容，然后输出标准输入的内容，最后输出 g 的内容。\n"
"  %s        将标准输入的内容复制到标准输出。\n"

