#: src/chmod.c:413
#, c-format
msgid ""
"Usage: %s [OPTION]... MODE[,MODE]... FILE...\n"
"  or:  %s [OPTION]... OCTAL-MODE FILE...\n"
"  or:  %s [OPTION]... --reference=RFILE FILE...\n"
msgstr ""
"用法：%s [选项]... 模式[,模式]... 文件...\n"
"　或：%s [选项]... 八进制模式 文件...\n"
"　或：%s [选项]... --reference=参考文件 文件...\n"

#: src/chmod.c:419
msgid ""
"Change the mode of each FILE to MODE.\n"
"With --reference, change the mode of each FILE to that of RFILE.\n"
"\n"
msgstr ""
"将每个 <文件> 的模式变更为指定 <模式>。\n"
"使用 --reference 时，把每个 <文件> 的模式设置为与 <参考文件> 相同。\n"
"\n"

#: src/chmod.c:424 src/chown.c:98
msgid ""
"  -c, --changes\n"
"         like verbose but report only when a change is made\n"
msgstr ""
"  -c, --changes\n"
"         类似 verbose 选项，但仅在做出修改时进行报告\n"

#: src/chmod.c:428 src/chown.c:102
msgid ""
"  -f, --silent, --quiet\n"
"         suppress most error messages\n"
msgstr ""
"  -f, --silent, --quiet\n"
"         不显示大多数错误消息\n"

#: src/chmod.c:436
msgid ""
"      --dereference\n"
"         affect the referent of each symbolic link,\n"
"         rather than the symbolic link itself\n"
msgstr ""
"      --dereference\n"
"         影响每个符号链接指向的文件，\n"
"         而非符号链接本身\n"

#: src/chmod.c:441
msgid ""
"  -h, --no-dereference\n"
"         affect each symbolic link, rather than the referent\n"
msgstr ""
"  -h, --no-dereference\n"
"         影响每个符号链接，而非其指向的文件\n"

#: src/chmod.c:453
msgid ""
"      --reference=RFILE\n"
"         use RFILE's mode instead of specifying MODE values.\n"
"         RFILE is always dereferenced if a symbolic link.\n"
msgstr ""
"      --reference=参考文件\n"
"         使用 <参考文件> 的模式，而非指定 <模式>。\n"
"         如果 <参考文件> 是符号链接，则总是解引用它。\n"

#: src/chmod.c:458
msgid ""
"  -R, --recursive\n"
"         change files and directories recursively\n"
msgstr ""
"  -R, --recursive\n"
"         递归修改文件和目录\n"

#: src/chmod.c:465
msgid ""
"\n"
"Each MODE is of the form '[ugoa]*([-+=]([rwxXst]*|[ugo]))+|[-+=][0-7]+'.\n"
msgstr ""
"\n"
"每个 <模式> 都应当符合此格式：\"[ugoa]*([-+=]([rwxXst]*|[ugo]))+|[-+=][0-7]+"
"\"。\n"

#: src/chmod.c:613
#, c-format
msgid "cannot combine mode and --reference options"
msgstr "无法同时指定模式和 --reference 选项"

#: src/chmod.c:644
#, c-format
msgid "invalid mode: %s"
msgstr "无效的模式：%s"

#: src/chown-core.c:171
#, c-format
