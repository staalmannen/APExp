#, c-format
msgid "integer overflow"
msgstr "整数溢出"

#: src/pr.c:916
#, c-format
msgid "'--pages=FIRST_PAGE[:LAST_PAGE]' missing argument"
msgstr "\"--pages=首页[:末页]\" 缺少参数"

#: src/pr.c:918
#, c-format
msgid "invalid page range %s"
msgstr "页码范围 %s 无效"

#: src/pr.c:979
msgid "'-l PAGE_LENGTH' invalid number of lines"
msgstr "\"-l 页面长度\" 中含有无效的行数"

#: src/pr.c:995
msgid "'-N NUMBER' invalid starting line number"
msgstr "\"-N 编号\" 中含有无效的起始行号"

#: src/pr.c:999
msgid "'-o MARGIN' invalid line offset"
msgstr "\"-o 页边距\" 中含有无效的行偏移量"

#: src/pr.c:1036
msgid "'-w PAGE_WIDTH' invalid number of characters"
msgstr "\"-w 页面宽度\" 中含有无效的字符数"

#: src/pr.c:1046
msgid "'-W PAGE_WIDTH' invalid number of characters"
msgstr "\"-W 页面宽度\" 中含有无效的字符数"

#: src/pr.c:1075
#, c-format
msgid "cannot specify number of columns when printing in parallel"
msgstr "并排打印各文件时不能指定列数"

#: src/pr.c:1079
#, c-format
msgid "cannot specify both printing across and printing in parallel"
msgstr "无法同时指定横向打印和并排打印"

#: src/pr.c:1174
#, c-format
msgid "'-%c': Invalid argument: %s"
msgstr "\"-%c\": 无效的参数：%s"

#: src/pr.c:1194
#, c-format
msgid "'-%c' extra characters or invalid number in the argument: %s"
msgstr "\"-%c\" 的参数 %s 中有多余的字符或无效的数字"

#: src/pr.c:1298
#, c-format
msgid "page width too narrow"
msgstr "页宽过窄"

#: src/pr.c:2368
#, c-format
msgid "starting page number %ju exceeds page count %ju"
msgstr "起始页码 %ju 超出了总页数 %ju"

#: src/pr.c:2394
#, c-format
msgid "page number overflow"
msgstr "页码溢出"

#: src/pr.c:2399
#, c-format
msgid "Page %ju"
msgstr "第 %ju 页"

#: src/pr.c:2770
msgid "Paginate or columnate FILE(s) for printing.\n"
msgstr "对 <文件> 进行分页或分列以便后续打印使用。\n"

#: src/pr.c:2777
msgid ""
"\n"
"  +FIRST_PAGE[:LAST_PAGE], --pages=FIRST_PAGE[:LAST_PAGE]\n"
"         begin [stop] printing with page FIRST_[LAST_]PAGE\n"
msgstr ""
"\n"
"  +首页[:末页], --pages=首页[:末页]\n"
"         在指定的首页/末页处开始/停止打印\n"

#: src/pr.c:2781
msgid ""
"  -COLS, --columns=COLS\n"
"         output COLS columns and print columns down, unless -a is used.\n"
"         Balance number of lines in the columns on each page\n"
msgstr ""
"  -列数, --columns=列数\n"
"         将输出分为 <列数> 列，且从上到下打印，除非指定了 -a 选项。\n"
"         自动平衡每一页中每列占用的行数。\n"

#: src/pr.c:2786
msgid ""
"  -a, --across\n"
"         print columns across rather than down, used together with -COLS\n"
msgstr ""
"  -a, --across\n"
"         从左到右打印，而不是从上到下。须和 \"-列数\" 选项同时使用\n"

#: src/pr.c:2790
msgid ""
"  -c, --show-control-chars\n"
"         use hat notation (^G) and octal backslash notation\n"
msgstr ""
"  -c, --show-control-chars\n"
"         使用帽子表示法（如 ^G）和八进制反斜杠表示法表示控制字符\n"

#: src/pr.c:2794
msgid ""
"  -d, --double-space\n"
"         double space the output\n"
msgstr ""
"  -d, --double-space\n"
"         使用双倍行距进行输出\n"

#: src/pr.c:2798
msgid ""
"  -D, --date-format=FORMAT\n"
"         use FORMAT for the header date\n"
msgstr ""
"  -D, --date-format=格式\n"
"         指定页眉日期的 <格式>\n"

#: src/pr.c:2802
msgid ""
"  -e[CHAR[WIDTH]], --expand-tabs[=CHAR[WIDTH]]\n"
"         expand input CHARs (TABs) to tab WIDTH (8)\n"
msgstr ""
"  -e[字符[宽度]], --expand-tabs[=字符[宽度]]\n"
"         以指定的制表符 <宽度>（默认为 8）展开输入中的 <字符>（默认为制表"
"符）\n"

#: src/pr.c:2806
msgid ""
"  -F, -f, --form-feed\n"
"         use form feeds instead of newlines to separate pages\n"
"         (by a 3-line page header with -F or a 5-line header\n"
"         and trailer without -F)\n"
msgstr ""
"  -F, -f, --form-feed\n"
"         使用换页符代替换行符作为页面分隔符\n"
"         （使用 -F 选项时页眉为 3 行，不使用时页眉和页脚为 5 行）\n"

#: src/pr.c:2812
msgid ""
"  -h, --header=HEADER\n"
"         use a centered HEADER instead of filename in page header,\n"
"         -h \"\" prints a blank line, don't use -h\"\"\n"
msgstr ""
"  -h, --header=页眉\n"
"         居中打印 <页眉> 作为页眉，而不是打印文件名，\n"
"         使用 -h \"\" 打印一个空行，不要使用 -h\"\"\n"

#: src/pr.c:2817
msgid ""
"  -i[CHAR[WIDTH]], --output-tabs[=CHAR[WIDTH]]\n"
"         replace spaces with CHARs (TABs) to tab WIDTH (8)\n"
msgstr ""
"  -i[字符[宽度]], --output-tabs[=字符[宽度]]\n"
"         以指定的制表符 <宽度>（默认为 8）将空格换成 <字符>（默认为制表符）\n"

#: src/pr.c:2821
msgid ""
"  -J, --join-lines\n"
"         merge full lines, turns off -W line truncation,\n"
"         no column alignment, --sep-string[=STRING] sets separators\n"
msgstr ""
"  -J, --join-lines\n"
"         完整地合并行，关闭 -W 选项的行截断，\n"
"         不使用列对齐，使用 --sep-string[=字符串] 设置分隔符\n"

#: src/pr.c:2826
msgid ""
"  -l, --length=PAGE_LENGTH\n"
"         set the page length to PAGE_LENGTH (66) lines\n"
"         (default number of lines of text 56, and with -F 63).\n"
"         implies -t if PAGE_LENGTH <= 10\n"
msgstr ""
"  -l, --length=页面长度\n"
"         设置页面长度为 <页面长度> 行（默认为 66）\n"
"         （默认文本行数为 56，当启用 -F 时为 63）。\n"
"         如果 <页面长度> 小于或等于 10，则隐含启用 -t\n"

#: src/pr.c:2832
msgid ""
"  -m, --merge\n"
"         print all files in parallel, one in each column,\n"
"         truncate lines, but join lines of full length with -J\n"
msgstr ""
"  -m, --merge\n"
"         并排打印所有文件，每个文件占用一列，\n"
"         会截断行，但是如果指定了 -J，则完整地合并行\n"

#: src/pr.c:2837
msgid ""
"  -n[SEP[DIGITS]], --number-lines[=SEP[DIGITS]]\n"
"         number lines, use DIGITS (5) digits, then SEP (TAB),\n"
"         default counting starts with 1st line of input file\n"
msgstr ""
"  -n[分隔符[位数]], --number-lines[=分隔符[位数]]\n"
"         显示行号，使用指定的 <位数>（默认为 5），后接 <分隔符>\n"
"         （默认为制表符），默认从输入文件的第一行开始计数\n"

#: src/pr.c:2842
msgid ""
"  -N, --first-line-number=NUMBER\n"
"         start counting with NUMBER at 1st line of first\n"
"         page printed (see +FIRST_PAGE)\n"
msgstr ""
"  -N, --first-line-number=编号\n"
"         从打印的首页的首行以指定的 <编号> 开始计数（参见 \"+首页\"）\n"

#: src/pr.c:2847
msgid ""
"  -o, --indent=MARGIN\n"
"         offset each line with MARGIN (zero) spaces, do not\n"
"         affect -w or -W, MARGIN will be added to PAGE_WIDTH\n"
msgstr ""
"  -o, --indent=页边距\n"
"         将每行缩进 <页边距>（默认为 0）个空格，\n"
"         不影响 -w 或 -W，<页边距> 的值会被加进 <页面宽度> 中\n"

#: src/pr.c:2852
msgid ""
"  -r, --no-file-warnings\n"
"         omit warning when a file cannot be opened\n"
msgstr ""
"  -r, --no-file-warnings\n"
"         当文件无法打开时不显示警告\n"

#: src/pr.c:2856
msgid ""
"  -s[CHAR], --separator[=CHAR]\n"
"         separate columns by a single character, default for CHAR\n"
"         is the <TAB> character without -w and 'no char' with -w.\n"
"         -s[CHAR] turns off line truncation of all 3 column\n"
"         options (-COLS|-a -COLS|-m) except -w is set\n"
msgstr ""
"  -s[字符], --separator[=字符]\n"
"         由单个 <字符> 分隔各列，未使用 -w 时默认为制表符，使用 -w\n"
"         时默认没有分隔符。除非使用了 -w，否则 -s[字符] 会禁用全部\n"
"         3 种分列选项（-列数|-a -列数|-m）的行截断\n"

#: src/pr.c:2863
msgid ""
"  -S[STRING], --sep-string[=STRING]\n"
"         separate columns by STRING,\n"
"         without -S: Default separator <TAB> with -J and <space>\n"
"         otherwise (same as -S\" \"), no effect on column options\n"
msgstr ""
"  -S[字符串], --sep-string[=字符串]\n"
"         使用 <字符串> 分隔各列，\n"
"         不使用 -S 时：使用 -J 时，使用默认的制表符作为分隔符，\n"
"         否则使用空格作为分隔符（等于 -S\" \"），对分列选项无影响\n"

#: src/pr.c:2869
msgid ""
"  -t, --omit-header\n"
"         omit page headers and trailers; implied if PAGE_LENGTH <= 10\n"
msgstr ""
"  -t, --omit-header\n"
"         省略页眉和页脚；在 <页面长度> <= 10 时被隐含启用\n"

#: src/pr.c:2873
msgid ""
"  -T, --omit-pagination\n"
"         omit page headers and trailers,\n"
"         eliminate any pagination by form feeds set in input files\n"
msgstr ""
"  -T, --omit-pagination\n"
"         省略页眉和页脚，并消除输入文件中的换页符引起的分页\n"

#: src/pr.c:2878
msgid ""
"  -v, --show-nonprinting\n"
"         use octal backslash notation\n"
msgstr ""
"  -v, --show-nonprinting\n"
"         使用八进制反斜杠表示法\n"

#: src/pr.c:2882
msgid ""
"  -w, --width=PAGE_WIDTH\n"
"         set page width to PAGE_WIDTH (72) characters for\n"
"         multiple text-column output only, -s[char] turns off (72)\n"
msgstr ""
"  -w, --width=页面宽度\n"
"         仅将多列文本输出的页宽设置为 <页面宽度>（默认为 72）\n"
"         个字符，-s[字符] 选项会禁用此选项默认的页宽限制 72。\n"

#: src/pr.c:2887
msgid ""
"  -W, --page-width=PAGE_WIDTH\n"
"         set page width to PAGE_WIDTH (72) characters always,\n"
"         truncate lines, except -J option is set,\n"
"         no interference with -S or -s\n"
msgstr ""
"  -W, --page-width=页面宽度\n"
"         将所有情况下的页宽设置为 <页面宽度>（默认为 72）个字符，\n"
"         除非使用了 -J 选项，否则会截断行。不受 -S 或 -s 影响\n"

#: src/printenv.c:62
#, c-format
msgid ""
"Usage: %s [OPTION] [VARIABLE]...\n"
"Print the values of the specified environment VARIABLE(s).\n"
"If no VARIABLE is specified, print name and value pairs for them all.\n"
"\n"
msgstr ""
"用法： %s [选项] [变量]...\n"
"显示指定的环境 <变量> 的值。\n"
"如果没有指定 <变量>，则打印出所有变量的名称和值。\n"
"\n"

#: src/printf.c:44
#, c-format
msgid ""
"warning: %s: character(s) following character constant have been ignored"
msgstr "警告：%s: 跟随在字符常量后的其它字符已被忽略"

#: src/printf.c:53
#, c-format
msgid ""
"Usage: %s FORMAT [ARGUMENT]...\n"
"  or:  %s OPTION\n"
msgstr ""
"用法：%s 格式 [参数]\n"
"　或：%s 选项\n"

#: src/printf.c:58
msgid ""
"Print ARGUMENT(s) according to FORMAT, or execute according to OPTION:\n"
"\n"
msgstr ""
"按照指定 <格式> 打印 <参数>，或执行以下 <选项> 对应的功能：\n"
"\n"

#: src/printf.c:64
msgid ""
"\n"
"FORMAT controls the output as in C printf.  Interpreted sequences are:\n"
"\n"
"  \\\"      double quote\n"
msgstr ""
"\n"
"<格式> 用于控制输出，用法同 C 中的 printf 函数。支持解释的序列有：\n"
"\n"
"  \\\"      双引号\n"

#: src/printf.c:82
msgid ""
"  \\NNN    byte with octal value NNN (1 to 3 digits)\n"
"  \\xHH    byte with hexadecimal value HH (1 to 2 digits)\n"
"  \\uHHHH  Unicode (ISO/IEC 10646) character with hex value HHHH (4 digits)\n"
"  \\UHHHHHHHH  Unicode character with hex value HHHHHHHH (8 digits)\n"
msgstr ""
"  \\NNN    以 1 至 3 位八进制数 NNN 表示的字节\n"
"  \\xHH    以 1 至 2 位十六进制数 HH 表示的字节\n"
"  \\uHHHH  以 4 位十六进制数 HHHH 表示的 Unicode (ISO/IEC 10646) 字符\n"
"  \\UHHHHHHHH  以 8 位十六进制数 HHHHHHHH 表示的 Unicode 字符\n"

#: src/printf.c:88
msgid ""
"  %%      a single %\n"
"  %b      ARGUMENT as a string with '\\' escapes interpreted,\n"
"          except that octal escapes should have a leading 0 like \\0NNN\n"
"  %q      ARGUMENT is printed in a format that can be reused as shell "
"input,\n"
"          escaping non-printable characters with the POSIX $'' syntax\n"
"\n"
"and all C format specifications ending with one of diouxXfeEgGcs, with\n"
"ARGUMENTs converted to proper type first.  Variable widths are handled.\n"
msgstr ""
"  %%      一个 \"%\"\n"
"  %b      将 <参数> 视为字符串打印，且解释以 \"\\\" 开头的转义序列，\n"
"          例外：八进制字节的转义序列要有前导 0，例如 \\0NNN\n"
"  %q      <参数> 以可重用作 shell 输入的格式打印，\n"
"          不可打印字符按照 POSIX $'' 语法进行转义。\n"
"\n"
"以及所有以 diouxXfeEgGcs 之一结尾的 C 格式说明符，这种情况下将首先把 <参数>\n"
"转换为合适的类型。支持指定变量的宽度。\n"

#: src/printf.c:109
#, c-format
msgid "%s: expected a numeric value"
msgstr "%s: 需要一个数值"

#: src/printf.c:119
#, c-format
msgid "%s: value not completely converted"
msgstr "%s: 给定值不能被完全转换"

#: src/printf.c:232 src/printf.c:259
#, c-format
msgid "missing hexadecimal number in escape"
msgstr "转义序列中缺少十六进制数"

#: src/printf.c:266
#, c-format
msgid "invalid universal character name \\%c%0*x"
msgstr "无效的 Unicode 字符名称 \\%c%0*x"

#: src/printf.c:607
#, c-format
msgid "invalid field width: %s"
msgstr "无效的字段宽度：%s"

#: src/printf.c:638
#, c-format
msgid "invalid precision: %s"
msgstr "无效的精度：%s"

#: src/printf.c:663
#, c-format
msgid "%.*s: invalid conversion specification"
msgstr "%.*s: 无效的转换说明符"

#: src/printf.c:748
#, c-format
msgid "warning: ignoring excess arguments, starting with %s"
msgstr "警告：已忽略从 %s 开始的过多的参数"

#. TRANSLATORS: Please translate "F. Pinard" to "François Pinard"
#. if "ç" (c-with-cedilla) is available in the translation's character
#. set and encoding.
#. This is a proper name. See the gettext manual, section Names.
#: src/ptx.c:41
msgid "F. Pinard"
msgstr "François Pinard"

#: src/ptx.c:406
#, c-format
msgid "%s (for regexp %s)"
msgstr "%s（正则表达式 %s）"

#: src/ptx.c:794
#, c-format
msgid "error: regular expression has a match of length zero: %s"
msgstr "错误：正则表达式匹配的长度为零：%s"

#: src/ptx.c:1672
#, c-format
msgid ""
"Usage: %s [OPTION]... [INPUT]...   (without -G)\n"
"  or:  %s -G [OPTION]... [INPUT [OUTPUT]]\n"
msgstr ""
"用法：%s [选项]... [输入]...  （不带 -G 选项时）\n"
"　或：%s -G [选项]... [输入 [输出]]\n"

#: src/ptx.c:1676
msgid ""
"Output a permuted index, including context, of the words in the input "
"files.\n"
msgstr "输出输入文件内的单词的轮排索引，包括上下文。\n"

#: src/ptx.c:1683
msgid ""
"  -A, --auto-reference           output automatically generated references\n"
msgstr "  -A, --auto-reference           输出自动生成的参照\n"

#: src/ptx.c:1686
msgid "  -G, --traditional              behave more like System V 'ptx'\n"
msgstr ""
"  -G, --traditional              使程序的行为更接近 System V 的 \"ptx\"\n"

#: src/ptx.c:1689
msgid ""
"  -F, --flag-truncation=STRING   use STRING for flagging line truncations.\n"
"                                 The default is '/'\n"
msgstr ""
"  -F, --flag-truncation=字符串   使用 <字符串> 标记行的截断位置。\n"
"                                 默认值为 \"/\"\n"

#: src/ptx.c:1693
msgid "  -M, --macro-name=STRING        macro name to use instead of 'xx'\n"
msgstr "  -M, --macro-name=字符串        指定代替 \"xx\" 的宏名\n"

#: src/ptx.c:1696
msgid "  -O, --format=roff              generate output as roff directives\n"
msgstr "  -O, --format=roff              生成 roff 格式输出\n"

#: src/ptx.c:1699
msgid ""
"  -R, --right-side-refs          put references at right, not counted in -w\n"
msgstr "  -R, --right-side-refs          将参照放置在右侧，不计入 -w 宽度内\n"

#: src/ptx.c:1702
msgid "  -S, --sentence-regexp=REGEXP   for end of lines or end of sentences\n"
msgstr "  -S, --sentence-regexp=正则     用于匹配行末或句末\n"

#: src/ptx.c:1705
msgid "  -T, --format=tex               generate output as TeX directives\n"
msgstr "  -T, --format=tex               生成 TeX 格式输出\n"

#: src/ptx.c:1708
msgid "  -W, --word-regexp=REGEXP       use REGEXP to match each keyword\n"
msgstr "  -W, --word-regexp=正则         使用 <正则> 匹配每个关键字\n"

#: src/ptx.c:1711
msgid "  -b, --break-file=FILE          word break characters in this FILE\n"
msgstr ""
"  -b, --break-file=文件          使用 <文件> 中的字符作为单词分隔字符\n"

#: src/ptx.c:1714
msgid ""
"  -f, --ignore-case              fold lower case to upper case for sorting\n"
msgstr "  -f, --ignore-case              排序时忽略大小写\n"

#: src/ptx.c:1717
msgid ""
"  -g, --gap-size=NUMBER          gap size in columns between output fields\n"
msgstr "  -g, --gap-size=数值            指定多个输出字段之间的列间隙大小\n"

#: src/ptx.c:1720
msgid "  -i, --ignore-file=FILE         read ignore word list from FILE\n"
msgstr "  -i, --ignore-file=文件         从 <文件> 中读取忽略单词列表\n"

#: src/ptx.c:1723
msgid "  -o, --only-file=FILE           read only word list from this FILE\n"
msgstr "  -o, --only-file=文件           从 <文件> 中读取仅限单词列表\n"

#: src/ptx.c:1726
msgid ""
"  -r, --references               first field of each line is a reference\n"
msgstr "  -r, --references               将每行的第一个字段改为参照\n"

#: src/ptx.c:1729
msgid ""
"  -t, --typeset-mode             change the default width from 72 to 100\n"
msgstr "  -t, --typeset-mode             将默认宽度从 72 改成 100\n"

#: src/ptx.c:1732
msgid ""
"  -w, --width=NUMBER             output width in columns, reference "
"excluded\n"
msgstr ""
"  -w, --width=数值               输出的宽度（最大列数），不计参照占用的宽度\n"

#: src/ptx.c:1830
#, c-format
msgid "invalid gap width: %s"
msgstr "无效的间隙宽度：%s"

#: src/ptx.c:1858
#, c-format
msgid "invalid line width: %s"
msgstr "无效的行宽：%s"

#: src/pwd.c:56
msgid ""
"Print the full filename of the current working directory.\n"
"\n"
msgstr ""
"输出当前工作目录的完整名称。\n"
"\n"

#: src/pwd.c:60
msgid ""
"  -L, --logical\n"
"         use PWD from environment, even if it contains symlinks\n"
msgstr ""
"  -L, --logical\n"
"         使用环境变量 PWD 的值，即使其中包含符号链接\n"

#: src/pwd.c:64
msgid ""
"  -P, --physical\n"
"         resolve all symlinks\n"
msgstr ""
"  -P, --physical\n"
"         解析所有符号链接\n"

#: src/pwd.c:70
msgid ""
"\n"
"If no option is specified, -P is assumed.\n"
msgstr ""
"\n"
"如果没有指定任何选项，则假定启用 -P。\n"

#: src/pwd.c:163
#, c-format
msgid "failed to chdir to %s"
msgstr "无法切换到目录 %s"

#: src/pwd.c:168 src/pwd.c:274 src/split.c:532
#, c-format
msgid "failed to stat %s"
msgstr "对 %s 调用 stat 失败"

#: src/pwd.c:232
#, c-format
msgid "couldn't find directory entry in %s with matching i-node"
msgstr "无法在 %s 中找到匹配 inode 的目录项"

#: src/pwd.c:359
#, c-format
msgid "ignoring non-option arguments"
msgstr "忽略不是选项的参数"

#. This is a proper name. See the gettext manual, section Names.
#: src/readlink.c:31
msgid "Dmitry V. Levin"
msgstr "Dmitry V. Levin"

#: src/readlink.c:61 src/realpath.c:70 src/shred.c:170 src/stat.c:1755
#: src/touch.c:216
#, c-format
msgid "Usage: %s [OPTION]... FILE...\n"
msgstr "用法：%s [选项]... 文件...\n"

#: src/readlink.c:62
msgid ""
"Print value of a symbolic link or canonical file name\n"
"\n"
msgstr ""
"输出符号链接的值或规范化文件名。\n"
"\n"

#: src/readlink.c:64
msgid ""
"  -f, --canonicalize\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively;\n"
"         all but the last component must exist\n"
msgstr ""
"  -f, --canonicalize\n"
"         通过递归地跟随指定文件名的\n"
"         各个组成部分的符号链接来规范化文件名；\n"
"         除最后一部分外，文件名的所有组成部分必须存在\n"

#: src/readlink.c:70
msgid ""
"  -e, --canonicalize-existing\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively;\n"
"         all components must exist\n"
msgstr ""
"  -e, --canonicalize-existing\n"
"         通过递归地跟随指定文件名的\n"
"         各个组成部分的符号链接来规范化文件名；\n"
"         文件名的所有组成部分必须存在\n"

#: src/readlink.c:76
msgid ""
"  -m, --canonicalize-missing\n"
"         canonicalize by following every symlink\n"
"         in every component of the given name recursively,\n"
"         without requirements on components existence\n"
msgstr ""
"  -m, --canonicalize-missing\n"
"         通过递归地跟随指定文件名的\n"
"         各个组成部分的符号链接来规范化文件名，\n"
"         但不对各个组成部分的存在性作出要求\n"

#: src/readlink.c:82
msgid ""
"  -n, --no-newline\n"
"         do not output the trailing delimiter\n"
msgstr ""
"  -n, --no-newline\n"
"         不输出末尾的换行符\n"

#: src/readlink.c:86
msgid "  -q, --quiet\n"
msgstr "  -q, --quiet\n"

#: src/readlink.c:89
msgid ""
"  -s, --silent\n"
"         suppress most error messages\n"
"         (on by default if POSIXLY_CORRECT is not set)\n"
msgstr ""
"  -s, --silent\n"
"         不输出大多数的错误消息\n"
"         （当 POSIXLY_CORRECT 未设置时，默认启用）\n"

#: src/readlink.c:94
msgid ""
"  -v, --verbose\n"
"         report error messages\n"
"         (on by default if POSIXLY_CORRECT is set)\n"
msgstr ""
"  -v, --verbose\n"
"         报告错误消息\n"
"         （当 POSIXLY_CORRECT 已设置时，默认启用）\n"

#: src/readlink.c:169
#, c-format
msgid "ignoring --no-newline with multiple arguments"
msgstr "指定了多个参数，忽略 --no-newline 选项"

#: src/realpath.c:71
msgid "Print the resolved absolute file name.\n"
msgstr "打印经过解析的绝对路径文件名。\n"

#: src/realpath.c:74
msgid ""
"  -E, --canonicalize           all but the last component must exist "
"(default)\n"
msgstr ""
"  -E, --canonicalize           路径中除最后一部分外的所有组成部分\n"
"                               必须存在（默认）\n"

#: src/realpath.c:78
msgid "  -e, --canonicalize-existing  all components of the path must exist\n"
msgstr "  -e, --canonicalize-existing  路径中的所有组成部分必须存在\n"

#: src/realpath.c:81
msgid ""
"  -m, --canonicalize-missing   no path components need exist or be a "
"directory\n"
msgstr ""
"  -m, --canonicalize-missing   路径中的各个组成部分若不存在则视为目录\n"

#: src/realpath.c:85
msgid ""
"  -L, --logical                resolve '..' components before symlinks\n"
msgstr ""
"  -L, --logical                在解析符号链接之前先处理路径中的 '..' 组成部"
"分\n"

#: src/realpath.c:88
msgid ""
"  -P, --physical               resolve symlinks as encountered (default)\n"
msgstr "  -P, --physical               遇到符号链接则立即解析（默认）\n"

#: src/realpath.c:91
msgid "  -q, --quiet                  suppress most error messages\n"
msgstr "  -q, --quiet                  不输出大多数错误消息\n"

#: src/realpath.c:94
msgid ""
"      --relative-to=DIR        print the resolved path relative to DIR\n"
msgstr "      --relative-to=目录       相对于 <目录> 输出解析后的路径\n"

#: src/realpath.c:97
msgid ""
"      --relative-base=DIR      print absolute paths unless paths below DIR\n"
msgstr ""
"      --relative-base=目录     输出绝对路径，除非它是 <目录> 的子目录\n"

#: src/realpath.c:100
msgid "  -s, --strip, --no-symlinks   don't expand symlinks\n"
msgstr "  -s, --strip, --no-symlinks   不要解析符号链接\n"

#: src/realpath.c:103
msgid ""
"  -z, --zero                   end each output line with NUL, not newline\n"
msgstr "  -z, --zero                   以 NUL 字符而非换行符结束每个输出行\n"

#: src/relpath.c:130
msgid "generating relative path"
msgstr "生成相对路径"

#: src/remove.c:278
#, c-format
msgid "%s: descend into write-protected directory %s? "
msgstr "%s: 是否进入有写保护的目录 %s？"

#: src/remove.c:279
#, c-format
msgid "%s: descend into directory %s? "
msgstr "%s: 是否进入目录 %s？"

#: src/remove.c:298
#, c-format
msgid "%s: attempt removal of inaccessible directory %s? "
msgstr "%s: 是否尝试删除不可访问的目录 %s？"

#. TRANSLATORS: In the next two strings the second %s is
#. replaced by the type of the file.  To avoid grammatical
#. problems, it may be more convenient to translate these
#. strings instead as: "%1$s: %3$s is write-protected and
#. is of type '%2$s' -- remove it? ".
#: src/remove.c:316
#, c-format
msgid "%s: remove write-protected %s %s? "
msgstr "%s: 是否删除有写保护的%s %s？"

#: src/remove.c:317
#, c-format
msgid "%s: remove %s %s? "
msgstr "%s: 是否删除%s %s？"

#: src/remove.c:399
#, c-format
msgid "removed directory %s\n"
msgstr "已删除目录 %s\n"

#: src/remove.c:470
#, c-format
msgid "refusing to remove %s or %s directory: skipping %s"
msgstr "拒绝删除 %s 或 %s 目录：跳过 %s"

#: src/remove.c:499
#, c-format
msgid "failed to stat %s: skipping %s"
msgstr "对 %s 调用 stat 失败：跳过 %s"

#: src/remove.c:512 src/remove.c:562
#, c-format
msgid "skipping %s, since it's on a different device"
msgstr "跳过 %s，因为它位于另一个设备上"

#: src/remove.c:514
#, c-format
msgid "and --preserve-root=all is in effect"
msgstr "且 --preserve-root=all 正在生效"

#: src/remove.c:583
#, c-format
msgid "traversal failed: %s"
msgstr "遍历失败：%s"

#: src/remove.c:589
#, c-format
msgid ""
"unexpected failure: fts_info=%d: %s\n"
"please report to %s"
msgstr ""
"意外的错误：fts_info=%d: %s\n"
"请报告给 %s"

#: src/rm.c:115
#, c-format
msgid "Try '%s ./%s' to remove the file %s.\n"
msgstr "尝试使用 \"%s ./%s\" 删除文件 %s。\n"

#: src/rm.c:132
msgid ""
"Remove (unlink) the FILE(s).\n"
"\n"
msgstr ""
"删除 (unlink) 一个或多个 <文件>。\n"
"\n"

#: src/rm.c:136
msgid ""
"  -f, --force\n"
"         ignore nonexistent files and arguments, never prompt\n"
msgstr ""
"  -f, --force\n"
"         忽略不存在的文件和参数，且从不询问\n"

#: src/rm.c:140
msgid ""
"  -i\n"
"         prompt before every removal\n"
msgstr ""
"  -i\n"
"         每次删除前询问\n"

#: src/rm.c:144
msgid ""
"  -I\n"
"         prompt once before removing more than three files,\n"
"         or when removing recursively; less intrusive than -i,\n"
"         while still giving protection against most mistakes\n"
msgstr ""
"  -I\n"
"         在删除超过三个文件或者递归删除前询问一次；\n"
"         此选项比 -i 提示次数更少，但仍可以避免大多数错误的发生\n"

#: src/rm.c:150
msgid ""
"      --interactive[=WHEN]\n"
"         prompt according to WHEN: never, once (-I), or always (-i);\n"
"         without WHEN, prompt always\n"
msgstr ""
"      --interactive[=何时]\n"
"         根据 <何时> 的值进行询问：never、once（同 -I）或者\n"
"         always（同 -i）；如果省略 <何时>，则默认为 always\n"

#: src/rm.c:155
msgid ""
"      --one-file-system\n"
"         when removing a hierarchy recursively,\n"
"         skip any directory that is on a file system different\n"
"         from that of the corresponding command line argument\n"
msgstr ""
"      --one-file-system\n"
"         递归删除目录时，跳过所有和该目录所对应的命令行参\n"
"         数不在同一个文件系统上的目录\n"

#: src/rm.c:161
msgid ""
"      --no-preserve-root\n"
"         do not treat '/' specially\n"
msgstr ""
"      --no-preserve-root\n"
"         不要对 \"/\" 特殊处理\n"

#: src/rm.c:165
msgid ""
"      --preserve-root[=all]\n"
"         do not remove '/' (default);\n"
"         with 'all', reject any command line argument\n"
"         on a separate device from its parent\n"
msgstr ""
"      --preserve-root[=all]\n"
"         不要删除 \"/\"（默认行为）；\n"
"         如添加了 \"all\" 参数，将拒绝处理与其父目录位于\n"
"         不同设备上的命令行参数\n"

#: src/rm.c:171
msgid ""
"  -r, -R, --recursive\n"
"         remove directories and their contents recursively\n"
msgstr ""
"  -r, -R, --recursive\n"
"         递归删除目录及其内容\n"

#: src/rm.c:175
msgid ""
"  -d, --dir\n"
"         remove empty directories\n"
msgstr ""
"  -d, --dir\n"
"         删除空目录\n"

#: src/rm.c:185
msgid ""
"\n"
"By default, rm does not remove directories.  Use the --recursive (-r or -R)\n"
"option to remove each listed directory, too, along with all of its "
"contents.\n"
msgstr ""
"\n"
"默认情况下，rm 不会删除目录。使用 --recursive（-r 或 -R）选项可删除每个给定\n"
"的目录，以及其中的全部内容。\n"

#: src/rm.c:190
msgid ""
"\n"
"Any attempt to remove a file whose last file name component is '.' or '..'\n"
"is rejected with a diagnostic.\n"
msgstr ""
"\n"
"若试图删除文件名最后一个组成部分为 \".\" 或 \"..\" 的文件，\n"
"则请求会被拒绝，并输出一条诊断信息。\n"

#: src/rm.c:195
#, c-format
msgid ""
"\n"
"To remove a file whose name starts with a '-', for example '-foo',\n"
"use one of these commands:\n"
"  %s -- -foo\n"
"\n"
"  %s ./-foo\n"
msgstr ""
"\n"
"要删除文件名第一个字符为 \"-\" 的文件（例如 \"-foo\"），请使用\n"
"以下命令之一：\n"
"  %s -- -foo\n"
"\n"
"  %s ./-foo\n"

#: src/rm.c:204
msgid ""
"\n"
"If you use rm to remove a file, it might be possible to recover\n"
"some of its contents, given sufficient expertise and/or time.  For greater\n"
"assurance that the contents are unrecoverable, consider using shred(1).\n"
msgstr ""
"\n"
"如果您使用 rm 来删除文件，在有足够的技术和/或时间的情况下，有可能可以\n"
"恢复文件的部分内容。如果想进一步保证所删除的文件的内容无法恢复，请考虑\n"
