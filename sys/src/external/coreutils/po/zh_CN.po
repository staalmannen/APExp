msgstr "用法：%s [选项]... 新根 [命令 [参数]...]\n"

#: src/chroot.c:188
msgid ""
"Run COMMAND with root directory set to NEWROOT.\n"
"\n"
msgstr ""
"以指定的 <新根> 为根目录，运行指定的 <命令>。\n"
"\n"

#: src/chroot.c:193
msgid ""
"      --groups=G_LIST\n"
"         specify supplementary groups as g1,g2,..,gN\n"
msgstr ""
"      --groups=组列表\n"
"         指定附加用户组，格式为：组1,组2,..,组N\n"

#: src/chroot.c:197
msgid ""
"      --userspec=USER:GROUP\n"
"         specify user and group (ID or name) to use\n"
msgstr ""
"      --userspec=USER:GROUP\n"
"         指定使用的用户及用户组（可使用 ID 或名称）\n"

#: src/chroot.c:201
#, c-format
msgid ""
"      --skip-chdir\n"
"         do not change working directory to %s\n"
msgstr ""
"      --skip-chdir\n"
"         不要将工作目录变更为 %s\n"

#: src/chroot.c:208
msgid ""
"\n"
"If no command is given, run '\"$SHELL\" -i' (default: '/bin/sh -i').\n"
msgstr ""
"\n"
"如果没有给定命令，则运行 '\"$SHELL\" -i'（默认：'/bin/sh -i'）。\n"

#: src/chroot.c:288
#, c-format
msgid "option --skip-chdir only permitted if NEWROOT is old %s"
msgstr "选项 --skip-chdir 只能在 <新根> 是旧的 %s 时使用"

#: src/chroot.c:331
#, c-format
