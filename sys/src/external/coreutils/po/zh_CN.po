#: src/dd.c:526
#, c-format
msgid ""
"Usage: %s [OPERAND]...\n"
"  or:  %s OPTION\n"
msgstr ""
"用法：%s [操作数] ...\n"
"　或：%s 选项\n"

#: src/dd.c:531
msgid ""
"Copy a file, converting and formatting according to the operands.\n"
"\n"
msgstr ""
"复制文件，同时根据操作数进行转换和格式化。\n"
"\n"

#: src/dd.c:535
msgid ""
"  bs=BYTES        read and write up to BYTES bytes at a time (default: "
"512);\n"
"                  overrides ibs and obs\n"
msgstr ""
"  bs=字节数      一次读取和写入的字节数（默认：512）；\n"
"                 会覆盖 ibs 和 obs 的值\n"

#: src/dd.c:539
msgid "  cbs=BYTES       convert BYTES bytes at a time\n"
msgstr "  cbs=字节数     一次转换的字节数\n"

#: src/dd.c:542
msgid ""
"  conv=CONVS      convert the file as per the comma separated symbol list\n"
msgstr "  conv=转换      按照以逗号分隔的符号列表指定的方式转换文件\n"

#: src/dd.c:545
msgid "  count=N         copy only N input blocks\n"
msgstr "  count=N        只复制 N 个输入块\n"

#: src/dd.c:548
msgid "  ibs=BYTES       read up to BYTES bytes at a time (default: 512)\n"
msgstr "  ibs=字节数     一次读取的字节数（默认：512)\n"

#: src/dd.c:551
msgid "  if=FILE         read from FILE instead of standard input\n"
msgstr "  if=文件         从 <文件> 而非标准输入读取\n"

#: src/dd.c:554
msgid "  iflag=FLAGS     read as per the comma separated symbol list\n"
msgstr "  iflag=标志      按照以逗号分隔的符号列表指定的方式读取\n"

#: src/dd.c:557
msgid "  obs=BYTES       write BYTES bytes at a time (default: 512)\n"
msgstr "  obs=字节数      一次写入的字节数（默认：512）\n"

#: src/dd.c:560
msgid "  of=FILE         write to FILE instead of standard output\n"
msgstr "  of=文件         写入到 <文件> 而非标准输出\n"

#: src/dd.c:563
msgid "  oflag=FLAGS     write as per the comma separated symbol list\n"
msgstr "  oflag=标志      按照以逗号分隔的符号列表指定的方式写入\n"

#: src/dd.c:566
msgid "  seek=N          (or oseek=N) skip N obs sized output blocks\n"
msgstr "  seek=N          （或 oseek=N）跳过 N 个大小为 obs 的输出块\n"

#: src/dd.c:569
msgid "  skip=N          (or iseek=N) skip N ibs sized input blocks\n"
msgstr "  skip=N          （或 iseek=N）跳过 N 个大小为 ibs 的输入块\n"

#: src/dd.c:572
msgid ""
"  status=LEVEL    The LEVEL of information to print to standard error;\n"
"                  'none' suppresses everything but error messages,\n"
"                  'noxfer' suppresses the final transfer statistics,\n"
"                  'progress' shows periodic transfer statistics\n"
msgstr ""
"  status=等级     要输出到标准错误的信息 <等级>；\n"
"                  \"none\" 将仅输出错误信息，\n"
"                  \"noxfer\" 将不输出最终的传输统计信息，\n"
"                  \"progress\" 将周期性显示传输统计信息\n"

#: src/dd.c:578
msgid ""
"\n"
"N and BYTES may be followed by the following multiplicative suffixes:\n"
"c=1, w=2, b=512, kB=1000, K=1024, MB=1000*1000, M=1024*1024, xM=M,\n"
"GB=1000*1000*1000, G=1024*1024*1024, and so on for T, P, E, Z, Y, R, Q.\n"
"Binary prefixes can be used, too: KiB=K, MiB=M, and so on.\n"
"If N ends in 'B', it counts bytes not blocks.\n"
"\n"
"Each CONV symbol may be:\n"
"\n"
msgstr ""
"\n"
"N 和 <字节数> 后可以带有以下的乘数后缀：\n"
"c=1、w=2、b=512、kB=1000、K=1024、MB=1000*1000、M=1024*1024、xM=M、\n"
"GB=1000*1000*1000、G=1024*1024*1024，T、P、E、Z、Y、R、Q 以此类推。\n"
"也可以使用二进制前缀：KiB=K、MiB=M，以此类推。\n"
"如果 N 以 \"B\" 结尾，则表示字节数而非块数。\n"
"\n"
"每个 <转换> 符号可以是：\n"
"\n"

#: src/dd.c:589
msgid ""
"  ascii     from EBCDIC to ASCII\n"
"  ebcdic    from ASCII to EBCDIC\n"
"  ibm       from ASCII to alternate EBCDIC\n"
"  block     pad newline-terminated records with spaces to cbs-size\n"
"  unblock   replace trailing spaces in cbs-size records with newline\n"
"  lcase     change upper case to lower case\n"
"  ucase     change lower case to upper case\n"
"  sparse    try to seek rather than write all-NUL output blocks\n"
"  swab      swap every pair of input bytes\n"
"  sync      pad every input block with NULs to ibs-size; when used\n"
"            with block or unblock, pad with spaces rather than NULs\n"
msgstr ""
"  ascii     由 EBCDIC 码转换至 ASCII 码\n"
"  ebcdic    由 ASCII 码转换至 EBCDIC 码\n"
"  ibm       由 ASCII 码转换至代用的 EBCDIC 码\n"
"  block     在以换行符结尾的记录末尾填充空格，直至 cbs 大小\n"
"  unblock   将 cbs 大小的记录中的末尾空格替换为一个换行符\n"
"  lcase     将大写字符转换为小写\n"
"  ucase     将小写字符转换为大写\n"
"  sparse    尝试寻址 (seek) 而非写入全为 NUL 空字符的输出块\n"
"  swab      交换每一对输入字节\n"
"  sync      将每个输入块以 NUL 空字符填充至 ibs 大小；当配合\n"
"            block 或 unblock 使用时，会以空格代替 NUL 空字符来填充\n"

#: src/dd.c:602
msgid ""
"  excl      fail if the output file already exists\n"
"  nocreat   do not create the output file\n"
"  notrunc   do not truncate the output file\n"
"  noerror   continue after read errors\n"
"  fdatasync  physically write output file data before finishing\n"
"  fsync     likewise, but also write metadata\n"
msgstr ""
"  excl      如果输出文件已存在，则操作失败\n"
"  nocreat   不要创建输出文件\n"
"  notrunc   不要截断输出文件\n"
"  noerror   发生读取错误后仍然继续\n"
"  fdatasync  结束前将输出文件数据从物理上写入磁盘\n"
"  fsync     与上一个类似，但也将元数据一同写入\n"

#: src/dd.c:610
msgid ""
"\n"
"Each FLAG symbol may be:\n"
"\n"
"  append    append mode (makes sense only for output; conv=notrunc "
"suggested)\n"
msgstr ""
"\n"
"每个 <标志> 符号可以是：\n"
"\n"
"  append    追加模式（仅对输出有意义；隐含了 conv=notrunc）\n"

#: src/dd.c:617
msgid "  cio       use concurrent I/O for data\n"
msgstr "  cio       使用并发 I/O 存取数据\n"

#: src/dd.c:619
msgid "  direct    use direct I/O for data\n"
msgstr "  direct    使用直接 I/O 存取数据\n"

#: src/dd.c:620
msgid "  directory  fail unless a directory\n"
msgstr "  directory  除非是目录，否则操作失败\n"

#: src/dd.c:622
msgid "  dsync     use synchronized I/O for data\n"
msgstr "  dsync     使用同步 I/O 存取数据\n"

#: src/dd.c:624
msgid "  sync      likewise, but also for metadata\n"
msgstr "  sync      与上一个类似，但同时也对元数据生效\n"

#: src/dd.c:625
msgid "  fullblock  accumulate full blocks of input (iflag only)\n"
msgstr "  fullblock  累积完整的输入块（仅限 iflag）\n"

#: src/dd.c:628
msgid "  nonblock  use non-blocking I/O\n"
msgstr "  nonblock  使用无阻塞 I/O\n"

#: src/dd.c:630
msgid "  noatime   do not update access time\n"
msgstr "  noatime   不更新访问时间\n"

#: src/dd.c:633
msgid "  nocache   Request to drop cache.  See also oflag=sync\n"
msgstr "  nocache   请求不使用缓存。也请参见 oflag=sync\n"

#: src/dd.c:637
msgid "  noctty    do not assign controlling terminal from file\n"
msgstr "  noctty    不根据文件指派控制终端\n"

#: src/dd.c:640
msgid "  nofollow  do not follow symlinks\n"
msgstr "  nofollow  不跟随符号链接\n"

#: src/dd.c:642
msgid "  nolinks   fail if multiply-linked\n"
msgstr "  nolinks   如果被多重链接，则操作失败\n"

#: src/dd.c:644
msgid "  binary    use binary I/O for data\n"
msgstr "  binary    使用二进制 I/O 存取数据\n"

#: src/dd.c:646
msgid "  text      use text I/O for data\n"
msgstr "  text      使用文本 I/O 存取数据\n"

