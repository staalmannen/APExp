msgstr "在 \",\" 后的数字无效"

#: src/sort.c:4734
#, c-format
msgid "empty tab"
msgstr "分隔符为空"

#: src/sort.c:4822 src/wc.c:906
#, c-format
msgid "cannot read file names from %s"
msgstr "无法从 %s 中读取文件名"

#: src/sort.c:4845
#, c-format
msgid "%s:%lu: invalid zero-length file name"
msgstr "%s:%lu: 无效的零长度文件名"

#: src/sort.c:4851
#, c-format
msgid "no input from %s"
msgstr "没有来自 %s 的输入"

#: src/sort.c:4904
#, c-format
msgid "text ordering performed using %s sorting rules"
msgstr "使用 %s 排序规则进行了文本排序"

#: src/sort.c:4908
msgid "text ordering performed using simple byte comparison"
msgstr "使用简单字节比较进行了文本排序"

#: src/sort.c:4940
#, c-format
msgid "extra operand %s not allowed with -%c"
msgstr "使用 -%2$c 时不允许指定额外的操作对象 %1$s"

#: src/split.c:210
#, c-format
msgid "the suffix length needs to be at least %d"
msgstr "后缀长度至少应为 %d"

#: src/split.c:226
#, c-format
msgid "Usage: %s [OPTION]... [FILE [PREFIX]]\n"
msgstr "用法：%s [选项]... [文件 [前缀]]\n"

#: src/split.c:230
msgid ""
"Output pieces of FILE to PREFIXaa, PREFIXab, ...;\n"
"default size is 1000 lines, and default PREFIX is 'x'.\n"
msgstr ""
"将 <文件> 拆分并输出到 \"前缀aa\"、\"前缀ab\" 等文件；\n"
"默认以 1000 行为拆分单位，默认 <前缀> 为 \"x\"。\n"

#: src/split.c:238
#, c-format
msgid ""
"  -a, --suffix-length=N\n"
"         generate suffixes of length N (default %d)\n"
msgstr ""
"  -a, --suffix-length=N\n"
"         生成长度为 N（默认为 %d）的文件名后缀\n"

#: src/split.c:242
msgid ""
"      --additional-suffix=SUFFIX\n"
"         append an additional SUFFIX to file names\n"
msgstr ""
"      --additional-suffix=后缀\n"
"         向文件名添加一个额外的 <后缀>\n"

#: src/split.c:246
msgid ""
"  -b, --bytes=SIZE\n"
"         put SIZE bytes per output file\n"
msgstr ""
"  -b, --bytes=大小\n"
"         每个输出文件的大小为 <大小> 字节\n"

#: src/split.c:250
msgid ""
"  -C, --line-bytes=SIZE\n"
"         put at most SIZE bytes of records per output file\n"
msgstr ""
"  -C, --line-bytes=大小\n"
"         每个输出文件包含完整的记录，且最大大小为 <大小> 字节\n"

#: src/split.c:254
msgid ""
"  -d\n"
"         use numeric suffixes starting at 0, not alphabetic\n"
msgstr ""
"  -d\n"
"         使用从 0 开始的数字后缀代替字母后缀\n"

#: src/split.c:258
msgid ""
"      --numeric-suffixes[=FROM]\n"
"         same as -d, but allow setting the start value\n"
msgstr ""
"      --numeric-suffixes[=初值]\n"
"         类似 -d，但可以设定后缀的初值\n"

#: src/split.c:262
msgid ""
"  -x\n"
"         use hex suffixes starting at 0, not alphabetic\n"
msgstr ""
"  -x\n"
"         使用从 0 开始的十六进制数后缀代替字母后缀\n"

#: src/split.c:266
msgid ""
"      --hex-suffixes[=FROM]\n"
"         same as -x, but allow setting the start value\n"
msgstr ""
"      --hex-suffixes[=初值]\n"
"         类似 -x，但可以设定后缀的初值\n"

#: src/split.c:270
msgid ""
"  -e, --elide-empty-files\n"
"         do not generate empty output files with '-n'\n"
msgstr ""
"  -e, --elide-empty-files\n"
"         和 \"-n\" 一起使用时，不生成空的输出文件\n"

#: src/split.c:274
msgid ""
"      --filter=COMMAND\n"
"         write to shell COMMAND; file name is $FILE\n"
msgstr ""
"      --filter=命令\n"
"         将输出用管道传递给 shell <命令>；文件名在 $FILE 中\n"

#: src/split.c:278
msgid ""
"  -l, --lines=NUMBER\n"
"         put NUMBER lines/records per output file\n"
msgstr ""
"  -l, --lines=数值\n"
"         每个输出文件包含 <数值> 行（或称记录）\n"

#: src/split.c:282
msgid ""
"  -n, --number=CHUNKS\n"
"         generate CHUNKS output files; see explanation below\n"
msgstr ""
"  -n, --number=块数\n"
"         生成 <块数> 个输出文件。参见下面的说明。\n"

#: src/split.c:286
msgid ""
"  -t, --separator=SEP\n"
"         use SEP instead of newline as the record separator;\n"
"         '\\0' (zero) specifies the NUL character\n"
msgstr ""
"  -t, --separator=分隔符\n"
"         使用 <分隔符> 而不是换行符作为记录分隔符；\n"
"         使用 \"\\0\"（数字 0）指定 NUL 字符\n"

#: src/split.c:291
msgid ""
"  -u, --unbuffered\n"
"         immediately copy input to output with '-n r/...'\n"
msgstr ""
"  -u, --unbuffered\n"
"         立即使用 \"-n r/...\" 将输入复制到输出\n"

#: src/split.c:295
msgid ""
"      --verbose\n"
"         print a diagnostic just before each output file is opened\n"
msgstr ""
"      --verbose\n"
"         在打开每个输出文件前输出一条诊断信息\n"

#: src/split.c:302
msgid ""
"\n"
"CHUNKS may be:\n"
"  N       split into N files based on size of input\n"
"  K/N     output Kth of N to standard output\n"
"  l/N     split into N files without splitting lines/records\n"
"  l/K/N   output Kth of N to standard output without splitting lines/"
"records\n"
"  r/N     like 'l' but use round robin distribution\n"
"  r/K/N   likewise but only output Kth of N to standard output\n"
msgstr ""
"\n"
"<块数> 可以是：\n"
"  N       基于输入的大小分割为 N 个文件\n"
"  K/N     将 N 个文件中的第 K 个输出到标准输出\n"
"  l/N     分割为 N 个文件，但分割时不切断行（或称记录）\n"
"  l/K/N   将 N 个文件中的第 K 个输出到标准输出，但分割时不切断行（或称记"
"录）\n"
"  r/N     类似 l 但使用轮转分配\n"
"  r/K/N   类似 r/N 但仅将 N 个文件中的第 K 个输出到标准输出\n"

#: src/split.c:311
msgid ""
"\n"
"-n (except -nr) will buffer to $TMPDIR, defaulting to /tmp,\n"
"if the input size cannot easily be determined.\n"
msgstr ""
"\n"
"-n 选项（除 -nr 外）会在输入大小难以确定时\n"
"将数据缓冲至 $TMPDIR（默认为 /tmp）。\n"

