"         仅打印当前进程的安全上下文\n"

#: src/id.c:108
msgid ""
"  -g, --group\n"
"         print only the effective group ID\n"
msgstr ""
"  -g, --group\n"
"         仅打印有效组 ID\n"

#: src/id.c:112
msgid ""
"  -G, --groups\n"
"         print all group IDs\n"
msgstr ""
"  -G, --groups\n"
"         打印所有的组 ID\n"

#: src/id.c:116
msgid ""
"  -n, --name\n"
"         print a name instead of a number, for -u,-g,-G\n"
msgstr ""
"  -n, --name\n"
"         打印名称而非数字，与 -u、-g、-G 一起使用\n"

#: src/id.c:120
msgid ""
"  -r, --real\n"
