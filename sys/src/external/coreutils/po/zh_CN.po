msgstr "空闲"

#: src/who.c:550
msgid "PID"
msgstr "PID"

#: src/who.c:550
msgid "COMMENT"
msgstr "备注    "

#: src/who.c:550
msgid "EXIT"
msgstr "退出"

#: src/who.c:630
#, c-format
msgid "Usage: %s [OPTION]... [ FILE | ARG1 ARG2 ]\n"
msgstr "用法：%s [选项]... [ 文件 | 参数1 参数2 ]\n"

#: src/who.c:631
msgid "Print information about users who are currently logged in.\n"
msgstr "显示当前已登录的用户信息。\n"

#: src/who.c:637
msgid "  -a, --all         same as -b -d --login -p -r -t -T -u\n"
msgstr "  -a, --all         等价于 -b -d --login -p -r -t -T -u\n"

#: src/who.c:640
msgid "  -b, --boot        time of last system boot\n"
msgstr "  -b, --boot        显示上次系统引导时间\n"

#: src/who.c:643
msgid "  -d, --dead        print dead processes\n"
msgstr "  -d, --dead        显示已死的进程\n"

#: src/who.c:646
msgid "  -H, --heading     print line of column headings\n"
msgstr "  -H, --heading     显示表头行\n"

#: src/who.c:649
msgid "  -l, --login       print system login processes\n"
msgstr "  -l，--login       显示系统登录进程\n"

#: src/who.c:652
msgid "      --lookup      attempt to canonicalize hostnames via DNS\n"
msgstr "      --lookup      尝试通过 DNS 规范化主机名\n"

#: src/who.c:655
msgid ""
"  -m                only hostname and user associated with standard input\n"
msgstr "  -m                只显示和标准输入关联的主机和用户\n"

#: src/who.c:658
msgid "  -p, --process     print active processes spawned by init\n"
msgstr "  -p, --process     显示由 init 进程衍生的活动进程\n"

#: src/who.c:661
msgid "  -q, --count       all login names and number of users logged on\n"
msgstr "  -q, --count       显示所有已登录用户的登录名和已登录的用户数量\n"

#: src/who.c:664
msgid "  -r, --runlevel    print current runlevel\n"
msgstr "  -r, --runlevel    显示当前的运行级别\n"

#: src/who.c:667
msgid "  -s, --short       print only name, line, and time (default)\n"
msgstr "  -s, --short       只显示名称、线路和时间（默认）\n"

#: src/who.c:670
msgid "  -t, --time        print last system clock change\n"
msgstr "  -t, --time        显示上次系统时钟更改\n"

#: src/who.c:673
msgid "  -T, -w, --mesg    add user's message status as +, - or ?\n"
msgstr "  -T, -w, --mesg    用 +、- 或 ? 标注用户的消息状态\n"

#: src/who.c:676
msgid "  -u, --users       list users logged in, including idle time\n"
msgstr "  -u, --users       列出已登录的用户，包括空闲时间\n"

#: src/who.c:679
msgid "      --message     same as -T\n"
msgstr "      --message     同 -T\n"

#: src/who.c:682
msgid "      --writable    same as -T\n"
msgstr "      --writable    同 -T\n"

#: src/who.c:687
#, c-format
msgid ""
"\n"
"If FILE is not specified, use %s.  %s as FILE is common.\n"
"If ARG1 ARG2 given, -m presumed: 'am i' or 'mom likes' are usual.\n"
msgstr ""
"\n"
"如果没有指定 <文件>，则使用 %s。%s 也是常用的 <文件>。\n"
"如果给定了 <参数1> 和 <参数2>，则隐含启用 -m 选项：常见的参数例子如\n"
"\"am i\" 或 \"mom likes\"。\n"

#: src/whoami.c:43
msgid ""
"Print the user name associated with the current effective user ID.\n"
"Same as id -un.\n"
"\n"
msgstr ""
"显示与当前的有效用户 ID 相关联的用户名。\n"
"与 id -un 相同。\n"
"\n"

#: src/yes.c:45
#, c-format
msgid ""
"Usage: %s [STRING]...\n"
"  or:  %s OPTION\n"
msgstr ""
"用法：%s [字符串]...\n"
"　或：%s 选项\n"

#: src/yes.c:51
msgid ""
"Repeatedly output a line with all specified STRING(s), or 'y'.\n"
"\n"
