msgstr "无效的 ispeed %s"

#: src/stty.c:1192
#, c-format
msgid "invalid ospeed %s"
msgstr "无效的 ospeed %s"

#: src/stty.c:1211
#, c-format
msgid "%s: error setting %s"
msgstr "%s: 设置 %s 时出错"

#: src/stty.c:1251
#, c-format
msgid "invalid line discipline %s"
msgstr "无效的行规则 %s"

#: src/stty.c:1344
#, c-format
