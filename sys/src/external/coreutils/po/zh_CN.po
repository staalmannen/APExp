msgid " %H:%M:%S  "
msgstr " %H:%M:%S  "

#: src/uptime.c:72
#, c-format
msgid " ??:????  "
msgstr " ??:????  "

#: src/uptime.c:80
#, c-format
msgid "up ???? days ??:??,  "
msgstr "已启动 ???? 天 ??:??， "

#: src/uptime.c:89
#, c-format
msgid "up %jd day %2d:%02d,  "
msgid_plural "up %jd days %2d:%02d,  "
msgstr[0] "已启动 %jd 天 %2d:%02d， "

#: src/uptime.c:94
#, c-format
msgid "up  %2d:%02d,  "
msgstr "已启动 %2d:%02d， "

#: src/uptime.c:97
#, c-format
msgid "%td user"
msgid_plural "%td users"
msgstr[0] "%td 个用户"

#: src/uptime.c:108
#, c-format
msgid ",  load average: %.2f"
msgstr "， 平均负载：%.2f"

#: src/uptime.c:150
#, c-format
msgid ""
"Print the current time, the length of time the system has been up,\n"
"the number of users on the system, and the average number of jobs\n"
"in the run queue over the last 1, 5 and 15 minutes."
msgstr ""
"输出当前时间、系统启动后经过的时间、当前登录用户数，以及\n"
"最近 1、5 和 15 分钟系统运行队列中的平均任务数。"

#: src/uptime.c:159
#, c-format
msgid ""
"  Processes in\n"
"an uninterruptible sleep state also contribute to the load average.\n"
msgstr "  处于不可中断睡眠状态的程序也会被计入系统平均负载。\n"

#: src/uptime.c:165
#, c-format
msgid ""
"If FILE is not specified, use %s.  %s as FILE is common.\n"
"\n"
msgstr ""
"如果没有指定 <文件>，则使用 %s。%s 也是常用的 <文件>。\n"
"\n"

#: src/users.c:103
#, c-format
msgid ""
"Output who is currently logged in according to FILE.\n"
"If FILE is not specified, use %s.  %s as FILE is common.\n"
"\n"
msgstr ""
"根据 <文件> 输出当前已经登录到系统的用户。\n"
"如果没有指定 <文件>，则使用 %s。%s 也是常用的 <文件>。\n"
"\n"

#: src/wc.c:175
#, c-format
msgid "using neon hardware support"
msgstr "使用 neon 硬件支持"

#: src/wc.c:176
#, c-format
msgid "neon support not detected"
msgstr "未检测到 neon 支持"

#: src/wc.c:194
msgid ""
"Print newline, word, and byte counts for each FILE, and a total line if\n"
"more than one FILE is specified.  A word is a nonempty sequence of non "
"white\n"
"space delimited by white space characters or by start or end of input.\n"
msgstr ""
"打印每个 <文件> 的换行符、单词和字节计数；如果指定了多个 <文件>，\n"
"则还会打印一个 \"总计\" 行。此处的 \"单词\" 是指由空白字符或者输入的开始\n"
"或结束分隔的、非空的、由非空白字符构成的字符序列。\n"

#: src/wc.c:202
msgid ""
"\n"
"The options below may be used to select which counts are printed, always in\n"
"the following order: newline, word, character, byte, maximum line length.\n"
msgstr ""
"\n"
"可使用以下选项选择输出哪些种类的计数。输出总是遵循以下顺序：\n"
"换行符数、单词数、字符数、字节数、最长行的长度。\n"

#: src/wc.c:207
msgid ""
"  -c, --bytes\n"
"         print the byte counts\n"
msgstr ""
"  -c, --bytes\n"
"         输出字节数\n"

#: src/wc.c:211
msgid ""
"  -m, --chars\n"
"         print the character counts\n"
msgstr ""
"  -m, --chars\n"
"         输出字符数\n"

#: src/wc.c:215
msgid ""
"  -l, --lines\n"
"         print the newline counts\n"
msgstr ""
"  -l, --lines\n"
"         输出换行符数\n"

#: src/wc.c:219
msgid ""
"      --debug\n"
"         indicate what line count acceleration is used\n"
msgstr ""
"      --debug\n"
"         提示使用了哪一种加速行数统计的方式\n"

#: src/wc.c:223
msgid ""
"      --files0-from=F\n"
"         read input from the files specified by\n"
"         NUL-terminated names in file F;\n"
"         If F is -, read names from standard input\n"
msgstr ""
"      --files0-from=F\n"
"         从文件 F 中读取以 NUL 空字符分隔的文件名\n"
"         作为输入文件的名称；\n"
"         如果 F 是 -，则从标准输入读取文件名\n"

#: src/wc.c:229
msgid ""
"  -L, --max-line-length\n"
"         print the maximum display width\n"
msgstr ""
"  -L, --max-line-length\n"
"         输出最长行的长度\n"

#: src/wc.c:233
msgid ""
"  -w, --words\n"
"         print the word counts\n"
msgstr ""
"  -w, --words\n"
"         输出单词数\n"

#: src/wc.c:237
msgid ""
"      --total=WHEN\n"
"         when to print a line with total counts;\n"
"         WHEN can be: auto, always, only, never\n"
msgstr ""
"      --total=何时\n"
"         何时打印含有 \"总计\" 的行；\n"
"         <何时> 可以是：auto、always、only、never\n"

#: src/wc.c:1011
#, c-format
msgid "total lines"
msgstr "总行数"

#: src/wc.c:1017
#, c-format
msgid "total words"
msgstr "总单词数"

#: src/wc.c:1023
#, c-format
msgid "total characters"
msgstr "总字符数"

#: src/wc.c:1029
#, c-format
msgid "total bytes"
msgstr "总字节数"

# 在 who -u 中表示“用户超过 24 小时无活动”，但是此字符串长度限制为 6 字节（不含 '\0'），否则乱码。所以只能放一个汉字，或者不使用空格放两个汉字。两个汉字对齐效果会好一点（刚好和 "空闲" 产生的对齐偏差抵消，使得 who -aH 时，空闲为 "很久" 的用户的 PID 列是对齐的）
#: src/who.c:204
msgid " old "
msgstr "很久"

# 要对齐，需要占 12 个英文字符宽度。
#: src/who.c:428
msgid "system boot"
msgstr "系统引导    "

#: src/who.c:437
msgid "id="
msgstr "id="

# termination 的缩写
#: src/who.c:454 src/who.c:459
msgid "term="
msgstr "终止="

#: src/who.c:456 src/who.c:460
msgid "exit="
msgstr "退出="

#: src/who.c:477
msgid "LOGIN"
msgstr "登录    "

# 要对齐，需要占 12 个英文字符宽度。
#: src/who.c:497
msgid "clock change"
msgstr "时钟更改    "

# 这个需要占 10 个英文字符宽度才能让 who -aH 后续的列正常对齐。怎么办呢？在 "运行级别" 后面加两个空格，虽然和后面的数字离得远了点，但是相比之下似乎左对齐比较重要。
#: src/who.c:509 src/who.c:510
msgid "run-level"
msgstr "运行级别  "

#: src/who.c:513 src/who.c:514
msgid "last="
msgstr "上一个="

#: src/who.c:543
#, c-format
msgid ""
"\n"
"# users=%td\n"
msgstr ""
"\n"
"用户数=%td\n"

# 空格用于对齐
#: src/who.c:549
msgid "NAME"
msgstr "名称    "

# 空格用于对齐
#: src/who.c:549
msgid "LINE"
msgstr "线路        "

# 空格用于对齐
#: src/who.c:549
msgid "TIME"
msgstr "时间            "

# 此字符串大小限制为 6 字节（不含 '\0'），但是 printf 时使用的是 "%-6s"。所以，必然比英文原文少 2 个空格，导致 who -aH 的输出从 PID 列开始出现对齐问题，这个问题似乎无法解决。
