msgstr ""
"  -r, --real\n"
"         打印真实 ID 而非有效 ID，与 -u、-g、-G 一起使用\n"

#: src/id.c:124
msgid ""
"  -u, --user\n"
"         print only the effective user ID\n"
msgstr ""
"  -u, --user\n"
"         仅打印有效用户 ID\n"

#: src/id.c:128
msgid ""
"  -z, --zero\n"
"         delimit entries with NUL characters, not whitespace;\n"
