#: src/paste.c:227
#, c-format
msgid "standard input is closed"
msgstr "标准输入已关闭"

#: src/paste.c:457
msgid ""
"Write lines consisting of the sequentially corresponding lines from\n"
"each FILE, separated by TABs, to standard output.\n"
"The newline of every line except the line from the last file\n"
"is replaced with a TAB.\n"
msgstr ""
"将各个 <文件> 里相同行号的行合并成一行，中间用制表符分隔，\n"
"并输出到标准输出。\n"
"除了最后一个文件以外，每一行的换行符都会被替换成 TAB。\n"

#: src/paste.c:467
msgid ""
"  -d, --delimiters=LIST\n"
"         reuse characters from LIST instead of TABs;\n"
"         backslash escapes are supported\n"
msgstr ""
"  -d, --delimiters=列表\n"
"         循环使用 <列表> 里的字符代替 TAB 作为分隔符\n"
"         支持反斜杠转义\n"

#: src/paste.c:472
msgid ""
"  -s, --serial\n"
"         paste one file at a time instead of in parallel; the newline of\n"
"         every line except the last line in each file is replaced with a "
"TAB\n"
msgstr ""
"  -s, --serial\n"
"         每次粘贴一个文件，而不是并行执行；\n"
"         每个文件除了最后一行以外的每一行的换行符都会被替换成 TAB。\n"

#: src/paste.c:542
#, c-format
msgid "delimiter list ends with an unescaped backslash: %s"
msgstr "分隔符列表的末尾有未转义的反斜杠：%s"

