msgstr ""
"  -t [[EE]JJ]MMDDhhmm[.ss]  te gebruiken tijd i.p.v. huidige tijd\n"
"                              (met een opmaak die verschilt van '-d')\n"

#: src/touch.c:263
#, fuzzy
msgid ""
"      --time=WORD\n"
"         specify which time to change:\n"
"         access time (-a): 'access', 'atime', 'use';\n"
"         modification time (-m): 'modify', 'mtime'\n"
msgstr ""
"      --time=SOORT    alleen dit soort tijdsstempel instellen; SOORT mag "
