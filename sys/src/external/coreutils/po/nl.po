#, c-format
msgid "Usage: %s OPTION... [FILE]...\n"
msgstr ""
"Gebruik:  %s OPTIE... [BESTAND...]\n"
"\n"

#: src/cut.c:184
msgid "Print selected parts of lines from each FILE to standard output.\n"
msgstr ""
"Stuurt de geselecteerde delen van regels uit elk BESTAND naar "
