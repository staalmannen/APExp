"standaard),\n"
"                         'prepend' (voorvoegen) of 'separate' (gescheiden);\n"

#: src/uniq.c:188
#, fuzzy
msgid ""
"  -f, --skip-fields=N\n"
"         avoid comparing the first N fields\n"
msgstr "  -f, --skip-fields=N    de eerste N velden niet vergelijken\n"

#: src/uniq.c:192
#, fuzzy
msgid ""
"      --group[=METHOD]\n"
"         show all items, separating groups with an empty line;\n"
"         METHOD={separate(default),prepend,append,both}\n"
msgstr ""
"      --group[=SCHEIDINGSMETHODE]\n"
