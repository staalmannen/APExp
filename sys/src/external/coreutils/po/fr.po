#: src/cksum.c:501
#, c-format
msgid "Print or check %s checksums.\n"
msgstr "Afficher ou vérifier les sommes de contrôle %s.\n"

#: src/cksum.c:504 src/cksum.c:519
msgid "Legacy interface to the cksum utility.\n"
msgstr "Interface historique vers l'utilitaire chsum.\n"

#: src/cksum.c:509
msgid ""
"Print or verify checksums.\n"
"By default use the 32 bit CRC algorithm.\n"
msgstr ""
"Afficher ou vérifier la somme de contrôle.\n"
"Utilise l'algorithme CRC 32 bits par défaut.\n"

#: src/cksum.c:514
#, c-format
msgid "Print or check %s (%d-bit) checksums.\n"
msgstr "Afficher ou vérifier les sommes de contrôle %s (%d bits).\n"

#: src/cksum.c:526
msgid ""
"  -r\n"
"         use BSD sum algorithm (the default), use 1K blocks\n"
msgstr ""
"  -r\n"
"         utiliser l'algorithme de calcul de somme BSD (par défaut)\n"
"         avec des blocs de 1K octets\n"

#: src/cksum.c:530
msgid ""
"  -s, --sysv\n"
"         use System V sum algorithm, use 512 bytes blocks\n"
msgstr ""
"  -s, --sysv\n"
"         utiliser l'algorithme de calcul de somme de Système V avec des\n"
"         blocs de 512 octets\n"

#: src/cksum.c:540
msgid ""
"  -a, --algorithm=TYPE\n"
"         select the digest type to use.  See DIGEST below\n"
msgstr ""
"  -a, --algorithm=TYPE\n"
"         sélectionner le type de résumé à utiliser. Voyez RÉSUMÉ ci-dessous\n"

#: src/cksum.c:545
msgid ""
"      --base64\n"
"         emit base64-encoded digests, not hexadecimal\n"
msgstr ""
"      --base64\n"
"         sortir des résumés encodés en base64 au lieu de hexadécimal\n"

#: src/cksum.c:556
msgid ""
"  -b, --binary\n"
"         read in binary mode (default unless reading tty stdin)\n"
msgstr ""
"  -b, --binary\n"
"         lire en mode binaire (par défaut sauf en lecture depuis\n"
"         l'entrée standard d'un tty)\n"

#: src/cksum.c:561
msgid ""
"  -b, --binary\n"
"         read in binary mode\n"
msgstr ""
"  -b, --binary\n"
"         lire en mode binaire\n"

# Ajout volontaire de place pour l'argument (Stéphane)
#: src/cksum.c:568
msgid ""
"  -c, --check\n"
"         read checksums from the FILEs and check them\n"
msgstr ""
"  -c, --check\n"
"         lire les sommes de contrôle à partir des FICHIERs et les vérifier\n"

#: src/cksum.c:576
msgid ""
"  -l, --length=BITS\n"
"         digest length in bits; must not exceed the max size\n"
"         and must be a multiple of 8 for blake2b;\n"
"         must be 224, 256, 384, or 512 for sha2 or sha3\n"
msgstr ""
"  -l, --length=BITS\n"
"         longueur de la somme de contrôle en bits ; ne doit pas\n"
"         dépasser la taille maximale et doit être un multiple de\n"
"         8 pour blake2b ; doit être 224, 256, 384 ou 512 pour sha2\n"
"         ou sha3\n"

#: src/cksum.c:585
msgid ""
"      --raw\n"
"         emit a raw binary digest, not hexadecimal\n"
msgstr ""
"      --raw\n"
"         émettre un résumé binaire brut, pas de l'hexadécimal\n"

#: src/cksum.c:590 src/cksum.c:605
msgid ""
"      --tag\n"
"         create a BSD-style checksum\n"
msgstr ""
"      --tag\n"
"         créer une somme de contrôle de type BSD\n"

#: src/cksum.c:595
msgid ""
"      --tag\n"
"         create a BSD-style checksum (the default)\n"
msgstr ""
"      --tag\n"
"         créer une somme de contrôle de type BSD (par défaut)\n"

#: src/cksum.c:600
msgid ""
"      --untagged\n"
"         create a reversed style checksum, without digest type\n"
msgstr ""
"      --untagged\n"
"         créer une somme de contrôle inversée, sans type de résumé\n"

#: src/cksum.c:615
msgid ""
"  -t, --text\n"
"         read in text mode (default if reading tty stdin)\n"
msgstr ""
"  -t, --text\n"
"         lire en mode texte (par défaut sauf en lecture depuis\n"
"         l'entrée standard d'un tty)\n"

#: src/cksum.c:620
msgid ""
"  -t, --text\n"
"         read in text mode (default)\n"
msgstr ""
"  -t, --text\n"
"         lire en mode texte (par défaut)\n"

#: src/cksum.c:627
msgid ""
"  -z, --zero\n"
"         end each output line with NUL, not newline,\n"
"         and disable file name escaping\n"
msgstr ""
"  -z, --zero\n"
"         terminer chaque ligne de sortie par NUL au lieu d'un\n"
"         saut de ligne et désactive l'échappement du nom du fichier\n"

#: src/cksum.c:632
msgid ""
"\n"
"The following five options are useful only when verifying checksums:\n"
msgstr ""
"\n"
"Les cinq options suivantes ne sont utiles qu'en vérifiant des sommes\n"
"de contrôle :\n"

#: src/cksum.c:636
msgid ""
"      --ignore-missing\n"
"         don't fail or report status for missing files\n"
msgstr ""
"      --ignore-missing\n"
"         ne pas échouer ou indiquer le statut des fichiers\n"
"         manquants\n"

#: src/cksum.c:640
msgid ""
"      --quiet\n"
"         don't print OK for each successfully verified file\n"
msgstr ""
"      --quiet\n"
"         ne pas afficher OK à chaque vérification réussie\n"

#: src/cksum.c:644
msgid ""
"      --status\n"
"         don't output anything, status code shows success\n"
msgstr ""
"      --status\n"
"         ne rien afficher, le code d'état indique le succès\n"

#: src/cksum.c:648
msgid ""
"      --strict\n"
"         exit non-zero for improperly formatted checksum lines\n"
msgstr ""
"      --strict\n"
"         quitter avec un code de retour non nul en cas de\n"
"         formatage incorrect des lignes de contrôle\n"

#: src/cksum.c:652
msgid ""
"  -w, --warn\n"
"         warn about improperly formatted checksum lines\n"
msgstr ""
"  -w, --warn\n"
