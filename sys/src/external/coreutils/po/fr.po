msgid "Print information about users who are currently logged in.\n"
msgstr "Afficher des informations sur les utilisateurs connectés.\n"

#: src/who.c:637
msgid "  -a, --all         same as -b -d --login -p -r -t -T -u\n"
msgstr "  -a, --all         identique à -b -d --login -p -r -t -T -u\n"

#: src/who.c:640
msgid "  -b, --boot        time of last system boot\n"
msgstr "  -b, --boot        afficher l'heure du dernier démarrage système\n"

#: src/who.c:643
msgid "  -d, --dead        print dead processes\n"
msgstr "  -d, --dead        afficher la liste des processus morts\n"

#: src/who.c:646
msgid "  -H, --heading     print line of column headings\n"
msgstr "  -H, --heading     afficher les en-têtes de colonne des lignes\n"

#: src/who.c:649
msgid "  -l, --login       print system login processes\n"
msgstr "  -l, --login       afficher le processus de connexion du système\n"

#: src/who.c:652
msgid "      --lookup      attempt to canonicalize hostnames via DNS\n"
msgstr ""
"      --lookup      utiliser la forme canonique des noms d'hôte grâce au "
"DNS\n"

#: src/who.c:655
msgid ""
"  -m                only hostname and user associated with standard input\n"
msgstr ""
"  -m                nom d'hôte et d'utilisateur seulement associés à "
"l'entrée standard\n"

#: src/who.c:658
msgid "  -p, --process     print active processes spawned by init\n"
msgstr "  -p, --process     afficher la liste des processus lancés par init\n"

#: src/who.c:661
msgid "  -q, --count       all login names and number of users logged on\n"
msgstr ""
