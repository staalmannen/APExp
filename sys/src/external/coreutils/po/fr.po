msgstr "  -t                       équivalent à -vT\n"

#: src/cat.c:124
msgid "  -T, --show-tabs          display TAB characters as ^I\n"
msgstr "  -T, --show-tabs          afficher les caractères TAB comme ^I\n"

#: src/cat.c:127
