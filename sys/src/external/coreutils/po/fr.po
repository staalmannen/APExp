#: src/ptx.c:406
#, c-format
msgid "%s (for regexp %s)"
msgstr "%s (pour l'expression rationnelle %s)"

#: src/ptx.c:794
#, c-format
msgid "error: regular expression has a match of length zero: %s"
msgstr ""
"erreur: l'expression rationnelle a une correspondance de longueur zéro: %s"

#: src/ptx.c:1672
#, c-format
msgid ""
"Usage: %s [OPTION]... [INPUT]...   (without -G)\n"
"  or:  %s -G [OPTION]... [INPUT [OUTPUT]]\n"
msgstr ""
"Utilisation : %s [OPTION]... [ENTRÉE]...   (sans l'option -G)\n"
"         ou : %s -G [OPTION]... [ENTRÉE [SORTIE]]\n"

#: src/ptx.c:1676
msgid ""
"Output a permuted index, including context, of the words in the input "
"files.\n"
msgstr ""
"Afficher un index permuté, incluant le contexte, des mots des fichiers "
"d'entrée.\n"

#: src/ptx.c:1683
msgid ""
"  -A, --auto-reference           output automatically generated references\n"
msgstr ""
"  -A, --auto-reference           afficher les références générées "
"automatiquement\n"

#: src/ptx.c:1686
msgid "  -G, --traditional              behave more like System V 'ptx'\n"
msgstr ""
"  -G, --traditional              se comporter plutôt comme « ptx » de System "
"V\n"

#: src/ptx.c:1689
msgid ""
"  -F, --flag-truncation=STRING   use STRING for flagging line truncations.\n"
"                                 The default is '/'\n"
msgstr ""
"  -F, --flag-truncation=CHAÎNE   utiliser CHAÎNE pour indiquer les "
"troncatures\n"
"                                   de ligne. Utiliser « / » par défaut\n"

#: src/ptx.c:1693
msgid "  -M, --macro-name=STRING        macro name to use instead of 'xx'\n"
msgstr ""
"  -M, --macro-name=CHAÎNE        nom de la macro à utiliser au lieu de "
"« xx »\n"

#: src/ptx.c:1696
msgid "  -O, --format=roff              generate output as roff directives\n"
msgstr ""
"  -O, --format=roff              générer la sortie comme des directives "
"roff\n"

#: src/ptx.c:1699
msgid ""
"  -R, --right-side-refs          put references at right, not counted in -w\n"
msgstr ""
"  -R, --right-side-refs          placer la références à droite, pas compté\n"
"                                 dans -w\n"

#: src/ptx.c:1702
msgid "  -S, --sentence-regexp=REGEXP   for end of lines or end of sentences\n"
msgstr ""
"  -S, --sentence-regexp=EXP_RAT  pour les fins de lignes ou de phrases\n"

#: src/ptx.c:1705
msgid "  -T, --format=tex               generate output as TeX directives\n"
msgstr ""
"  -T, --format=tex               générer la sortie comme des directives TeX\n"

#: src/ptx.c:1708
msgid "  -W, --word-regexp=REGEXP       use REGEXP to match each keyword\n"
msgstr ""
"  -W, --word-regexp=EXP_RAT      utiliser EXP_RAT pour établir la "
"correspondance\n"
"                                 à chaque mot\n"

#: src/ptx.c:1711
msgid "  -b, --break-file=FILE          word break characters in this FILE\n"
msgstr ""
"  -b, --break-file=FICHIER       utiliser les césures de mots de FICHIER\n"

#: src/ptx.c:1714
msgid ""
"  -f, --ignore-case              fold lower case to upper case for sorting\n"
msgstr ""
"  -f, --ignore-case              convertir minuscules en majuscules pour le "
"tri\n"

#: src/ptx.c:1717
msgid ""
"  -g, --gap-size=NUMBER          gap size in columns between output fields\n"
msgstr ""
"  -g, --gap-size=NOMBRE          espacer les champs de NOMBRE colonnes\n"

#: src/ptx.c:1720
msgid "  -i, --ignore-file=FILE         read ignore word list from FILE\n"
msgstr ""
"  -i, --ignore-file=FICHIER      lire la liste des mots à ignorer dans "
"FICHIER\n"

#: src/ptx.c:1723
msgid "  -o, --only-file=FILE           read only word list from this FILE\n"
msgstr ""
"  -o, --only-file=FICHIER        lire la liste des mots à conserver dans "
"FICHIER\n"

#: src/ptx.c:1726
msgid ""
"  -r, --references               first field of each line is a reference\n"
msgstr ""
"  -r, --references               premier champ de chaque ligne en référence\n"

#: src/ptx.c:1729
msgid ""
"  -t, --typeset-mode             change the default width from 72 to 100\n"
msgstr ""
"  -t, --typeset-mode             changer la largeur par défaut de 72 à 100\n"

#: src/ptx.c:1732
msgid ""
"  -w, --width=NUMBER             output width in columns, reference "
"excluded\n"
msgstr ""
"  -w, --width=NOMBRE             largeur d'affichage en colonnes, sans "
"référence\n"

#: src/ptx.c:1830
#, c-format
msgid "invalid gap width: %s"
msgstr "largeur de saut incorrecte : %s"

#: src/ptx.c:1858
#, c-format
msgid "invalid line width: %s"
msgstr "largeur de ligne incorrecte : %s"

#: src/pwd.c:56
msgid ""
"Print the full filename of the current working directory.\n"
"\n"
msgstr ""
"Afficher le nom complet du fichier du répertoire de travail actuel.\n"
"\n"

#: src/pwd.c:60
msgid ""
"  -L, --logical\n"
"         use PWD from environment, even if it contains symlinks\n"
msgstr ""
"  -L, --logical\n"
"         utiliser PWD depuis l'environnement, même s'il contient des liens "
"symboliques\n"

#: src/pwd.c:64
msgid ""
"  -P, --physical\n"
"         resolve all symlinks\n"
msgstr ""
"  -P, --physical\n"
"         éviter tout lien symbolique\n"

#: src/pwd.c:70
msgid ""
"\n"
"If no option is specified, -P is assumed.\n"
msgstr ""
"\n"
"Si aucune option n’est indiquée, -P est tacite.\n"

#: src/pwd.c:163
#, c-format
msgid "failed to chdir to %s"
msgstr "impossible de changer de répertoire vers %s"

#: src/pwd.c:168 src/pwd.c:274 src/split.c:532
#, c-format
msgid "failed to stat %s"
msgstr "impossible d’obtenir l'état de %s"

#: src/pwd.c:232
#, c-format
msgid "couldn't find directory entry in %s with matching i-node"
msgstr ""
"impossible de repérer l'entrée du répertoire dans %s avec l'inœud "
"correspondant"

#: src/pwd.c:359
#, c-format
msgid "ignoring non-option arguments"
msgstr "ignore les arguments qui ne sont pas des options"

