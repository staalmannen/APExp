#: src/chcon.c:354
#, c-format
msgid ""
"Usage: %s [OPTION]... CONTEXT FILE...\n"
"  or:  %s [OPTION]... [-u USER] [-r ROLE] [-l RANGE] [-t TYPE] FILE...\n"
"  or:  %s [OPTION]... --reference=RFILE FILE...\n"
msgstr ""
"Utilisation : %s [OPTION]... CONTEXTE FICHIER...\n"
"         ou : %s [OPTION]... [-u UTILISATEUR] [-r RÔLE] [-l INTERVALLE] [-t "
"TYPE] FICHIER...\n"
"         ou : %s [OPTION]... --reference=FICHIER_R FICHIER...\n"

#: src/chcon.c:360
msgid ""
"Change the SELinux security context of each FILE to CONTEXT.\n"
"With --reference, change the security context of each FILE to that of "
"RFILE.\n"
msgstr ""
"Modifier le contexte de sécurité SELinux de chaque FICHIER en CONTEXTE.\n"
"Avec --reference, modifier le contexte de sécurité de chaque FICHIER à\n"
"celui de FICHIER_R.\n"

#: src/chcon.c:367 src/chown.c:110
msgid ""
"      --dereference\n"
"         affect the referent of each symbolic link (this is\n"
"         the default), rather than the symbolic link itself\n"
msgstr ""
"      --dereference\n"
"         affecter le référent de chaque lien symbolique (par\n"
"         défaut), au lieu du lien symbolique lui-même\n"

#: src/chcon.c:372
msgid ""
"  -h, --no-dereference\n"
"         affect symbolic links instead of any referenced file\n"
msgstr ""
"  -h, --no-dereference\n"
"         affecter les liens symboliques au lieu des fichiers\n"
"         référencés\n"

#: src/chcon.c:376
msgid ""
"  -u, --user=USER\n"
"         set user USER in the target security context\n"
msgstr ""
"  -u, --user=UTILISATEUR\n"
"         définir l'utilisateur UTILISATEUR dans le contexte de\n"
"         sécurité cible\n"

#: src/chcon.c:380
msgid ""
"  -r, --role=ROLE\n"
"         set role ROLE in the target security context\n"
msgstr ""
"  -r, --role=RÔLE\n"
"         définir le rôle RÔLE dans le contexte de sécurité cible\n"

#: src/chcon.c:384
msgid ""
"  -t, --type=TYPE\n"
"         set type TYPE in the target security context\n"
msgstr ""
"  -t, --type=TYPE\n"
"         définir le type TYPE dans le contexte de sécurité cible\n"

#: src/chcon.c:388
msgid ""
"  -l, --range=RANGE\n"
"         set range RANGE in the target security context\n"
msgstr ""
"  -l, --range=INTERVALLE\n"
"         définir l'intervalle INTERVALLE dans le contexte de\n"
"         sécurité cible\n"

#: src/chcon.c:392 src/chmod.c:445 src/chown.c:127
msgid ""
"      --no-preserve-root\n"
"         do not treat '/' specially (the default)\n"
msgstr ""
"      --no-preserve-root\n"
"         ne pas traiter « / » de manière spéciale (par défaut)\n"

#: src/chcon.c:396 src/chmod.c:449 src/chown.c:131
msgid ""
"      --preserve-root\n"
"         fail to operate recursively on '/'\n"
msgstr ""
"      --preserve-root\n"
"         bloquer le traitement récursif sur « / »\n"

#: src/chcon.c:400
msgid ""
"      --reference=RFILE\n"
"         use RFILE's security context rather than specifying a CONTEXT "
"value\n"
msgstr ""
"      --reference=FICHIER_R\n"
"         utiliser le contexte de sécurité de FICHIER_R au\n"
"         lieu d'indiquer une valeur de CONTEXTE\n"

#: src/chcon.c:404 src/chown.c:140
msgid ""
"  -R, --recursive\n"
"         operate on files and directories recursively\n"
msgstr ""
"  -R, --recursive\n"
"         opérer récursivement sur les fichiers et répertoires\n"

#: src/chcon.c:408 src/chmod.c:432 src/chown.c:106
msgid ""
"  -v, --verbose\n"
"         output a diagnostic for every file processed\n"
msgstr ""
"  -v, --verbose\n"
"         afficher un diagnostic pour chaque fichier traité\n"

