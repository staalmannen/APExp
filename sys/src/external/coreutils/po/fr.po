"derniers\n"
"         octets de chaque fichier\n"

#: src/head.c:125
#, c-format
msgid ""
"  -n, --lines=[-]NUM\n"
"         print the first NUM lines instead of the first %d;\n"
"         with the leading '-', print all but the last NUM lines of each "
"file\n"
msgstr ""
"  -n, --lines=[-]NUM\n"
"         afficher les NUM premières lignes au lieu des %d premières ;\n"
"         avec le préfixe « - », afficher toutes les lignes sauf les N\n"
