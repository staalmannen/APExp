#: src/df.c:1499
msgid ""
"Show information about the file system on which each FILE resides,\n"
"or all file systems by default.\n"
msgstr ""
"Afficher des renseignements sur le système de fichiers qui contient "
"FICHIER,\n"
"ou sur tous les systèmes de fichiers par défaut.\n"

#. TRANSLATORS: The thousands and decimal separators are best
#. adjusted to an appropriate default for your locale.
#: src/df.c:1508
msgid ""
"  -a, --all\n"
"         include pseudo, duplicate, inaccessible file systems\n"
msgstr ""
"  -a, --all\n"
"         inclure les systèmes de fichiers factices, dupliqués ou "
"inaccessibles\n"

#: src/df.c:1512
msgid ""
"  -B, --block-size=SIZE\n"
"         scale sizes by SIZE before printing them; see SIZE format below;\n"
"         E.g., '-BM' prints sizes in units of 1,048,576 bytes\n"
msgstr ""
"  -B, --block-size=TAILLE\n"
"         convertir les tailles en TAILLE avant de les afficher ; consultez\n"
"         le format de TAILLE ci-dessous\n"
"         par exemple, « -BM » affiche les tailles en unités de 1 048 576 "
"octets ;\n"

#: src/df.c:1517
msgid ""
"  -h, --human-readable\n"
"         print sizes in powers of 1024 (e.g., 1023M)\n"
msgstr ""
"  -h, --human-readable\n"
"         afficher les tailles dans des puissances de 1024 (par exemple "
"1023M)\n"

#: src/df.c:1521
msgid ""
"  -H, --si\n"
"         print sizes in powers of 1000 (e.g., 1.1G)\n"
msgstr ""
"  -H, --si\n"
"         afficher les tailles avec un multiple de 1000 (par exemple 1,1G)\n"

#: src/df.c:1525
msgid ""
"  -i, --inodes\n"
"         list inode information instead of block usage\n"
msgstr ""
"  -i, --inodes\n"
"         afficher les renseignements des inœuds, pas des blocs\n"

#: src/df.c:1529 src/du.c:344
msgid ""
"  -k\n"
"         like --block-size=1K\n"
msgstr ""
"  -k\n"
"         identique à --block-size=1K\n"

#: src/df.c:1533
msgid ""
"  -l, --local\n"
"         limit listing to local file systems\n"
msgstr ""
"  -l, --local\n"
"         limiter le parcours aux systèmes de fichiers locaux\n"

#: src/df.c:1537
msgid ""
"      --no-sync\n"
"         do not invoke sync before getting usage info (default)\n"
msgstr ""
"      --no-sync\n"
"         ne pas réaliser de synchronisation avant d'obtenir les\n"
"         renseignements d'utilisation (par défaut)\n"

#: src/df.c:1541
msgid ""
"      --output[=FIELD_LIST]\n"
"         use the output format defined by FIELD_LIST,\n"
"         or print all fields if FIELD_LIST is omitted\n"
msgstr ""
"      --output[=LISTE_CHAMPS]\n"
"         utiliser le format de sortie défini par LISTE_CHAMPS,\n"
"         ou afficher tous les champs en absence d’argument.\n"

#: src/df.c:1546
msgid ""
"  -P, --portability\n"
"         use the POSIX output format\n"
msgstr ""
"  -P, --portability\n"
"         utiliser le format de sortie POSIX\n"

#: src/df.c:1550
msgid ""
"      --sync\n"
"         invoke sync before getting usage info\n"
msgstr ""
"      --sync\n"
"         invoquer sync avant d'obtenir les renseignements d'utilisation\n"

#: src/df.c:1554
msgid ""
"      --total\n"
"         elide all entries insignificant to available space,\n"
"         and produce a grand total\n"
msgstr ""
"      --total\n"
"         passer sous silence toutes les entrées non pertinentes\n"
"         pour l'espace disponible et afficher un total global\n"

#: src/df.c:1559
msgid ""
"  -t, --type=TYPE\n"
"         limit listing to file systems of type TYPE\n"
msgstr ""
"  -t, --type=TYPE\n"
"         limiter l'affichage aux systèmes de fichier de type TYPE\n"

#: src/df.c:1563
msgid ""
"  -T, --print-type\n"
"         print file system type\n"
msgstr ""
"  -T, --print-type\n"
"         afficher le type du système de fichiers\n"

#: src/df.c:1567
msgid ""
"  -x, --exclude-type=TYPE\n"
"         limit listing to file systems not of type TYPE\n"
msgstr ""
"  -x, --exclude-type=TYPE\n"
"         limiter l'affichage aux autres systèmes de fichiers\n"
"         que ceux de type TYPE\n"

#: src/df.c:1571
msgid ""
"  -v\n"
"         (ignored)\n"
msgstr ""
"  -v\n"
"         (ignoré)\n"

#: src/df.c:1579
msgid ""
"\n"
"FIELD_LIST is a comma-separated list of columns to be included.  Valid\n"
"field names are: 'source', 'fstype', 'itotal', 'iused', 'iavail', 'ipcent',\n"
"'size', 'used', 'avail', 'pcent', 'file' and 'target' (see info page).\n"
msgstr ""
"\n"
"LISTE_CHAMPS est une liste séparée par des virgules de colonnes à inclure. "
"Les\n"
"noms de champs possibles sont : « source », « fstype », « itotal », "
"« iused »,\n"
"« iavail », « ipcent », « size », « used », « avail », « pcent », « file » "
"et\n"
"« target » (consultez la page info).\n"

#: src/df.c:1605
#, c-format
msgid "options %s and %s are mutually exclusive"
msgstr "les options %s et %s sont mutuellement exclusives"

#: src/df.c:1755
#, c-format
msgid "file system type %s both selected and excluded"
msgstr "le système de fichiers %s est à la fois sélectionné et exclu"

#: src/df.c:1806
msgid "Warning: "
msgstr "Avertissement : "

#: src/df.c:1808 src/stat.c:960
msgid "cannot read table of mounted file systems"
msgstr "impossible de lire la table des systèmes de fichiers montés"

#: src/df.c:1843
#, c-format
msgid "no file systems processed"
msgstr "aucun système de fichiers traité"

#. This is a proper name. See the gettext manual, section Names.
#: src/dircolors.c:35
msgid "H. Peter Anvin"
msgstr "H. Peter Anvin"

#: src/dircolors.c:103
msgid ""
"Output commands to set the LS_COLORS environment variable.\n"
"\n"
"Determine format of output:\n"
msgstr ""
"Commande d'affichage pour initialiser la variable d'environnement "
"LS_COLORS.\n"
"\n"
"Déterminer le format de sortie :\n"

#: src/dircolors.c:108
msgid ""
"  -b, --sh, --bourne-shell\n"
"         output Bourne shell code to set LS_COLORS\n"
msgstr ""
"  -b, --sh, --bourne-shell\n"
"         code de sortie pour un shell Bourne pour\n"
"         initialiser la variable LS_COLORS\n"

#: src/dircolors.c:112
msgid ""
"  -c, --csh, --c-shell\n"
"         output C shell code to set LS_COLORS\n"
msgstr ""
"  -c, --csh, --c-shell\n"
"         code de sortie pour un shell C pour initialiser\n"
"         la variable LS_COLORS\n"

#: src/dircolors.c:116
msgid ""
"  -p, --print-database\n"
"         output defaults\n"
msgstr ""
"  -p, --print-data-base\n"
"         utiliser les valeurs par défaut\n"

#: src/dircolors.c:120
msgid ""
"      --print-ls-colors\n"
"         output fully escaped colors for display\n"
msgstr ""
"      --print-ls-colors\n"
"         envoyer les couleurs avec code d'échappement complet pour "
"affichage\n"

#: src/dircolors.c:126
msgid ""
"\n"
"If FILE is specified, read it to determine which colors to use for which\n"
"file types and extensions.  Otherwise, a precompiled database is used.\n"
"For details on the format of these files, run 'dircolors --print-database'.\n"
msgstr ""
"\n"
"Si FICHIER est fourni, le lire pour déterminer les couleurs à utiliser pour "
"les\n"
"types de fichiers et les extensions. Autrement, la base de données "
"précompilée\n"
"sera utilisée. Pour obtenir des précisions sur le format de ces fichiers,\n"
"exécutez « dircolors --print-database ».\n"

#: src/dircolors.c:338
#, c-format
msgid "%s:%td: invalid line;  missing second token"
msgstr "%s:%td : ligne incorrecte ; second jeton manquant"

#: src/dircolors.c:393
#, c-format
msgid "%s:%td: unrecognized keyword %s"
msgstr "%s:%td : mot clef %s non reconnu"

#: src/dircolors.c:394
msgid "<internal>"
msgstr "<interne>"

#: src/dircolors.c:479
#, c-format
msgid ""
"the options to output non shell syntax,\n"
"and to select a shell syntax are mutually exclusive"
msgstr ""
"les options pour envoyer la syntaxe pas pour le shell et la\n"
"sélection de la syntaxe du shell sont mutuellement exclusives"

#: src/dircolors.c:487
#, c-format
msgid "options --print-database and --print-ls-colors are mutually exclusive"
msgstr ""
"les options --print-database et --print-ls-colors sont mutuellement "
"exclusives"

#: src/dircolors.c:498
msgid "file operands cannot be combined with --print-database (-p)"
msgstr ""
"les opérandes de fichier ne peuvent pas être combinés avec --print-database "
"(-p)"

#: src/dircolors.c:520
#, c-format
msgid "no SHELL environment variable, and no shell type option given"
msgstr ""
"aucune variable d'environnement SHELL et aucune option de type de shell "
"donnée"

#: src/dirname.c:49
#, c-format
msgid "Usage: %s [OPTION] NAME...\n"
msgstr "Utilisation : %s [OPTION] NOM...\n"

#: src/dirname.c:53
msgid ""
"Output each NAME with its last non-slash component and trailing slashes\n"
"removed; if NAME contains no /'s, output '.' (meaning the current "
"directory).\n"
"\n"
msgstr ""
"Afficher chaque NOM en supprimant son dernier composant et sa barre oblique\n"
"finale ; si NOM ne contient pas de « / », la sortie sera « . » (signifiant\n"
"le répertoire actuel).\n"
"\n"

#: src/dirname.c:64
#, c-format
msgid ""
"\n"
"Examples:\n"
"  %s /usr/bin/          -> \"/usr\"\n"
"  %s dir1/str dir2/str  -> \"dir1\" followed by \"dir2\"\n"
"  %s stdio.h            -> \".\"\n"
msgstr ""
"\n"
"Exemples :\n"
"  %s /usr/bin           → « /usr »\n"
"  %s rep1/cha rep2/cha  → « rep1 » suivi de « rep2 »\n"
"  %s stdio.h            → « . »\n"

#: src/du.c:279 src/sort.c:421 src/wc.c:189
#, c-format
msgid ""
"Usage: %s [OPTION]... [FILE]...\n"
"  or:  %s [OPTION]... --files0-from=F\n"
msgstr ""
"Utilisation : %s [OPTION]... [FICHIER]...\n"
"         ou : %s [OPTION]... --files0-from=F\n"

#: src/du.c:283
msgid ""
"Summarize device usage of the set of FILEs, recursively for directories.\n"
msgstr ""
"Totaliser l'occupation du périphérique pour l'ensemble des FICHIERs,\n"
"récursivement pour les répertoires.\n"

#: src/du.c:289 src/env.c:130 src/printenv.c:69
msgid ""
"  -0, --null\n"
"         end each output line with NUL, not newline\n"
msgstr ""
"  -0, --null\n"
"         terminer chaque ligne de sortie par NUL au lieu d'un\n"
"         saut de ligne\n"

#: src/du.c:293
msgid ""
"  -a, --all\n"
"         write counts for all files, not just directories\n"
msgstr ""
"  -a, --all\n"
"         afficher le décompte pour tous les fichiers, pas\n"
"         seulement pour les répertoires\n"

#: src/du.c:297
msgid ""
"  -A, --apparent-size\n"
"         print apparent sizes rather than device usage;\n"
"         although the apparent size is usually smaller, it may be\n"
"         larger due to holes in ('sparse') files,\n"
"         internal fragmentation, indirect blocks, etc.\n"
msgstr ""
"  -A, --apparent-size\n"
"         afficher les tailles apparentes au lieu de l'occupation\n"
"         d’espace du périphérique ; même si la taille apparente est\n"
"         habituellement plus petite, elle peut être plus grande\n"
"         en raison de trous dans les fichiers (« sparse »), de\n"
"         la fragmentation, de blocs indirects et autres raisons\n"
"         similaires\n"

#: src/du.c:304
msgid ""
"  -B, --block-size=SIZE\n"
"         scale sizes by SIZE before printing them; See SIZE format below;\n"
"         E.g., '-BM' prints sizes in units of 1,048,576 bytes\n"
msgstr ""
"  -B, --block-size=TAILLE\n"
"         convertir les tailles en TAILLE avant de les afficher ; consultez "
"le\n"
"         format de TAILLE ci-dessous\n"
"         par exemple, « -BM » affiche les tailles en unités de 1 048 576 "
"octets ;\n"

#: src/du.c:309
msgid ""
"  -b, --bytes\n"
"         equivalent to '--apparent-size --block-size=1'\n"
msgstr ""
"  -b, --bytes\n"
"         équivalent à « --apparent-size --block-size=1 »\n"

#: src/du.c:313
msgid ""
"  -c, --total\n"
"         produce a grand total\n"
msgstr ""
"  -c, --total\n"
"         produire le total général\n"

#: src/du.c:317
msgid ""
"  -D, --dereference-args\n"
"         dereference only symlinks that are listed on the command line\n"
msgstr ""
"  -D, --dereference-args\n"
"         ne déréférencer que les liens symboliques sur la ligne de commande\n"

#: src/du.c:321
msgid ""
"  -d, --max-depth=N\n"
"         print the total for a directory (or file, with --all)\n"
"         only if it is N or fewer levels below the command\n"
"         line argument;  --max-depth=0 is the same as --summarize\n"
msgstr ""
"  -d, --max-depth=N\n"
"         afficher le total pour un répertoire (ou un fichier, avec --all)\n"
"         seulement s'il est à N niveaux ou moins selon les arguments de la\n"
"         ligne de commande ; --max-depth=0 est identique à --summarize\n"

#: src/du.c:327
msgid ""
"      --files0-from=F\n"
"         summarize device usage of the NUL-terminated file names\n"
"         specified in file F;  if F is -, read names from standard input\n"
msgstr ""
"      --files0-from=F\n"
"         résumer l'occupation du périphérique pour les noms de fichiers,\n"
"         terminés par NUL, indiqués dans le fichier F ; si F est -, alors\n"
"         les noms sont lus sur l'entrée standard\n"

#: src/du.c:332
msgid ""
"  -H\n"
"         equivalent to --dereference-args (-D)\n"
msgstr ""
"  -H\n"
"         équivalent à --dereference-args (-D)\n"

#: src/du.c:336
msgid ""
"  -h, --human-readable\n"
"         print sizes in human readable format (e.g., 1K 234M 2G)\n"
msgstr ""
"  -h, --human-readable\n"
"         afficher les tailles dans un format lisible (par exemple 1K, 234M "
"ou 2G)\n"

#: src/du.c:340
msgid ""
"      --inodes\n"
"         list inode usage information instead of block usage\n"
msgstr ""
"      --inodes\n"
"         afficher les renseignements des inœuds à la place de ceux\n"
"         des blocs\n"

#: src/du.c:348
msgid ""
"  -L, --dereference\n"
"         dereference all symbolic links\n"
msgstr ""
"  -L, --dereference\n"
"         déréférencer tous les liens symboliques\n"

#: src/du.c:352
msgid ""
"  -l, --count-links\n"
"         count sizes many times if hard linked\n"
msgstr ""
"  -l, --count-links\n"
"         comptabiliser les tailles de tous les liens directs\n"

#: src/du.c:356
msgid ""
"  -m\n"
"         like --block-size=1M\n"
msgstr ""
"  -m\n"
"         identique à --block-size=1M\n"

#: src/du.c:360
msgid ""
"  -P, --no-dereference\n"
"         don't follow any symbolic links (this is the default)\n"
msgstr ""
"  -P, --no-dereference\n"
"         ne pas suivre les liens symboliques (par défaut)\n"

#: src/du.c:364
msgid ""
"  -S, --separate-dirs\n"
"         for directories do not include size of subdirectories\n"
msgstr ""
"  -S, --separate-dirs\n"
"         ne pas inclure la taille des sous-répertoires\n"

#: src/du.c:368
msgid ""
"      --si\n"
"         like -h, but use powers of 1000 not 1024\n"
msgstr ""
"      --si\n"
"         identique à -h mais en multiple de 1000 au lieu de 1024\n"

#: src/du.c:372
msgid ""
"  -s, --summarize\n"
"         display only a total for each argument\n"
msgstr ""
"  -s, --summarize\n"
"         n'afficher qu'un total pour chaque argument\n"

#: src/du.c:376
msgid ""
"  -t, --threshold=SIZE\n"
"         exclude entries smaller than SIZE if positive,\n"
"         or entries greater than SIZE if negative\n"
msgstr ""
"  -t, --threshold=TAILLE\n"
"         exclure les entrées plus petites que TAILLE si\n"
"         positive, ou plus grandes que TAILLE si négative\n"

#: src/du.c:381
msgid ""
"      --time\n"
"         show time of the last modification of any file in the directory,\n"
"         or any of its subdirectories\n"
msgstr ""
"      --time\n"
"         afficher l'heure de la dernière modification de tous les fichiers\n"
"         du répertoire ou des sous-répertoires\n"

#: src/du.c:386
msgid ""
"      --time=WORD\n"
"         show time as WORD instead of modification time:\n"
"         atime, access, use, ctime or status\n"
msgstr ""
"      --time=MOT\n"
"         afficher l'heure de MOT au lieu de l'heure de modification :\n"
"         atime, access, use, ctime ou status.\n"

#: src/du.c:391
msgid ""
"      --time-style=STYLE\n"
"         time/date format with --time; see TIME_STYLE below\n"
msgstr ""
"      --time-style=STYLE\n"
"         formatter heure/date avec --time. Voyez STYLE_TEMPS ci-dessous\n"

#: src/du.c:395
msgid ""
"  -X, --exclude-from=FILE\n"
"         exclude files that match any pattern in FILE\n"
msgstr ""
"  -X, --exclude-from=FICHIER\n"
"         exclure les fichiers correspondants à un des\n"
"         motifs du FICHIER\n"

#: src/du.c:399
msgid ""
"      --exclude=PATTERN\n"
"         exclude files that match PATTERN\n"
msgstr ""
"      --exclude=MOTIF\n"
"         exclure les fichiers correspondants à MOTIF\n"

#: src/du.c:403
msgid ""
"  -x, --one-file-system\n"
"         skip directories on different file systems\n"
msgstr ""
"  -x, --one-file-system\n"
"         ignorer les répertoires de différents systèmes de\n"
"         fichiers\n"

#: src/du.c:411
msgid ""
"\n"
"The --time-style STYLE argument can be full-iso, long-iso, iso, or +FORMAT.\n"
"FORMAT is interpreted like in date(1).\n"
"Also the TIME_STYLE environment variable sets the default style to use.\n"
msgstr ""
"\n"
"L'argument --time=STYLE peut être full-iso, long-iso, iso ou +FORMAT.\n"
"FORMAT est interprété comme avec date(1).\n"
"La variable d'environnement TIME_STYME défini le style par défaut à "
"utiliser.\n"

#: src/du.c:742
#, c-format
msgid "fts_read failed: %s"
msgstr "échec de fts_read : %s"

#: src/du.c:870
#, c-format
msgid "invalid maximum depth %s"
msgstr "profondeur maximale %s incorrecte"

#: src/du.c:900
#, c-format
msgid "invalid --threshold argument '-0'"
msgstr "argument « -0 » de --threshold incorrect"

#: src/du.c:983
#, c-format
msgid "cannot both summarize and show all entries"
msgstr "impossible d'afficher à la fois un résumé et toutes les entrées"

#: src/du.c:990
#, c-format
msgid "warning: summarizing is the same as using --max-depth=0"
msgstr ""
"avertissement : résumer est la même chose qu'utiliser l'option --max-depth=0"

#: src/du.c:995
#, c-format
msgid "warning: summarizing conflicts with --max-depth=%td"
msgstr "avertissement : conflit avec --max-depth=%td à la génération du résumé"

#: src/du.c:1007
#, c-format
msgid "warning: options --apparent-size and -b are ineffective with --inodes"
msgstr ""
"avertissement : les options --apparent-size et -b sont inefficaces avec --"
"inodes"

#: src/du.c:1074 src/sort.c:4813 src/wc.c:882
msgid "file operands cannot be combined with --files0-from"
msgstr ""
"les opérandes de fichier ne peuvent pas être combinés avec --files0-from"

#: src/du.c:1141 src/sort.c:4834 src/wc.c:946
#, c-format
msgid "when reading file names from standard input, no file name of %s allowed"
msgstr ""
"le nom de fichier %s n'est pas autorisé lors de la lecture de l'entrée "
"standard"

#: src/du.c:1158 src/du.c:1166 src/wc.c:959 src/wc.c:966
msgid "invalid zero-length file name"
msgstr "nom de fichier de longueur nulle incorrect"

#. This is a proper name. See the gettext manual, section Names.
#: src/echo.c:28
msgid "Brian Fox"
msgstr "Brian Fox"

#. This is a proper name. See the gettext manual, section Names.
#: src/echo.c:29
msgid "Chet Ramey"
msgstr "Chet Ramey"

#: src/echo.c:43
#, c-format
msgid ""
"Usage: %s [SHORT-OPTION]... [STRING]...\n"
"  or:  %s LONG-OPTION\n"
msgstr ""
"Utilisation : %s [OPTION_COURTE]... [CHAÎNE]...\n"
"         ou : %s OPTION_LONGUE\n"

#: src/echo.c:47
msgid ""
"Echo the STRING(s) to standard output.\n"
"\n"
msgstr ""
"Duplique la ou les CHAÎNEs sur la sortie standard.\n"
"\n"

#: src/echo.c:51
msgid "  -n     do not output the trailing newline\n"
msgstr "  -n     ne pas afficher de saut de ligne de terminaison\n"

#: src/echo.c:55
msgid "  -e     enable interpretation of backslash escapes (default)\n"
msgstr ""
"  -e     activer l'interprétation de protection par barre oblique inverse "
"(par défaut)\n"

#: src/echo.c:58
msgid "  -e     enable interpretation of backslash escapes\n"
msgstr ""
"  -e     activer l'interprétation de protection par barre oblique inverse\n"

#: src/echo.c:62
msgid "  -E     disable interpretation of backslash escapes\n"
msgstr ""
"  -E     désactiver l'interprétation de protection par barre oblique "
"inverse\n"

#: src/echo.c:65
msgid "  -E     disable interpretation of backslash escapes (default)\n"
msgstr ""
"  -E     désactiver l'interprétation de protection par barre oblique inverse "
"(par défaut)\n"

#: src/echo.c:70
msgid ""
"\n"
"If -e is in effect, the following sequences are recognized:\n"
"\n"
msgstr ""
"\n"
"Si -e est effectif, les séquences suivantes sont reconnues :\n"
"\n"

#: src/echo.c:75 src/printf.c:70
msgid ""
"  \\\\      backslash\n"
"  \\a      alert (BEL)\n"
"  \\b      backspace\n"
"  \\c      produce no further output\n"
"  \\e      escape\n"
"  \\f      form feed\n"
"  \\n      new line\n"
"  \\r      carriage return\n"
"  \\t      horizontal tab\n"
"  \\v      vertical tab\n"
msgstr ""
"  \\\\     barre oblique inverse\n"
"  \\a     alerte (SON)\n"
"  \\b     retour arrière\n"
"  \\c     bloquer l'affichage ultérieur\n"
"  \\e     échappement\n"
"  \\f     saut de page\n"
"  \\n     changement de ligne\n"
"  \\r     retour chariot\n"
"  \\t     tabulation horizontale\n"
"  \\v     tabulation verticale\n"

# Seulement la traduction est correctement alignée (Stéphane)
#: src/echo.c:87
msgid ""
"  \\0NNN   byte with octal value NNN (1 to 3 digits)\n"
"  \\xHH    byte with hexadecimal value HH (1 to 2 digits)\n"
msgstr ""
"  \\0NNN  octet de valeur octale NNN (1 à 3 chiffres)\n"
"  \\xHH   octet de valeur hexadécimale HH (1 ou 2 chiffres)\n"

#: src/echo.c:92
msgid ""
"\n"
"Consider using the printf(1) command instead,\n"
"as it avoids problems when outputting option-like strings.\n"
msgstr ""
"\n"
"Envisagez d'utiliser la commande printf(1) car elle évite\n"
"les problèmes associés à l'affichage des chaînes d'option.\n"

#. This is a proper name. See the gettext manual, section Names.
#: src/env.c:35 src/printenv.c:45 src/whoami.c:33
msgid "Richard Mlynarik"
msgstr "Richard Mlynarik"

#: src/env.c:113
#, c-format
msgid "Usage: %s [OPTION]... [-] [NAME=VALUE]... [COMMAND [ARG]...]\n"
msgstr "Utilisation : %s [OPTION]... [-] [NOM=VALEUR]... [COMMANDE [ARG]...]\n"

#: src/env.c:116
msgid "Set each NAME to VALUE in the environment and run COMMAND.\n"
msgstr ""
"Initialiser chaque NOM à VALEUR dans l'environnement et exécuter COMMANDE.\n"

#: src/env.c:122
msgid ""
"  -a, --argv0=ARG\n"
"         pass ARG as the zeroth argument of COMMAND\n"
msgstr ""
"  -a, --argv0=ARG\n"
"         passer ARG comme argument zéro de la commande\n"

#: src/env.c:126
msgid ""
"  -i, --ignore-environment\n"
"         start with an empty environment\n"
msgstr ""
"  -i, --ignore-environment\n"
"         démarrer avec un environnement vide\n"

#: src/env.c:134
msgid ""
"  -u, --unset=NAME\n"
"         remove variable from the environment\n"
msgstr ""
"  -u, --unset=NOM\n"
"         supprimer la variable de l'environnement\n"

#: src/env.c:138
msgid ""
"  -C, --chdir=DIR\n"
"         change working directory to DIR\n"
msgstr ""
"  -C, --chdir=RÉP\n"
"         changer le répertoire de travail à RÉP\n"

#: src/env.c:142
msgid ""
"  -S, --split-string=S\n"
"         process and split S into separate arguments;\n"
"         used to pass multiple arguments on shebang lines\n"
msgstr ""
"  -S, --split-string=S\n"
"         traiter et scinder S en groupes d'arguments séparés;\n"
"         utilisé pour passer plusieurs arguments sur la ligne shebang\n"

#: src/env.c:147
msgid ""
"      --block-signal[=SIG]\n"
"         block delivery of SIG signal(s) to COMMAND\n"
msgstr ""
"      --block-signal[=SIG]\n"
"         bloquer la réception du ou des signaux SIG à COMMANDE\n"

#: src/env.c:151
msgid ""
"      --default-signal[=SIG]\n"
"         reset handling of SIG signal(s) to the default\n"
msgstr ""
"      --default-signal[=SIG]\n"
"         réinitialiser la gestion du ou des signaux à la valeur par défaut\n"

#: src/env.c:155
msgid ""
"      --ignore-signal[=SIG]\n"
"         set handling of SIG signal(s) to do nothing\n"
msgstr ""
"      --ignore-signal[=SIG]\n"
"         ne pas gérer le ou les signaux SIG\n"

