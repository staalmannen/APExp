msgstr "Utilisation : %s [OPTION]... [FICHIER]\n"

#: src/basenc.c:108
msgid "basenc encode or decode FILE, or standard input, to standard output.\n"
msgstr ""
"Encoder ou décoder le FICHIER ou l'entrée standard avec basenc vers la "
"sortie standard.\n"

#: src/basenc.c:112
#, c-format
msgid "Base%d encode or decode FILE, or standard input, to standard output.\n"
msgstr ""
"Encoder ou décoder le FICHIER ou l'entrée standard en base%d, vers la sortie "
"standard.\n"

#: src/basenc.c:120
msgid ""
"      --base64\n"
"         same as 'base64' program (RFC4648 section 4)\n"
msgstr ""
"      --base64\n"
"         comme le programme « base64 » (RFC4648 section 4)\n"

#: src/basenc.c:124
msgid ""
"      --base64url\n"
"         file- and url-safe base64 (RFC4648 section 5)\n"
msgstr ""
"      --base64url\n"
"         base64 sûr pour fichier et url (RFC4648 section 5)\n"

#: src/basenc.c:128
msgid ""
"      --base58\n"
"         visually unambiguous base58 encoding\n"
msgstr ""
"      --base58\n"
"         visualiser l'encodage base58 non ambigu\n"

#: src/basenc.c:132
msgid ""
"      --base32\n"
"         same as 'base32' program (RFC4648 section 6)\n"
msgstr ""
"      --base32\n"
"         comme le programme « base32 » (RFC4648 section 6)\n"

#: src/basenc.c:136
msgid ""
"      --base32hex\n"
"         extended hex alphabet base32 (RFC4648 section 7)\n"
msgstr ""
"      --base32hex\n"
"         étend l'alphabet hexadécimal de base32 (RFC4648 section 7)\n"

#: src/basenc.c:140
msgid ""
"      --base16\n"
"         hex encoding (RFC4648 section 8)\n"
msgstr ""
"      --base16\n"
"         encodage hexadécimal (RFC4648 section 8)\n"

#: src/basenc.c:144
msgid ""
"      --base2msbf\n"
"         bit string with most significant bit (msb) first\n"
msgstr ""
"      --base2msbf\n"
"         chaîne de bits avec le bit le plus significatif (msb) en premier\n"

#: src/basenc.c:148
msgid ""
"      --base2lsbf\n"
"         bit string with least significant bit (lsb) first\n"
msgstr ""
"      --base2lsbf\n"
"         chaîne de bits avec le bit le moins significatif (lsb) en premier\n"

#: src/basenc.c:153
msgid ""
"  -d, --decode\n"
"         decode data\n"
msgstr ""
"  -d, --decode\n"
"         décoder les données\n"

#: src/basenc.c:157
msgid ""
"  -i, --ignore-garbage\n"
"         when decoding, ignore non-alphabet characters\n"
msgstr ""
"  -i, --ignore-garbage\n"
"         lors du décodage, ignorer les caractères non\n"
"         alphabétiques\n"

#: src/basenc.c:161
msgid ""
"  -w, --wrap=COLS\n"
"         wrap encoded lines after COLS character (default 76).\n"
"         Use 0 to disable line wrapping\n"
msgstr ""
"  -w, --wrap=COLS\n"
"         effectuer la césure des lignes après COLS caractères\n"
"         (76 par défaut). Utilisez 0 pour désactiver la césure\n"

#: src/basenc.c:167
msgid ""
"      --z85\n"
"         ascii85-like encoding (ZeroMQ spec:32/Z85);\n"
"         when encoding, input length must be a multiple of 4;\n"
"         when decoding, input length must be a multiple of 5\n"
msgstr ""
"      --z85\n"
"         encodage similaire à ascii85 (ZeroMQ spec:32/Z85);\n"
"         à l'encodage, la longueur de l'entrée doit être un multiple de 4;\n"
"         au décodage, la longueur de l'entrée doit être un multiple de 5\n"

#: src/basenc.c:177
msgid ""
"\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"Lors du décodage, l'entrée peut contenir des sauts de lignes en plus des\n"
"octets de l'alphabet formel. Utilisez --ignore-garbage pour tenter de\n"
"récupérer tout autre octet non alphabétique dans le flux codé.\n"

#: src/basenc.c:184
#, c-format
msgid ""
"\n"
"The data are encoded as described for the %s alphabet in RFC 4648.\n"
"When decoding, the input may contain newlines in addition to the bytes of\n"
"the formal %s alphabet.  Use --ignore-garbage to attempt to recover\n"
"from any other non-alphabet bytes in the encoded stream.\n"
msgstr ""
"\n"
"Les données sont codées comme décrit pour l'alphabet %s dans la RFC 4648.\n"
"Lors du décodage, l'entrée peut contenir des sauts de lignes en plus des\n"
"octets de l'alphabet %s formel. Utilisez --ignore-garbage pour tenter de\n"
"récupérer tout autre octet non alphabétique dans le flux codé.\n"

#: src/basenc.c:879
#, c-format
msgid "invalid input (length must be multiple of 4 characters)"
msgstr "entrée invalide (la longueur doit être un multiple de 4 caractères)"

#: src/basenc.c:1479 src/cat.c:972 src/fmt.c:459
#, c-format
msgid "closing standard input"
msgstr "fermeture de l'entrée standard"

