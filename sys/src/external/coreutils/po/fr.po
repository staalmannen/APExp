msgstr "argument %s incorrect"

#: src/stty.c:1178
#, c-format
msgid "invalid ispeed %s"
msgstr "vitesse d'entrée %s incorrecte"

#: src/stty.c:1192
#, c-format
msgid "invalid ospeed %s"
msgstr "vitesse de sortie %s incorrecte"

#: src/stty.c:1211
#, c-format
msgid "%s: error setting %s"
msgstr "%s : erreur lors de la définition de %s"

#: src/stty.c:1251
#, c-format
msgid "invalid line discipline %s"
msgstr "procédure de contrôle %s incorrecte"

#: src/stty.c:1344
#, c-format
msgid "only one device may be specified"
msgstr "un seul périphérique peut être indiqué"

#: src/stty.c:1382
#, c-format
msgid ""
"the options for verbose and stty-readable output styles are\n"
"mutually exclusive"
msgstr ""
"les options pour le mode bavard et les styles de sortie compatibles avec "
"stty\n"
"sont mutuellement exclusives"

#: src/stty.c:1388
#, c-format
msgid "when specifying an output style, modes may not be set"
msgstr ""
"les mode ne peuvent pas être initialisés quand le style de sortie est indiqué"

#: src/stty.c:1406
#, c-format
msgid "%s: couldn't reset non-blocking mode"
msgstr "%s : impossible de réinitialiser le mode non bloquant"

#: src/stty.c:1448
#, c-format
msgid "indx: mode: actual mode"
msgstr "indx: mode: mode actuel"

#: src/stty.c:1459
#, c-format
msgid "%s: unable to perform all requested operations"
msgstr "%s : impossible d'effectuer toutes les opérations demandées"

#: src/stty.c:1731
#, c-format
