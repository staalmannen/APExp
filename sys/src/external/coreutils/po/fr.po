#: src/cp.c:160 src/mv.c:253
#, c-format
msgid ""
"Usage: %s [OPTION]... [-T] SOURCE DEST\n"
"  or:  %s [OPTION]... SOURCE... DIRECTORY\n"
"  or:  %s [OPTION]... -t DIRECTORY SOURCE...\n"
msgstr ""
"Utilisation : %s [OPTION]... [-T] SOURCE DEST\n"
"         ou : %s [OPTION]... SOURCE... RÉPERTOIRE\n"
"         ou : %s [OPTION]... -t RÉPERTOIRE SOURCE...\n"

#: src/cp.c:166
msgid "Copy SOURCE to DEST, or multiple SOURCE(s) to DIRECTORY.\n"
msgstr "Copier la SOURCE vers DEST ou plusieurs SOURCEs vers RÉPERTOIRE.\n"

#: src/cp.c:172
msgid ""
"  -a, --archive\n"
"         same as -dR --preserve=all\n"
msgstr ""
"  -a, --archive\n"
"         identique à -dR --preserve=all\n"

#: src/cp.c:176
msgid ""
"      --attributes-only\n"
"         don't copy the file data, just the attributes\n"
msgstr ""
"      --attributes-only\n"
"         ne pas copier les données du fichier, seulement\n"
"         les attributs\n"

#: src/cp.c:180 src/install.c:615 src/ln.c:441 src/mv.c:265
msgid ""
"      --backup[=CONTROL]\n"
"         make a backup of each existing destination file\n"
msgstr ""
"      --backup[=CONTROL]\n"
"         archiver chaque fichier de destination existant\n"

#: src/cp.c:184 src/install.c:619 src/ln.c:445 src/mv.c:269
msgid ""
"  -b\n"
"         like --backup but does not accept an argument\n"
msgstr ""
"  -b\n"
"         comme --backup mais n'accepte pas d'argument\n"

#: src/cp.c:188
msgid ""
"      --copy-contents\n"
"         copy contents of special files when recursive\n"
msgstr ""
"      --copy-contents\n"
"         copier le contenu des fichiers spéciaux en mode\n"
"         récursif\n"

#: src/cp.c:192
msgid ""
"  -d\n"
"         same as --no-dereference --preserve=links\n"
msgstr ""
"  -d\n"
"         identique à --no-dereference --preserve=links\n"

#: src/cp.c:196 src/install.c:644 src/mv.c:273
msgid ""
"      --debug\n"
"         explain how a file is copied.  Implies -v\n"
msgstr ""
"      --debug\n"
"         explique comment un fichier est copié. Implique -v\n"

#: src/cp.c:200
msgid ""
"  -f, --force\n"
"         if an existing destination file cannot be opened, remove it and "
"try\n"
"         again (this option is ignored when the -n option is also used)\n"
msgstr ""
"  -f, --force\n"
"         si un fichier de destination existe et ne peut être ouvert, alors "
"le\n"
"         supprimer et réessayer (cette option est ignorée si l'option -n "
"est\n"
"         aussi utilisée)\n"

#: src/cp.c:205
msgid ""
"  -i, --interactive\n"
"         prompt before overwrite (overrides a previous -n option)\n"
msgstr ""
"  -i, --interactive\n"
"         demander confirmation avant d'écraser (annule\n"
"         l'option -n précédente)\n"

#: src/cp.c:209
msgid ""
"  -H\n"
"         follow command-line symbolic links in SOURCE\n"
msgstr ""
"  -H\n"
"         suivre les liens symboliques en ligne de commande\n"
"         dans SOURCE\n"

#: src/cp.c:213
msgid ""
"  -L, --dereference\n"
"         always follow symbolic links in SOURCE\n"
msgstr ""
"  -L, --dereference\n"
"         toujours suivre les liens symboliques dans SOURCE\n"

#: src/cp.c:217
msgid ""
"  -P, --no-dereference\n"
"         never follow symbolic links in SOURCE\n"
msgstr ""
"  -P, --no-dereference\n"
"         ne jamais suivre les liens symboliques dans SOURCE\n"

#: src/cp.c:221
msgid ""
"      --keep-directory-symlink\n"
"         follow existing symlinks to directories\n"
msgstr ""
"      --keep-directory-symlink\n"
"         suivre les liens symboliques existants vers les répertoires\n"

#: src/cp.c:225
msgid ""
"  -l, --link\n"
"         hard link files instead of copying\n"
msgstr ""
"  -l, --link\n"
"         lier les fichiers au lieu de les copier\n"

#: src/cp.c:229
msgid ""
"  -n, --no-clobber\n"
"         (deprecated) silently skip existing files.  See also --update\n"
msgstr ""
"  -n, --no-clobber\n"
"         (déprécié) passe outre les fichiers existants sans message.\n"
"         Voyez aussi --update\n"

#: src/cp.c:233
msgid ""
"  -p\n"
"         same as --preserve=mode,ownership,timestamps\n"
msgstr ""
"  -p\n"
"         comme --preserve=mode,ownership,timestamps\n"

#: src/cp.c:237
msgid ""
"      --preserve[=ATTR_LIST]\n"
"         preserve the specified attributes\n"
msgstr ""
"      --preserve[=LISTE_ATTR]\n"
"         préserver les attributs spécifiés\n"

#: src/cp.c:241
msgid ""
"      --no-preserve=ATTR_LIST\n"
"         don't preserve the specified attributes\n"
msgstr ""
"      --no-preserve=LISTE_ATT\n"
"         ne pas préserver les attributs spécifiques\n"

#: src/cp.c:245
msgid ""
"      --parents\n"
"         use full source file name under DIRECTORY\n"
msgstr ""
"      --parents\n"
"         utiliser le nom du fichier source complet à\n"
"         l'intérieur de RÉPERTOIRE\n"

#: src/cp.c:249
msgid ""
"  -R, -r, --recursive\n"
"         copy directories recursively\n"
msgstr ""
"  -R, -r, --recursive\n"
"         copier récursivement les répertoires\n"

#: src/cp.c:253
msgid ""
"      --reflink[=WHEN]\n"
"         control clone/CoW copies. See below\n"
msgstr ""
"      --reflink[=QUAND]\n"
"         contrôler les copies clones/COW (Copy On Write). Voir ci-dessous\n"

#: src/cp.c:257
msgid ""
"      --remove-destination\n"
"         remove each existing destination file before attempting to open it\n"
"         (contrast with --force)\n"
msgstr ""
"      --remove-destination\n"
"         supprimer chaque fichier de destination existant avant d'essayer "
"de\n"
"         l'ouvrir (par opposition à --force)\n"

#: src/cp.c:262
msgid ""
"      --sparse=WHEN\n"
"         control creation of sparse files. See below\n"
msgstr ""
"      --sparse=QUAND\n"
"         contrôler la création des fichiers partiellement\n"
"         alloués. Voir ci-dessous\n"

#: src/cp.c:266 src/mv.c:300
msgid ""
"      --strip-trailing-slashes\n"
"         remove any trailing slashes from each SOURCE argument\n"
msgstr ""
"      --strip-trailing-slashes\n"
"         enlever les « / » de terminaison de chaque argument SOURCE\n"

#: src/cp.c:270
msgid ""
"  -s, --symbolic-link\n"
"         make symbolic links instead of copying\n"
msgstr ""
"  -s, --symbolic-link\n"
"         créer des liens symboliques au lieu d'une copie\n"

#: src/cp.c:274 src/install.c:673 src/ln.c:483 src/mv.c:304
msgid ""
"  -S, --suffix=SUFFIX\n"
"         override the usual backup suffix\n"
msgstr ""
"  -S, --suffix=SUFFIXE\n"
"         remplacer le suffixe habituel d'archivage\n"

#: src/cp.c:278 src/install.c:677
msgid ""
"  -t, --target-directory=DIRECTORY\n"
"         copy all SOURCE arguments into DIRECTORY\n"
msgstr ""
"  -t, --target-directory=RÉPERTOIRE\n"
"         copier tous les arguments SOURCE dans RÉPERTOIRE\n"

#: src/cp.c:282 src/install.c:681 src/mv.c:312
msgid ""
"  -T, --no-target-directory\n"
"         treat DEST as a normal file\n"
msgstr ""
"  -T, --no-target-directory\n"
"         traiter DEST comme un fichier normal\n"

#: src/cp.c:286 src/mv.c:316
msgid ""
"      --update[=UPDATE]\n"
"         control which existing files are updated;\n"
"         UPDATE={all,none,none-fail,older(default)}\n"
msgstr ""
"      --update[=QUOI]\n"
"         contrôle quels fichiers existants sont mis à jour ;\n"
"         QUOI={all(tous),none(aucun),none-fail,older(plus vieux, par "
"défaut)}\n"

#: src/cp.c:291 src/mv.c:321
msgid ""
"  -u\n"
"         equivalent to --update[=older].  See below\n"
msgstr ""
"  -u\n"
"         équivalent à --update[=older].  Voyez ci-dessous\n"

#: src/cp.c:295 src/mv.c:325 src/rm.c:179
msgid ""
"  -v, --verbose\n"
"         explain what is being done\n"
msgstr ""
"  -v, --verbose\n"
"         expliquer ce qui est fait\n"

#: src/cp.c:299
msgid ""
"  -x, --one-file-system\n"
"         stay on this file system\n"
msgstr ""
"  -x, --one-file-system\n"
"         reste sur ce système de fichier\n"

#: src/cp.c:303
msgid ""
"  -Z\n"
"         set SELinux security context of destination file to default type\n"
msgstr ""
"  -Z\n"
"         définir le contexte de sécurité SELinux au type par défaut\n"

#: src/cp.c:307 src/install.c:698 src/mkdir.c:82 src/mkfifo.c:67 src/mknod.c:69
msgid ""
"      --context[=CTX]\n"
"         like -Z, or if CTX is specified then set the\n"
"         SELinux or SMACK security context to CTX\n"
msgstr ""
"      --context[=CTX]\n"
"         comme -Z ou, si CTX est indiqué, définir le contexte\n"
"         de sécurité SELinux ou SMACK à CTX\n"

#: src/cp.c:314
msgid ""
"\n"
"ATTR_LIST is a comma-separated list of attributes. Attributes are 'mode' "
"for\n"
"permissions (including any ACL and xattr permissions), 'ownership' for user\n"
"and group, 'timestamps' for file timestamps, 'links' for hard links, "
"'context'\n"
"for security context, 'xattr' for extended attributes, and 'all' for all\n"
"attributes.\n"
msgstr ""
"\n"
"LISTE_ATTR est une liste d'attributs séparés par des virgules. Les attributs "
"sont\n"
"« mode » pour les permissions (y compris toutes les permissions ACL et "
"xattr),\n"
"« ownership » pour un utilisateur ou un groupe, « timestamps » pour "
"l'horodatage\n"
"de fichiers, « links » pour des liens en dur, « context » pour le contexte "
"de\n"
"sécurité, « xattr » pour les attributs étendus et « all » pour tous les "
"attributs\n"

#: src/cp.c:322
msgid ""
"\n"
"By default, sparse SOURCE files are detected by a crude heuristic and the\n"
"corresponding DEST file is made sparse as well.  That is the behavior\n"
"selected by --sparse=auto.  Specify --sparse=always to create a sparse DEST\n"
"file whenever the SOURCE file contains a long enough sequence of zero "
"bytes.\n"
"Use --sparse=never to inhibit creation of sparse files.\n"
msgstr ""
"\n"
"Par défaut, les fichiers SOURCE partiellement alloués sont détectés à "
"l'aide\n"
"d'une heuristique grossière et le fichier DEST correspondant est aussi\n"
"partiellement alloué. C'est le comportement sélectionné par --sparse=auto.\n"
"Indiquez --sparse=always pour créer un fichier DEST partiellement alloué\n"
"lorsque le fichier SOURCE contient une assez longue séquence d'octets nuls.\n"
"Utilisez --sparse=never pour inhiber la création de fichiers partiellement\n"
"alloués.\n"

#: src/cp.c:331
msgid ""
"\n"
"By default or with --reflink=auto, cp will try a lightweight copy, where "
"the\n"
"data blocks are copied only when modified, falling back to a standard copy\n"
"if this is not possible.  With --reflink[=always] cp will fail if CoW is "
"not\n"
"supported, while --reflink=never ensures a standard copy is performed.\n"
msgstr ""
"\n"
"Par défaut ou avec --reflink=auto, cp essaie de réaliser une copie légère, "
"où\n"
"les blocs de données ne sont copiés que s'ils sont modifiés. La copie "
"standard\n"
"est utilisée si la copie légère n'est pas possible. Avec --"
"reflink[=always],\n"
"cp échoue si la copie à l'écriture n'est pas supportée tandis que --"
"reflink=never\n"
"garanti qu'une copie classique est réalisée.\n"

#: src/cp.c:339
msgid ""
"\n"
"As a special case, cp makes a backup of SOURCE when the force and backup\n"
"options are given and SOURCE and DEST are the same name for an existing,\n"
"regular file.\n"
msgstr ""
"\n"
"cp réalise une archive de SOURCE dans le cas particulier où les options\n"
"« force » et « backup » sont utilisées et que SOURCE et DEST portent le\n"
"même nom qu'un fichier normal existant.\n"

