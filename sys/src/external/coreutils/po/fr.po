#: src/pinky.c:487
msgid "  -l     produce long format output for the specified USERs\n"
msgstr "  -l     afficher au format long pour les UTILISateurs indiqués\n"

#: src/pinky.c:490
msgid "  -b     omit the user's home directory and shell in long format\n"
msgstr ""
"  -b     omettre le répertoire personnel de l'utilisateur et son "
"interpréteur de commandes au format long\n"

#: src/pinky.c:493
msgid "  -h     omit the user's project file in long format\n"
msgstr ""
"  -h     omettre le fichier de projet de l'utilisateur au format long\n"

#: src/pinky.c:496
msgid "  -p     omit the user's plan file in long format\n"
msgstr "  -p     omettre le fichier de plan de l'utilisateur au format long\n"

#: src/pinky.c:499
msgid "  -s     do short format output, this is the default\n"
msgstr "  -s     afficher au format court, c'est le comportement par défaut\n"

#: src/pinky.c:502
msgid "  -f     omit the line of column headings in short format\n"
msgstr "  -f     omettre la ligne d'en-tête des colonnes au format court\n"

#: src/pinky.c:505
msgid "  -w     omit the user's full name in short format\n"
msgstr "  -w     omettre le nom complet de l'utilisateur au format court\n"

#: src/pinky.c:508
msgid "  -i     omit the user's full name and remote host in short format\n"
msgstr ""
"  -i     omettre le nom complet de l'utilisateur et le nom de l'hôte au "
"format court\n"

#: src/pinky.c:511
msgid ""
"  -q     omit the user's full name, remote host and idle time in short "
"format\n"
msgstr ""
"  -q     omettre le nom complet de l'utilisateur, le nom de l'hôte et le "
"temps d'inactivité au format court\n"

#: src/pinky.c:514
msgid ""
"      --lookup\n"
"         attempt to canonicalize hostnames via DNS\n"
msgstr ""
"      --lookup\n"
"         utiliser la forme canonique des noms d'hôte grâce au DNS\n"

