#, c-format
msgid ""
"Usage: %s [OPTION]... [FILE]\n"
"  or:  %s -e [OPTION]... [ARG]...\n"
"  or:  %s -i LO-HI [OPTION]...\n"
msgstr ""
"Utilisation : %s [OPTION]... [FICHIER]\n"
"         ou : %s -e [OPTION]... [ARG]...\n"
"         ou : %s -i MIN-MAX [OPTION]...\n"

#: src/shuf.c:62
msgid "Write a random permutation of the input lines to standard output.\n"
msgstr ""
"Afficher une permutation aléatoire des lignes entrées sur la sortie "
"standard.\n"

#: src/shuf.c:69
msgid "  -e, --echo                treat each ARG as an input line\n"
msgstr ""
"  -e, --echo                traiter chaque ARG comme une ligne d'entrée\n"

#: src/shuf.c:72
msgid ""
"  -i, --input-range=LO-HI   treat each number LO through HI as an input "
"line\n"
msgstr ""
"  -i, --input-range=MIN-MAX  traiter chaque nombre de MIN à MAX comme une "
"ligne d'entrée\n"

#: src/shuf.c:75
msgid "  -n, --head-count=COUNT    output at most COUNT lines\n"
msgstr "  -n, --head-count=N        afficher au plus N lignes\n"

#: src/shuf.c:78
msgid ""
"  -o, --output=FILE         write result to FILE instead of standard output\n"
msgstr ""
"  -o, --output=FICHIER      écrire le résultat dans FICHIER au lieu de la "
"sortie standard\n"

#: src/shuf.c:81
msgid "      --random-source=FILE  get random bytes from FILE\n"
msgstr ""
"      --random-source=FICHIER  obtenir des octets aléatoires de FICHIER\n"

#: src/shuf.c:84
msgid "  -r, --repeat              output lines can be repeated\n"
msgstr ""
"  -r, --repeat              les lignes affichées peuvent être répétées\n"

#: src/shuf.c:87
