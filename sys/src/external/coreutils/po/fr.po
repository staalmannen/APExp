msgstr "  -e                       équivalent à -vE\n"

#: src/cat.c:112
msgid "  -E, --show-ends          display $ or ^M$ at end of each line\n"
msgstr ""
"  -E, --show-ends          afficher $ ou ^M$ à la fin de chaque ligne\n"

#: src/cat.c:115
msgid "  -n, --number             number all output lines\n"
msgstr "  -n, --number             numéroter toutes les lignes en sortie\n"

#: src/cat.c:118
msgid "  -s, --squeeze-blank      suppress repeated empty output lines\n"
msgstr ""
"  -s, --squeeze-blank      supprimer les lignes vides qui se répètent en "
"sortie\n"

#: src/cat.c:121
