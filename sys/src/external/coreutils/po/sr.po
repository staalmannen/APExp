msgstr "„%s“ је замењено"

#: src/tail.c:1629
msgid "using notification mode"
msgstr "користи режим обавештавања"

#: src/tail.c:1691
#, c-format
msgid "error waiting for inotify and output events"
msgstr "грешка чекања на излазне и догађаје инотифија"

#: src/tail.c:1710
#, c-format
