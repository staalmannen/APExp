"      --ignore-fail-on-non-empty\n"
"         ignore each failure to remove a non-empty directory\n"
msgstr ""
"      --ignore-fail-on-non-empty\n"
"         занемарује сваки неуспех уклањања директоријума који није празан\n"

#: src/rmdir.c:181
msgid ""
"  -p, --parents\n"
"         remove DIRECTORY and its ancestors;\n"
"         e.g., 'rmdir -p a/b' is similar to 'rmdir a/b a'\n"
msgstr ""
"  -p, --parents\n"
"         уклања ДИРЕКТОРИЈУМ и све његове старије;\n"
"         нпр., „rmdir -p a/b/c“ је слично са „rmdir a/b a“\n"

#: src/rmdir.c:186
