#: src/pinky.c:487
msgid "  -l     produce long format output for the specified USERs\n"
msgstr "  -l     даје излаз дугог записа за наведеног КОРИСНИКА\n"

#: src/pinky.c:490
msgid "  -b     omit the user's home directory and shell in long format\n"
msgstr ""
"  -b              изоставља корисников лични директоријум и шкољку у дугом "
"запису\n"

#: src/pinky.c:493
msgid "  -h     omit the user's project file in long format\n"
msgstr "  -h     изоставља корисникову датотеку пројекта у дугом запису\n"

#: src/pinky.c:496
msgid "  -p     omit the user's plan file in long format\n"
msgstr "  -p     изоставља корисникову датотеку плана у дугом запису\n"

#: src/pinky.c:499
msgid "  -s     do short format output, this is the default\n"
msgstr "  -s     даје излаз кратког записа, ово је основно\n"

#: src/pinky.c:502
msgid "  -f     omit the line of column headings in short format\n"
msgstr "  -f     изоставља ред заглавља ступца у кратком запису\n"

#: src/pinky.c:505
msgid "  -w     omit the user's full name in short format\n"
msgstr "  -w     изоставља корисниково име и презиме у кратком запису\n"

#: src/pinky.c:508
msgid "  -i     omit the user's full name and remote host in short format\n"
msgstr ""
"  -i     изоставља корисниково име и презиме, удаљеног домаћина у кратком "
"запису\n"

#: src/pinky.c:511
msgid ""
"  -q     omit the user's full name, remote host and idle time in short "
"format\n"
msgstr ""
"  -q     изоставља корисниково име и презиме, удаљеног домаћина и време "
"мировања у кратком запису\n"

#: src/pinky.c:514
