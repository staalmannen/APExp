msgid "Usage: %s --coreutils-prog=PROGRAM_NAME [PARAMETERS]... \n"
msgstr "Употреба: %s --coreutils-prog=НАЗИВ_ПРОГРАМА [ПАРАМЕТРИ]... \n"

