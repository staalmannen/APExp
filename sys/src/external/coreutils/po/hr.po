"  -s, --signal=SIGNAL, -SIGNAL\n"
"         specify the name or number of the signal to be sent\n"
msgstr ""
"  -s, --signal=SIGNAL, -SIGNAL\n"
"         navodi naziv ili broj signala koji se šalje\n"

#: src/kill.c:75
msgid ""
"  -l, --list\n"
"         list signal names, or convert signal names to/from numbers\n"
msgstr ""
"  -l, --list\n"
"         ispisuje nazive signala ili ih pretvara u brojeve i obratno\n"

#: src/kill.c:79
