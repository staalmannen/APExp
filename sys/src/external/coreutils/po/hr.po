msgstr "nije moguće promijeniti vlasništvo zq %s"

#: src/install.c:478
#, c-format
msgid "cannot set timestamps for %s"
msgstr "neuspjelo postavljanje vremenskih oznaka za %s"

#: src/install.c:522
#, c-format
msgid "cannot run %s"
msgstr "neuspjelo pokretanje %s"

#: src/install.c:523
#, c-format
