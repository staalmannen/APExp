msgstr "Uporaba: %s\n"

#: src/getlimits.c:89
msgid ""
"Output platform dependent limits in a format useful for shell scripts.\n"
"\n"
msgstr ""
"Ispisuje ograničenja ovisna o platformi u formatu korisnom za ljuske "
"(shell).\n"
"\n"

