msgstr "neispravna baza adrese '%c'; mora biti jedan znak iz [doxn]"

#: src/od.c:1877
#, c-format
msgid "no type may be specified when dumping strings"
msgstr "nije dopušteno navođenje VRSTE pri ispisu stringova"

#: src/od.c:1952
