msgstr ""
"  -M, --macro-name=ZKETTE        Makroname, der statt „xx“ zu benutzen ist\n"

#: src/ptx.c:1696
msgid "  -O, --format=roff              generate output as roff directives\n"
msgstr ""
"  -O, --format=roff              Ausgabe als roff‐Anweisungen erzeugen\n"

#: src/ptx.c:1699
