</$objtype/mkfile

LIB=/$objtype/lib/ape/libc++.a

# string.cpp contributes string::npos and the iostream operators for string.
# The old libSC Pool_std.cpp / std_*.cpp files are not used — the string
# class itself is now fully inline in h/string.h.
OFILES=string.$O

</sys/src/cmd/mksyslib

CXXINCL=/sys/include/ape/c++
CFLAGS=-FV -I.
CC=pcc

# string.cpp is plain C++ that includes h/string.h — compile with driver
string.c: string.cpp
	c++ -F -I$CXXINCL $prereq > $target

CLEANFILES=*.c
