# bash.pc.in

prefix=/usr/local
exec_prefix=${prefix}
includedir=/sys/include/ape
libdir=/amd64/lib/ape

loadablesdir=${libdir}/bash
headersdir=${includedir}/bash

DEFS = -DHAVE_CONFIG_H
LOCAL_DEFS = -DSHELL
LOCAL_CFLAGS = 
CCFLAGS = ${DEFS} ${LOCAL_DEFS} ${LOCAL_CFLAGS}

CC = cc
SHOBJ_CC = 
SHOBJ_CFLAGS = 
SHOBJ_LD = 
SHOBJ_LDFLAGS = 
SHOBJ_XLDFLAGS = 
SHOBJ_LIBS = 

Name: bash
Description: Bash headers for bash loadable builtins
Version: 5.3-release
Url: 
Libs: ${SHOBJ_LIBS}
Cflags: ${SHOBJ_CFLAGS} ${CCFLAGS} -I${headersdir} -I${headersdir}/builtins -I${headersdir}/include
