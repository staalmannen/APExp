|     const char *string = "NaN";
|     char *term;
|     strtod (string, &term);
|     if (term != string && *(term - 1) == 0)
|       result |= 1;
|   }
|   {
|     /* Older glibc and Cygwin mis-parse "-0x".  */
|     const char *string = "-0x";
|     char *term;
|     double value = strtod (string, &term);
