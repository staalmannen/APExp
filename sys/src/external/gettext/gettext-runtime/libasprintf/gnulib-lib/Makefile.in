libgnu.la: $(libgnu_la_OBJECTS) $(libgnu_la_DEPENDENCIES) $(EXTRA_libgnu_la_DEPENDENCIES) 
	$(AM_V_CCLD)$(libgnu_la_LINK)  $(libgnu_la_OBJECTS) $(libgnu_la_LIBADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f unicase/*.$(OBJEXT)
	-rm -f unicase/*.lo
	-rm -f unictype/*.$(OBJEXT)
	-rm -f unictype/*.lo
	-rm -f uniwidth/*.$(OBJEXT)
	-rm -f uniwidth/*.lo

distclean-compile:
	-rm -f *.tab.c

