|       return 4;
|     }
|   for (i = 0; ; i++)
|     if ((m >> i) & 1)
|       break;
|   fprintf (fp, "word %d bit %d", (int) k, (int) i);
|   if (fclose (fp) != 0)
|     return 5;
|   return 0;
| }
