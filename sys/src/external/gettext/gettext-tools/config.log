| static memory_float minus = { -1.0L };
| int main ()
| {
|   size_t j, k, i;
|   unsigned int m;
|   FILE *fp = fopen ("conftest.out", "w");
|   if (fp == NULL)
|     return 1;
|   /* Find the different bit.  */
|   k = 0; m = 0;
|   for (j = 0; j < NWORDS; j++)
|     {
|       unsigned int x = plus.word[j] ^ minus.word[j];
|       if ((x & (x - 1)) || (x && m))
|         {
|           /* More than one bit difference.  */
|           fprintf (fp, "unknown");
|           fclose (fp);
|           return 2;
|         }
|       if (x)
