</$objtype/mkfile
APEXPROOT=../../../../..

TARG=	\
	msgfmt\
	msgmerge\

PARSEROBJS=	poparser.$O poparser_sysdep.$O StringEscape.$O

BIN=$APEXPROOT/$objtype/bin/ape


<$APEXPROOT/sys/src/cmd/mkmany

GETTEXTSRC=../../../external/gettext


CC=pcc
CFLAGS=-Fw -B -c


%.$O: $GETTEXTSRC/src/%.c
	$CC $CFLAGS $GETTEXTSRC/src/$stem.c

$O.msgfmt: msgfmt.$O $PARSEROBJS
	$CC -o $O.msgfmt msgfmt.$O $PARSEROBJS

$O.msgmerge: msgmerge.$O
	$CC -o $O.msgmerge msgmerge.$O $PARSEROBJS

install:V:
	cat $GETTEXTSRC/src/autopoint.in | sed 's,@datadir@,"/sys/lib/ape",' > $APEXPROOT/rc/bin/ape/autopoint
	cp $GETTEXTSRC/src/xgettext.sh $APEXPROOT/rc/bin/ape/xgettext
	chmod +x $APEXPROOT/rc/bin/ape/*







