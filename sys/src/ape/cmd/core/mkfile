APEXPROOT=../../../../..
APE=$APEXPROOT/sys/src/ape
<$APE/config

LIB= libcoreutils.a$O

TARG=


LIBOBJS=\


BIN=$APEXPROOT/$objtype/bin/ape

<$APEXPROOT/sys/src/cmd/mkmany

CORESRC=../../../external/coreutils

CC=pcc
LD=pcc

CFLAGS=-c -D_POSIX_SOURCE


%.$O: $CORESRC/src/%.c
