APEXPROOT=../../../../..
APE=$APEXPROOT/sys/src/ape
<$APE/config

LIB=$APEXPROOT/$objtype/lib/ape/libtk.a

TKSRC=$APEXPROOT/sys/src/external/tk
TCLSRC=$APEXPROOT/sys/src/external/tcl

XLIB_OBJS=\
	xcolors.$O\
	xdraw.$O\
	xgc.$O\
	ximage.$O\
	xutil.$O\

PLAN9_OBJS=\
