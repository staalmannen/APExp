UNIX_OBJS=\
	tkUnix3d.$O\
	tkUnixButton.$O\
	tkUnixConfig.$O\
	tkUnixCursor.$O\
	tkUnixDraw.$O\
	tkUnixFocus.$O\
	tkUnixMenu.$O\
	tkUnixMenubu.$O\
	tkUnixScale.$O\
	tkUnixScrlbr.$O\
	tkUnixXId.$O\

# Plan9 objects come first so our implementations win over xlib/ stubs
# (e.g. our XCreateWindow beats xgc.c's stub that returns 0).
# UNIX_OBJS come after TTK_OBJS; duplicate symbols (TkpScanWindowId,
# TkpChangeFocus, TkpCmapStressed) are silently skipped — plan9/ wins.
OFILES=\
	$PLAN9_OBJS\
	$DRAWIMPL_OBJ\
	$GENERIC_OBJS\
	$TTK_OBJS\
	$UNIX_OBJS\
	$XLIB_OBJS\

# Flags for generic/ and plan9/ files (APE headers + Tk includes)
CFLAGS=\
	-FVp -c\
	-I.\
	-I$TKSRC/generic\
	-I$TKSRC/generic/ttk\
	-I$TKSRC/xlib\
	-I$TKSRC/plan9\
	-I$TCLSRC/generic\
	-I$TCLSRC/plan9\
	-I$APEXPROOT/sys/include/ape\
	-I$APEXPROOT/$objtype/include/ape\
	-DHAVE_TCL_CONFIG_H\
	-DHAVE_TK_CONFIG_H\
	-DPLAN9\
	-DMODULE_SCOPE=/***/\
	-DWCHAR=char\
	-DTK_PLATFORM="plan9"\
	-DUSE_TCL_STUBS\

# DrawImpl uses APE's Plan 9 extension headers (draw.h, mouse.h, u.h)
# It must NOT include Xlib.h; add -DPLAN9_SOURCE to enable draw.h.
DRAWIMPL_CFLAGS=\
	-FVp -c\
	-I$TKSRC/plan9\
	-I$APEXPROOT/sys/include/ape\
	-I$APEXPROOT/$objtype/include/ape\
	-D_PLAN9_SOURCE\

HFILES=\
	tkConfig.h\

<$APEXPROOT/sys/src/cmd/mklib

$DRAWIMPL_OBJ: $TKSRC/plan9/tkPlan9DrawImpl.c
	$CC $DRAWIMPL_CFLAGS $TKSRC/plan9/tkPlan9DrawImpl.c

%.$O: $TKSRC/plan9/%.c
	$CC $CFLAGS $TKSRC/plan9/$stem.c

%.$O: $TKSRC/xlib/%.c
	$CC $CFLAGS $TKSRC/xlib/$stem.c

%.$O: $TKSRC/generic/%.c
	$CC $CFLAGS $TKSRC/generic/$stem.c

%.$O: $TKSRC/generic/ttk/%.c
	$CC $CFLAGS $TKSRC/generic/ttk/$stem.c

%.$O: $TKSRC/unix/%.c
	$CC $CFLAGS $TKSRC/unix/$stem.c

clean:V:
	rm -f $LIB
	rm -f *.$O
