</$objtype/mkfile
APEXPROOT=../../../../..
LIB=$APEXPROOT/$objtype/lib/ape/libpcre2posix.a

OFILES=pcre2posix.$O

</sys/src/cmd/mksyslib

PCRESRC=../../../external/pcre2


CC=pcc
LD=pcc
CFLAGS=-c -I. -I$PCRESRC/src -DHAVE_CONFIG_H -DPCRE2_CODE_UNIT_WIDTH=32

%.$O: $PCRESRC/src/%.c
	$CC $CFLAGS $PCRESRC/src/$stem.c

nuke:V:
	mk clean
	rm -f $LIB
	rm -f $APEXPROOT/$objtype/lib/ape/libpcreposix.a

