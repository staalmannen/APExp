LIB=$APEXPROOT/$objtype/lib/ape/libedit.a

OFILES=	chared.$O\
		common.$O\
		el.$O\
		eln.$O\
		emacs.$O\
		hist.$O\
		keymacro.$O\
		map.$O\
		chartype.$O\
		parse.$O\
		prompt.$O\
		read.$O\
		refresh.$O\
		search.$O\
		sig.$O\
		terminal.$O\
		tty.$O\
		vi.$O\
		reallocarr.$O\
		wcsdup.$O\
		tokenizer.$O\
