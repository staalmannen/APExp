APEXPROOT=../../../../../..
APE=$APEXPROOT/sys/src/ape
<$APE/config
LIB=$APEXPROOT/$objtype/lib/ape/libap.a

# split malloc into malloc, free and realloc

OFILES=\
	calloc.$O\
	malloc.$O\
	free.$O\
	realloc.$O\
	setmalloctag.$O\
	setrealloctag.$O\
# claude ported from musl / APE malloc internals\
	posix_memalign.$O\
	reallocarray.$O\
	memalign.$O\
	aligned_alloc.$O\
# GNU xalloc family\
	xmalloc.$O\

<$APEXPROOT/sys/src/cmd/mksyslib

CFLAGS=$CFLAGS -c -D_POSIX_SOURCE -D_PLAN9_SOURCE -I../include
