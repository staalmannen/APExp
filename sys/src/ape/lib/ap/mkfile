APEXPROOT=../../../../../
APE=$APEXPROOT/sys/src/ape
<$APE/config

DIRS=\
	aio\
	complex\
	conf\
	ctype\
	dirent\
	env\
	errno\
	exit\
	fcntl\
	fenv\
	fmt\
	legacy\
	locale\
	malloc\
	math\
	misc\
	mp\
	multibyte\
	network\
	passwd\
	plan9\
	prng\
	process\
	regex\
	search\
	sched\
	select\
	signal\
	stat\
	stdio\
	stdlib\
	string\
	syscall\
	temp\
	termcap\
	termios\
	thread\
	time\
	unistd\

default:V:	all

install all:V:
	for(i in $DIRS)@{
		echo $i
		cd $i
		mk $MKFLAGS $target
	}
	for(j in $objtype)@{
		echo arch/$j
		cd arch/$j
		mk $MKFLAGS $target
	}


installall:V:
	for(objtype in $CPUS)@{
		mk $MKFLAGS install
	}


clean nuke:V:
	for(i in $DIRS)@{
		echo $i
		cd $i
		mk $MKFLAGS $target
	}
