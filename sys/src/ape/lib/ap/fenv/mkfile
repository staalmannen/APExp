APEXPROOT=../../../../../..
APE=$APEXPROOT/sys/src/ape
<$APE/config
LIB=$APEXPROOT/$objtype/lib/ape/libap.a

OFILES=\
# musl \
	fegetexceptflag.$O\
	feholdexcept.$O\
	fesetexceptflag.$O\
	fesetround.$O\
	feupdateenv.$O\
	fenv.$O

<$APEXPROOT/sys/src/cmd/mksyslib

CC=pcc
CFLAGS=$CFLAGS -c -D_POSIX_SOURCE -D_BSD_SOURCE\
		-I$APEXPROOT/sys/include/ape -I$APEXPROOT/$objtype/include/ape
		-
# default
_archdir=dummy
_compiler=$CC
_srcext=c
_flags=$CFLAGS

# if matching arch directory present
ASMARCHS= 386 amd64 arm64 mips power
if ($objtype in $ASMARCHS)@{
		_archdir=$objtype
		_compiler=$Oa
		_srcext=s
		_flags=
	}

fenv.$O: $_archdir/fenv.$_srcext
	$_compiler $_flags -o $target $prereq


